  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Lyse cells directly in the 6-well plate (add appropriate volume of RLT buffer with β-mercaptoethanol).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Homogenise lysate and proceed with binding to RNeasy spin column per kit instructions.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Wash with RW1 and RPE buffers; dry spin to remove ethanol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Elute RNA in RNase-free water (e.g., 30–50 μL). Measure concentration and purity (A260/280).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Prepare RT master mix on ice according to kit protocol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Combine RNA (typically 500 ng–1 μg) with RT master mix to desired reaction volume.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate per kit cycling (genomic DNA wipeout if applicable) and hold on ice.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Prepare TaqMan® master mix for each assay (Master Mix + 20× Assay + nuclease-free water).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Dispense master mix into wells and add cDNA template (equal volume across wells).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Seal plate, briefly spin to remove bubbles.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Hold: 95 °C for 10 min",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "PCR (40 cycles): 95 °C for 15 s; 60 °C for 60 s (data acquisition at anneal/extend step)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Confirm amplification plots and absence of signal in NTC/−RT controls.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "For each sample and target, compute ΔCt = Ct(target) − Ct(GAPDH).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Select a calibrator group (e.g., undifferentiated control). Compute ΔΔCt = ΔCt(sample) − mean ΔCt(calibrator).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Fold-change = 2^(−ΔΔCt). Report mean ± SEM from biological replicates.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Reproducible triplicate Ct values (SD ≤ 0.3 cycles). Clear separation between target and NTC/−RT.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "High Ct variability → check pipetting accuracy and RNA integrity.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Signal in NTC/−RT → assess contamination or gDNA carryover; include DNase step.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Low efficiency → verify assay IDs and storage; avoid freeze-thaw cycles.",
      "is_critical": false,
      "timers": []
    }
  ],
