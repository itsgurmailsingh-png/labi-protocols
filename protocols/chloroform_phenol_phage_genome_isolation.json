  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Use cleaned phage stock from the phage stock protocol. Add 50 µL DNase I 10x buffer, 1 µL DNase I (1 U/µL), and 1 µL RNase A (10 mg/mL) for 01:30:00 at 37 °C without shaking to remove E. coli DNA and RNA.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 20 µL of 0.5 Molarity (M) EDTA (final concentration 20 Molarity (M) ) and incubate for 00:15:00 at 75 °C to deactivate DNase I and RNase A",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 2 µL Proteinase K (20 mg/mL) and 50 µL SDS 10% to digest the phage capsid and incubate overnight at 56 °C without shaking.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add equal volume phenol/chloroform/iosamyl alcohol (25:24:1) and mix well (do not vortex, as genome is easily damaged)",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge at room temperature for 00:10:00 at 10000 x g",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Carefully take aqueous phase",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add equal volume chloroform/isoamyl alcohol (24:1) and mix well (do not vortex, as genome is easily damaged)",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Centrifuge at room temperature for 00:10:00 at 10000 x g",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Carefully take aqueous phase",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 1/10 volume of Sodium acetate 3 Molarity (M)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add 2,5 volume of 100% Ethanol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Incubate at for 00:30:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Centrifuge for 00:10:00 at 4668 x G",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Discard supernatant",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Rinse pellet with 70 % ethanol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Dry pellet. Heating to 50 °C c increases drying.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Dissolve pellet in MQ water",
      "is_critical": false,
      "timers": []
    }
  ],
