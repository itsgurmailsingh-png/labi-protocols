  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Coat T25 flask, chamber slide and plates with Matrigel 01:00:00 prior to passaging.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Aspirate media from cell culture.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Wash with 1 mL PBS per well and aspirate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 1 mL Accutase per well of 6 well plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate in 37 °C for 3-4 minutes. 00:03:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Collect cells from 2 wells with 3 mL DMEM/F12 per well and transfer into 15mL conical A.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Collect cells from 4 wells with 3 mL DMEM/F12 per well and transfer into 15mL conical B.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Spin cells at 750 rpm for 00:03:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Aspirate media from each tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "To 15mL conical tube A, add 2 mL mTesR1 and distribute cells.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Karyotype: Add 2 mL of mTesR1 to T25 flask, then add 500 µL cells .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "gDNA pellet: 500 µL cells in 1.7 mL tube, spin down at max speed for 00:00:15 , aspirate media, store in -80 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "RNA pellet: 900 µL cells in 1.7 mL tube, spin down at max speed for 00:00:15 , aspirate media, store in -80 °C",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "ICC: Dilute 100 µL cells in 750 µL mTesR1. Plate 200 µL cells per well in 4 wells of a chamber slide.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "To 15mL conical tube B, add 4 mL mTesR1 and 4 mL of 2x Freezing Media (20% DMSO, FBS).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Add 1 mL cell suspension to each vial (1 well will freeze down into approximately 2 vials). Cryovials need to be labeled with the following before freezing down: Cell Type Line Name Passage # Date Your Name",
      "is_critical": false,
      "timers": []
    }
  ],
