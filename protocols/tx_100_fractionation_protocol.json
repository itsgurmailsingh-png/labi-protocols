  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "If tissue stored at -80 °C , place in -20 °C for at least 04:00:00 or Overnight to thaw prior to homogenization.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Prepare 1X TNE with phosphatase and protease inhibitors.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Weigh tissue out in mg.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add in 10 volumes of 1X TNE. 10 µL of TNE per 1 mg of tissue. Ex: 50 mg tissue = 500 µL of 1X TNE.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Either by mechanical (Dounce) or homogenizer machine, homogenize tissue gently and On ice .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "This is TNE crude lysate (no detergents).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Take specific volume of tissue in TNE and add in equal volume of 1X TNE w/ 2% Triton X-100 (Tx100). Ex. 150 µL of TNE tissue + 150 µL 1X TNE+2% Tx100.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Sonicate @ 4 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Spin down.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "After spin:",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Wash pellet in 150 µL of 1X TNE+1% Tx100. Note : Same volume that was used above from TNE.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Resuspend pellet in 75 µL to 100 µL of cTNE.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Sonicate @ 4 °C : 3 pluses: 00:00:10 ON / 00:00:02 OFF.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Boil: 00:10:00 at 95 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Spin down: 16000 x g, 4 °C, 15 minutes .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Supernatant from this is the insoluble fraction .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "3 pulses: 00:00:10 ON / 00:00:02 OFF.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Option 1 : 16000 x g, 4 °C, 15 minutes .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Option 2 : 20000 x g, 4 °C, 1 hour .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Supernatant = soluble . Save supernatant and add equal volume of complete TNE (cTNE). Sonicate @ 4 °C : 3 pluses: 00:00:10 ON / 00:00:02 OFF. Boil: 00:10:00 at 95 °C . Spin down: 16000 x g, 4 °C, 15 minutes . Supernatant from this is the soluble fraction .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Pellet = insoluble .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Resuspend pellet via pipette.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Spin down. Option 1 : 16000 x g, 4 °C, 15 minutes . Option 2 : 20000 x g, 4 °C, 1 hour ( 25000 x g, °C, ) .",
      "is_critical": false,
      "timers": []
    }
  ],
