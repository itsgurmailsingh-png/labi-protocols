      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Pipette 1 aspirates 700µL from tube at position 1 on rack 1 with air gap",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Pipette 2 aspirates 700µL from tube at position 2 on rack 1 with air gap",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Pipette 1 dispenses full volume into tube at position 1 on rack 3",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Pipette 1 mixes using 1000µL volume 5x",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
