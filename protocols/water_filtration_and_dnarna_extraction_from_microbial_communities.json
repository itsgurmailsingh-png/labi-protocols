  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Sterilize forceps and scissors with burner, then bleach, then EtOH before each filtration",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Filter water sample, make sure to keep the filtration unit closed when opening the wrapping, to hold nothing but the sample over the unit, and to stand as far as possible away from the unit while it is open",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Cut filter into small pieces (forceps and scissors) while filter lays on the filtration unit, make sure to stand as far as possible away from the unit",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Transfer pieces into bashing tubes until all pieces are covered with DNA/RNA Shield",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Clean filtration unit adapter with bleach after each filtration",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Bashing tubes can be stored at -20°C",
