      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Aliquot 50 µL of each sample into three wells of 96-well plate to create triplicates",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
