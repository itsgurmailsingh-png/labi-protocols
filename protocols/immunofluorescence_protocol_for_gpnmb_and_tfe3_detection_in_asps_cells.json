  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Culture ASPS cell lines in Opti-MEM™ supplemented with 10% FBS for 48 hours on appropriate chamber slides or coverslips.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Fix the cells with 4% paraformaldehyde (PFA).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Permeabilize the fixed cells using 0.5% Triton X-100.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate cells overnight at 4°C with both primary antibodies simultaneously:",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Goat polyclonal anti-human GPNMB (R&amp;D Systems, AF2550) at 20 µg/mL",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Rabbit monoclonal anti-TFE3 (Sigma Cell Marque, 354R-15) at 1:25 dilution",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate with secondary antibodies at 1 µg/mL for 30 minutes at room temperature:",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Alexa Fluor® 647 Donkey anti-Goat IgG for GPNMB detection",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "DyLight™ 488 Donkey anti-rabbit IgG for TFE3 detection",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Mount the samples with one drop of ProLong™ Gold antifade reagent containing DAPI.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Digitalize the stained slides using the ECHO Revolve fluorescent microscope (ECHO, RVL-100-M) at 40× resolution.",
      "is_critical": false,
      "timers": []
    }
  ],
