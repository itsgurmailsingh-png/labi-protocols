      "step_id": 0,
      "title": "Work under sterile conditions",
      "instruction": "Always work under sterile conditions",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "Prepare initial reagent additions",
      "instruction": "Add CaCl 2 2H 2 O (3.6 g · L -1 ) If you do not have hydrated CaCl 2, use 2.718 g CaCl 2 (powder) for 1L of the stock. 0.25 M Na 2 -EDTA stock: Dissolve 2.32 g Na 2 -EDTA (powder) and fill the bottle up with MilliQ (nuclease-free) water up to 25 mL. Afterwards, the pH was adjusted with diluted NaOH to pH = 8.0. K2HPO4 (82,3g·L -1 )",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "Add Citric acid",
      "instruction": "Add Citric acid (0.6 g · L -1 )",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "Add Sodium Nitrate",
      "instruction": "Add NaNO3 (17 g · L-1)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "Add Magnesium Sulfate",
      "instruction": "Add MgSO4 · 7 H2O (7.49 g · L-1) If you do not have hydrated MgSO4, use 3.659 g MgSO4 (powder) for 1L of the stock.",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "Add EDTA stock solution",
      "instruction": "0.25 M Na 2 -EDTA, pH 8.0 (0.56 ml · L -1 )",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "Adjust volume with MilliQ water",
      "instruction": "Fill up with MiliQ water to one liter",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "Mix the solution",
      "instruction": "Mix the solution with a stir bar",
      "is_critical": false,
      "timers": []
    },
