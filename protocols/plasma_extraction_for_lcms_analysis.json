  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Transfer plasma 50 ul (regular pipette tips) into a 3 ml glass tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 200 ul of LCMS grade-chloroform/methanol (2:1)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Stand for 5 min at room temperature .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Vortex for 1 min",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Repeat steps 2-5",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge 12,000 g, for 5 min at 4c",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Use glass pipette tips to collect the lower organic phase and transfer the same tube in step 6.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Evaporate the extracted solvents to dryness",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Cap the tube, store at -20oC",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Deliver the sample to mass spec core.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Use glass pipette tips to collect the lower organic phase and transfer the liquid to a new glass tube .",
      "is_critical": false,
      "timers": []
    }
