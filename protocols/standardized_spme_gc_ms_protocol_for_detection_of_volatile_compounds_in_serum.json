  "materials": [
    "serum samples",
    "HPLC-grade methanol",
    "1.5 mL tube",
    "vortex mixer",
    "centrifuge",
    "0.5 mL Eppendorf tube",
    "DVB/CAR/PDMS fiber",
    "GC inlet",
    "GC injector"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Thaw serum samples on ice.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "In a 1.5 mL tube, mix: o 100 µL of blood serum o 200 µL of HPLC-grade methanol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Vortex for 30 seconds.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Let stand at room temperature for 15 minutes to allow protein precipitation.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge at 12,500 rpm for 10 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer the clear supernatant to a 0.5 mL Eppendorf tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Store the supernatant at 4°C if not analyzed immediately (up to 24 hours).",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Precondition the DVB/CAR/PDMS fiber as per manufacturer instructions.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Introduce the DVB/CAR/PDMS SPME fiber directly into the serum supernatant.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Allow extraction to proceed for 30 minutes at room temperature.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Immediately transfer the fiber to the GC inlet for thermal desorption. Optional : For volatile-only profiling, perform headspace extraction at 40 °C.",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Desorb the fiber in the GC injector at 270 °C for 5 min in splitless mode.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Run GC-MS with the specified temperature program.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Acquire mass spectra in full scan mode (m/z 50–650).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Perform peak deconvolution.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Identify compounds using the NIST library (Salek et al 2013).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Normalize peak areas and calculate retention indices (Sun and Stremple 2003).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Compare VOC profiles between Chagas-positive and negative groups.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Perform all extractions in triplicate to assess reproducibility.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Regularly clean the injector port and replace the septum to avoid carryover.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Ensure fibers are properly conditioned before use.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Store samples and extracts cold to avoid degradation.",
      "is_critical": false,
      "timers": []
    }
  ],
