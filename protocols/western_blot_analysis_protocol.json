  "category": "Protein Science",
  "estimated_time_mins": 90,
  "materials": [
    "1.5 ml microcentrifuge tube",
    "centrifuge",
    "DC ™ Protein Assay Kit",
    "SDS-PAGE gel",
    "Trans-Blot Turbo™ Transfer System",
    "PBS",
    "RIPA buffer",
    "cOmplete™ Protease Inhibitor",
    "Blocking One",
    "primary antibody",
    "TBST",
    "horseradish peroxidase-conjugated secondary antibody",
    "Chemi-Lumi One Super",
    "LAS-4000mini image analyzer"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Scrape cells and transfer the suspension to a 1.5 ml microcentrifuge tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Centrifuge at 10,000 x g for 5 minutes at 4°C and collect the supernatant in a new microcentrifuge tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Determine protein concentration by using DC ™ Protein Assay Kit.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Load 35 µg of total protein on a SDS-PAGE gel.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Run the gel for 1 h at 100 V.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer proteins onto a PVDF membrane using Trans-Blot Turbo™ Transfer System.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Wash the cells with ice-cold PBS and add ice-cold RIPA buffer with cOmplete™ Protease Inhibitor Cocktail.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Incubate the lysate on ice for 15 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Place the blot in Blocking One and incubate with agitation for 20 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Incubate the blot with appropriate dilutions of primary antibody at 4°C overnight.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Place the blot in TBST and wash three times, 5 minutes each.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Incubate the blot with the species-matched horseradish peroxidase-conjugated secondary antibody for 1 hour.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Place the blot in TBST and wash three times, 5 minutes each.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add Chemi-Lumi One Super to cover the blot and incubate for 1 minute.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Detect chemiluminescence using LAS-4000mini image analyzer.",
      "is_critical": false,
      "timers": []
    }
  ],
  "verification_status": "verified",
  "merged_at": "2026-06-18"
}