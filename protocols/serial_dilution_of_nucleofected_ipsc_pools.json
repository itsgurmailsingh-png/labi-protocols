  "quality_score": 6.5,
  "category": "Cell Biology",
  "estimated_time_mins": 78,
  "materials": [
    "Matrigel",
    "PBS",
    "Accutase",
    "DMEM/F12",
    "15mL conical tube",
    "mTesR1",
    "Rock Inhibitor",
    "iPSC Freezing Medium"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Coat 3 wells of a 6 well plate with 1 mL Matrigel (supplemented with RGD fragment)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Aspirate media from cells in culture.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Wash with 1 mL - 2 mL PBS per well.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 1 mL Accutase per well.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate at 37 °C for 00:10:00 to achieve single cells. Individual donor lines exhibit variable sensitivity to accutase-mediated dissociation. Monitor cells regularly to identify when cells achieve single cells.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Collect cells in 5 mL DMEM/F12 and transfer to a 15mL conical tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Spin at 750-800 rpm for 00:03:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Aspirate media.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Resuspend cells in mTesR1 supplemented with 5 uM Rock Inhibitor.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Plate several dilutions of cells over the three wells (typically 25 μl, 50 μl and 75 μl in 2 mL of mTesR1).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Freeze down the remaining cells by adding an equal volume of 2x iPSC Freezing Media (20% DMSO in FBS).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Incubate at 37 °C overnight.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Change mTesR1 the following day.",
      "is_critical": false,
      "timers": []
    }
  ],
  "verification_status": "verified",
  "merged_at": "2026-06-18"
}