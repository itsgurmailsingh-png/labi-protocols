  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Deparaffinize and hydrate to water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Oxidize in periodic acid solution for 5 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Rinse in distilled water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Place in Coleman’s Schiff reagent for 15 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Rinse in running tap water for 10 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Counterstain in Harris Hematoxylin for 3 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Wash in running tap water until water runs clear",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "10 dips in 0.5% HCl/70% Ethanol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Rinse in running tap water for 30 seconds",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "10 dips in 1% Ammonia water for 30 seconds",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "95% Ethanol, 2X, 2 minutes each",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "100% Ethanol, 2X, 2 minutes each",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Xylene, 2X, 2 minutes each",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Coverslip with Cytoseal",
      "is_critical": false,
      "timers": []
    }
