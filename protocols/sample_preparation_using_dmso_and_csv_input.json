  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "This protocol preps up to two 96 well plates with reagent and sample. The protocol takes a csv as input to determine which wells in the middle rack (see below) will be populated. The csv must include the header, with the following order in the header: `vial_id, parent_well, dmso_volume, daughter_column`. The protocol pauses midway through after the samples are placed and mixed in the middle plates for the user to inspect before resuming.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Read in CSV/Excel file that has a list of vial_ids, parent_wells, dmso_volumes, & daughter_columns.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Pick up new 1000 uL tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Take specified dmso_volume from the DMSO in position A1 of 50 mL conical holder in slot 8.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Touch tips to remove droplets from pipette tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add specified dmso_volume to parent_well position of CRO vial holder in slot 9.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Mix the vial at parent_well position of the CRO vial holder in slot 9 using half the dmso_volume added (same tip).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Touch tip to remove droplets from pipette tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Repeat steps 2-7 for all entries in the csv/excel file.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Pause to allow visual inspection of the vial.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Resume protocol after inspection.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Pick up new 300 uL Tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Aspirate 240 uL of compound from parent_well position of CRO vial holder in slot 9.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Touch tips to remove droplets from the pipette tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Dispense 30 uL into all tubes of daughter_column and touch tips after each dispense.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Discard tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Repeat steps 11-15 for all entries in the csv/excel file.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
