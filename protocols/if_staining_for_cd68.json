  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "ANTIGEN RETRIEVAL",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 500 µL 1 Molarity (M) Citrate buffer ( pH 6 ) in each well. Make sure the tissue is flat and completely in contact with the buffer!",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "00:30:00 incubation at 80 °C , 00:20:00 in the same buffer On ice .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "1X PBS rinse.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "1X PBS rinse.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "1X PBS 00:05:00 on the wobbler.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "250 µl blocking step : in 1 x PBS 0.1% Tergitol (ThermoScientific; 464252500; CAS: 68131-40-8) (PBS-T) + 10% Donkey serum (Jackson Immuno Research; 017-000-121; RRID: AB2337258) (accordingly to the secondary Abs) 00:40:00 incubation on the wobbler.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "250 µl Primary Ab CD68 (Abcam; Ab 125212; RRID: AB_10975465) 1:500 in 1 x PBS-T + 10% Donkey serum (accordingly to the secondary Abs) Overnight at Room temperature on the wobbler.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "1 x PBS-T rinse.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "1 x PBS-T 00:05:00 on shaker.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "1 x PBS-T 00:05:00 on shaker",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "250 µl secondary Ab 2 h 1/500 in 1 x PBS-T 02:00:00 Room temperature on the wobbler (dark by covering with aluminium foil).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "1 x PBS rinse.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "1 x PBS 00:05:00 on shaker.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "1 x PBS 00:05:00 on shaker.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Briefly rinse sections in ½ PBS + ½ AD , mount them on a microscope slide (Avantor VWR Microscope slides cut edges frosted; 631-1551) and allow them to dry Overnight while covered.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Cover with 80 µL mowiol and DAPI 1/500 (stains nucleus, 405 nm). Use cover slips #1.5 (Epredia; BB02400500SC13MNZ0). Let dry Overnight .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Visualise the stained sections with Leica DM6 B LED Fluorescent microscope and the LasX software.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Rinse the sections with PBS (Gibco; 21600-096).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Quantify the images in FIJI",
      "is_critical": false,
      "timers": []
    }
  ],
