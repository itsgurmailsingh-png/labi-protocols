  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Aspire medium",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Wash wells with PBS-EDTA 0.5mM (e.g., 0.5 mL per well of a 12-well-plate; recline the cells from tube rack to disturb the neurons as little as possible). Aspirate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 1/4 of well volume of papain-HBSS-EDTA-HEPES solution (e.g., 250 µL per well of a 12-well-plate or 125 µL per well of a 24-well-plate)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate at 37°C for 10-15 min in shaker at 125 rpm (bacterial shaker taped or inside metal holders). Tap cells on the side every 5 min.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Pipette cell clumps up and down to break cells.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer dissociated cells to a 15 mL tube plate with 6 mL of DMEM-10%FBS (2 volume dilution of papain) and wash wells with 5 mL (e.g., 400 µL /well of a 12-well-plate)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "3 mL cells suspension+ 6 mL Medium+ 5 mL Medium wash for each plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "NOTE: There should almost no cell clumps.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Spin at 600g, 5 min, RT. Decant medium by inverting the tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Resuspend in 1-2 mL of DMEM-10%FBS/plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Pass cells through strainer on top of a 15 mL tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Count cells in hiPSCs setting",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Wash w. PBS ((-Ca/-Mg) twice",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "0.5 mL Accutase, w/Rock inhibitor, 37°C, ~25 min, frequent agitation",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Pipet gently w. p1000,",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Wash medium w/FBS, and add 15 mL conical tube,",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Spin, 300 g, 5min, 4°C, aspirate sup,",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Re-suspended in neuron media w. 10% FBS and Ri.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Spin, 300 g, 5min, RT, remove sup",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Add 100 µL staining buffer (2%BSA/0.02% tween20, RNAase inhibitor)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add 10 µL FcX. resuspend, 10min, 4C (Fc block)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Add 2 µL (1µg) hashing Ab for each sample, 30min, @4C",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Wash w.1 mL staining buffer, spin, 300 g, 5 min,",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Repeat washing 3 times.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Ensure &gt;60% viability",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Counting: 2.5 µL cell suspension + 2.5 µL staining buffer (1:2 dilution) + 5 µL Trypanblue",
      "is_critical": false,
      "timers": []
    }
  ],
