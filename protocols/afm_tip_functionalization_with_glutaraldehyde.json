  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Silanize the tip with 2% v/v 3-aminopropyltiethoxysilane (APTES) in acetone for 10 min at 25°C.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Rinse the tip with deionized (DI) water.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Immerse the tip in 0.5% v/v glutaraldehyde in DI water for 30 min at 25°C.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Rinse the tip with DI water.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate the tip in protein solution (100-300 µg/mL, eg. 100µg/mL αvβ3 protein) for 30 min at 25°C.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Rinse the tip with DI water.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "To block remaining aldehyde groups on the probe surface, treat the probe with 100 µg/mL bovine serum albumin (BSA) in tris buffered saline (TBS) for 1 min at 25°C.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Functionalized tips can be stored at 4°C in phosphate buffered saline (PBS) for 3 days.",
      "is_critical": false,
      "timers": []
    }
  ],
