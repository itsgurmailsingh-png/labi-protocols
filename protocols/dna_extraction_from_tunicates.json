      "title": "",
      "instruction": "Incubate at -20 °C for 03:00:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Centrifuge at maximum speed for 00:20:00 at 4 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Discard the supernatant.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Add 450 µL of cold 80 % volume ethanol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Centrifuge at maximum speed for 00:05:00 at Room temperature .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Discard the supernatant.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Add 200 µL of cold 80 % volume ethanol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Centrifuge at maximum speed for 00:05:00 at Room temperature .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Discard the supernatant.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Resuspend the pellet in ultra pure water (typically 20-100 µL ).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Measure the DNA concentration using the NanoDrop.",
