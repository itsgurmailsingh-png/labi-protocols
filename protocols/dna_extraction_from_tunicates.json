    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Centrifuge at maximum speed for 00:03:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Transfer aqueous phase to a new tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Add 2 volumes of 100 % volume Ethanol (typically 300-400 µL ).",
      "is_critical": false,
      "timers": []
    },
    {
