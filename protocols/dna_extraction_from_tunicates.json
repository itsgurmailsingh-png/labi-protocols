      "title": "",
      "instruction": "Add 0.1 volume of 3 Molarity (M) sodium acetate (typically 15-20 µL ).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Mix by inversion.",
      "is_critical": false,
      "timers": []
    },
    {
