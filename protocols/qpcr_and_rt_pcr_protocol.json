  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Dissect the dorsal medulla oblongata from paraformaldehyde-fixed coronal sections of the medulla oblongata.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Extract total RNA using Nucleic Acid Isolation Kit (Ambion), and measure yield using a nanodrop.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Mix the PCR products with 6x sample buffer (New England Biolabs) and 5% DMSO and load on 2.0% SeaKem agarose gel (Lonza Bioscience) pre-stained with RedSafe dye (1:20,000, Intron Biotechnology)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Run a 30-cycle PCR reaction.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Synthesize cDNA from 100 ng template RNA using SuperScriptVILO Master Mix (Life Technologies) and the suitable primers ( 20 µL final volume).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Run the PCR with a real-time PCR machine (e.g., StepOnePlusTM real-time PCR system, Applied Biosystems) in triplicates.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Prepare a 20 µL l reaction mix containing 1 m l cDNA, Power SYBRGreen (Applied Biosystems) and primers.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "If necessary, extract RNA from human brain (Agilent Technologies) as a reference sample.",
      "is_critical": false,
      "timers": []
    }
  ],
