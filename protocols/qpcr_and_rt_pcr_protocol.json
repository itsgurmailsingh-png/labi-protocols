  "materials": [
    "Nucleic Acid Isolation Kit (Ambion)",
    "6x sample buffer (New England Biolabs)",
    "DMSO",
    "SuperScriptVILO Master Mix (Life Technologies)",
    "real-time PCR machine (e.g., StepOnePlusTM)",
    "Power SYBRGreen (Applied Biosystems)",
    "RNA extraction kit (Agilent Technologies)"
