      "step_id": 0,
      "title": "",
      "instruction": "Check the waste and If the waste is full, disconnect the tank and dispose of the waste down the sink with running water. Add 200 mL of 5% bleach to the tank and reconnect to the Attune NxT. Fill the Focusing Fluid tank from the focusing fluid cube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Check and fill as needed the shutdown solution reservoir and the wash solution reservoir.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Also check the waste and focusing fluid reservoirs at the plate sampler station.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "At the workstation, click on instrument &gt; start-up at the top of the screen.",
