  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Grind tissue to a powder in liquid nitrogen.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1.3 mL of cold ( 4 °C ) pBIOZOL Reagent for up to 100 mg of frozen, ground tissue.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate the tube for 00:05:00 at 20 °C . Lay the tube down horizontally to maximize surface area during RNA extraction.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge for 00:02:00 at .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 100 µL of 5 Molarity (M) NaCl to the extract.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 300 µL of chloroform.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge the sample at 4 °C for 00:10:00 at to separate the phases.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add to the aqueous phase an equal volume of isopropyl alcohol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge the sample at 4 °C for 00:10:00 at .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Decant the supernatant, taking care not to lose the pellet.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Centrifuge at Room temperature for 00:05:00 at .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 10 µL – 30 µL RNase-free water to dissolve the RNA.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Mix by briefly vortexing or flicking the bottom of the tube until the sample is thoroughly suspended.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Transfer the supernatant to an RNase-free tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Tap tube to mix.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Mix thoroughly by inversion.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Transfer the top aqueous phase to an RNase-free tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Mix.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Let stand at 20 °C for 00:10:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Add 1 mL of chilled 75 % ethanol to the pellet. Pellet may be difficult to see.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Decant the liquid carefully, taking care not to lose the pellet.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Briefly centrifuge to collect the residual liquid and remove it with a pipette.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Pipette the water up and down over the pellet to dissolve the RNA. If any cloudiness is observed, centrifuge the solution at Room temperature for 00:01:00 at and transfer the supernatant to a fresh tube.",
      "is_critical": false,
      "timers": []
    }
  ],
