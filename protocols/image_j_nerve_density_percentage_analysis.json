      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Move both slider bars to the far right. Slowly move the top slider bar to the left until you just fill in the areas of interest with &#34;red&#34;. The percentage that appears under the histogram is the percentage of area filled. That is the nerve density percentage.",
      "is_critical": false,
      "timers": []
    },
