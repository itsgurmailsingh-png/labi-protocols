  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Centrifuge at lowest speed to cause algae to form pellet.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Homogenize each 250 µL portion of pellet material to a powder in liquid nitrogen using mortar and pestle prechilled with liquid nitrogen.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 750 µL TRIzol LS to each 250 µL of homogenized algal material.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Homogenization is continued until the TRIzol is pulverized as well.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Thaw and aliquot homogenate into several Eppendorf tubes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 50 µL potassium acetate ( 0.2 Molarity (M) final concentration) to each sample.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate for 00:05:00 at 20 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 200 µL chloroform (for polysaccharide-rich algae), or 100 µL BCP to each sample.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate at 20 °C for 00:10:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge samples at for 00:15:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "RNA will remain in the upper, aqueous phase (ca. 70 % of the applied TRIzol).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Carefully transfer each RNA phase into RNase-free 1.5 ml tubes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add 500 µL isopropanol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Incubate for 01:00:00 at -20 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Centrifuge at for 00:10:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Wash pellet with 75 % ethanol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Gently suspend pellet in solution.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Centrifuge at for 00:05:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Repeat ethanol wash steps. go to step #17",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Dry pellet at 50 °C for 00:05:00 – 00:10:00 Appearance of drying pellet is important: drying should be terminated when the pellet begins to become transparent; contaminated RNA remains white)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add RNAse-free water.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Dissolve pellet completely by pipetting.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Wash several times with sterile culture medium (not DEPC-treated).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "After washing, the algal material is aliquoted into portions of 250 µL (ca. 50 mg – 100 mg packed cell volume).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add more nitrogen if needed (see also Procedure described in Protocol 9).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Shake samples for 00:00:15 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Incubate at 55 °C – 60 °C for 00:10:00 .",
      "is_critical": false,
      "timers": []
    }
  ],
