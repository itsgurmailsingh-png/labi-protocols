  "category": "Microbiology",
  "estimated_time_mins": 60,
  "materials": [
    "BHI-supplemented broth",
    "SML electroporation buffer",
    "SMP electroporation buffer",
    "DNA",
    "electroporation device",
    "centrifuge",
    "ice",
    "BHI agar"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Inoculate 10 µL, BHI-supplemented broth with 100 µL, stock culture overnight.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Use the overnight culture to inoculate 100 mL, BHI-supplemented broth to a starting density of OD 0.02.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Harvest early-exponential phase culture (OD 0.2 to 0.25) by centrifugation by 12,000g x 00:15:00 at 25 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Wash once in 10 mL, SML electroporation buffer .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Resuspend in 10 mL, SMP electroporation buffer .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Take 400 µL of aliquots and and mix with 500 ng of DNA, transfer to prechilled cuvettes with 0.2cm gap.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate on ice for 00:10:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Electroporate at the following parameters: 25μF, resistance 200Ω, voltage 1.8kV.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Immediately transfer the cells into 10 mL of BHI broth and incubate for 03:00:00 .",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Plate cells in dilutions on solid selective and non-selective BHI agar.",
      "is_critical": false,
      "timers": []
    }
  ],
