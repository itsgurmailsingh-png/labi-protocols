  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "This is a custom protocol that automates certain steps of the Omega Mag-Bind Bacterial DNA 96 Kit on the OT-2 robot. This kit allows rapid isolation of genomic DNA from bacterial samples. Explanation of complex parameters below: * `Number of Samples`: The total number of DNA samples. Samples must range between 1 (minimum) and 12 (maximum). * `P300 Single GEN2 Pipette Mount Position`: The position of the pipette, either left or right. * `P1000 Single GEN2 Pipette Mount Position`: The position of the pipette, either left or right. * `Magnetic Module Engage Height`: The height the magnets will raise on the magnetic module. ---",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Transfer 5 uL of RNase A and then mix thoroughly 20 times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate at room temperature for 5 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Transfer 400 uL of MSL Buffer to all samples.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Transfer 10 uL of Mag-Bind particles to all samples and mix thoroughly 20 times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer 528 uL of Ethanol and mix thoroughly 20 times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate at room temperature for 5 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Engage magnetic module for 15 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Aspirate and discard supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Disengage magnetic module.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Transfer 400 uL of SPM buffer to samples.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Resuspend magnetic beads and then incubate for 3 minutes at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Engage magnetic module for 15 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Aspirate and discard supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Repeat steps 10-13 again.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Air dry magnetic beads for 5 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Remove residual supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Air dry beads for 15 minutes until they dry.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Disengage magnetic module.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
