  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "This protocols performs a blead cleanup on the OT-2 with overnight digestion step for 16, 32, or 48 samples. For detailed description of requirements and steps, please see below.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "12 well reservoir (liquid stock plate) contains: A1= 100% ACN, A2= 70% ethanol",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Eppendorf rack (liquid stock epps) contains: A1= bead solution, A2= 200 mM TEAB, A3= 5% HA, A4= 20% formic acid",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Homogenize bead solution in A1 of Eppendorf rack (50 µl 3x, fast speed)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "4 µl beads from A1 to column 1-6* of slot 1 (same tips)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "30 µl of sample from column 1-6* slot 2 to column 1-6* slot 1 (A1 to A1, B2 to B2 etc, new tip always)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "70 µl of 100% ACN to column 1-6* of slot 1 (airgap, mix after every time, 3x low speed, new tip always)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Wait 2 mins",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Engage magnetic module (magnetic beads as low as possible)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Wait 5 mins",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Remove 100 µl from column 1-6* of slot 1, dispose in reservoir slot 11 (Consolidate, same tips)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 100 µl 70% ethanol to column 1-6* of slot 1 (one tip)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Remove 100 µl from column 1-6* of slot 1, dispose in reservoir slot 11 (Consolidate, same tips)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Repeat step 11-12",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Disengage magnetic module",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Wait 2 mins",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Add 10 µl digestion solution to column 1-6* slot 1 (mix every time, 1x slowly, new tip always)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Pause protocol (‘move sample plate to heater shaker’)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Close HS module",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Heater activate (37°C)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Pause protocol (‘Overnight digestion’)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Deactivate heater",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Open HS module",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Pause protocol (‘move sample plate to magnetic mod’)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Engage magnetic module (magnetic beads as low as possible)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Wait 2 mins",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Move 10 µl from column 1-6* of slot 1 to new position in the same plate, according to the ‘sample transfer layout’ scheme attached (new tips always, low speed aspirate, away from mag beads, touch tip after dispense)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Add 5µl 200 mM TEAB to all TMT wells (new tip always, mix 3x)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Add 9 µl TMT/buffer mix from slot 9 to all samples**, according to the attached scheme ‘TMT layout’ (A1 -> A3, A5 or A7, B1 -> B3, B5 or B7 etc., new tip always, mix 3x low speed)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Wait 1 hr",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Add 5 µl 5% HA to all samples** (new tip always, mix every time, 1x medium speed)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Wait 15 mins",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Consolidate samples into one Eppendorf (B5-8 of slot 3), every two columns of samples combined into one epp (for triplos: column 7 + 8 from sample plate to B5 of slot 3, column 9 + 10 to B6 of slot 3, column 11 + 12 to B7, for monoplo: column 3 + 4 to B5)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Add 10 µl 20% formic acid to slots B5-8* of slot 3 (new tip always, mix after every time 3x high speed)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
