  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "1er lavado con 10 ml de tampón M9 estéril a temperatura ambiente y transferir a tubo Falcon de 15 ml.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "2do lavado con 5 ml de tampón M9 estéril a temperatura ambiente y transferir a tubo Falcon de 15 ml.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifugar a 2000 G por 5 minutos a temperatura ambiente.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Retirar sobrenadante.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "3er lavado con 4 ml de Buffer TDMSO.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Repetir paso 4 y 5.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Resuspender en 4ml de TDMSO.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Alicuotar 1 ml en 4 frascos (crioviales).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Desde la re-suspensión en TDMSO no debe pasar más allá de 15 minutos para mayor viabilidad.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Colocar los crioviales en una caja de poliestireno y colocar a -1 ºC por 10 a 15 minutos.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Pasar los tubos a -80 ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Probar la viabilidad en 1 semana y tras comprobarla se recomienda dejar 2 tubos en congelador a -80 ºC y otro en nitrógeno líquido.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Para descongelarlos se recomienda descongelar todo el tubo y verterlo en una placa NGM o congelarlos de costado o boca abajo para poder raspar y revivirlos parcialmente.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
