  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Wash tissue in PBSA.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Mince tissue with scalpel.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transfer the minced tissue to the Collagenase/DNAse solution in a 50ml Falcon.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Shake the suspension at 110-150 rpm for 60 mins at 37°C (with the tube on its side to increase agitation of the tissue).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "After 15, 30, and 60 mins – pipette up and down with descending sized pipettes (25, 10 and 5 ml).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Pipette thoroughly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Strain with a 70 um cell strainer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 10 ml DMEM (empty) to sieve and push through with syringe plunger.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Keep on ice from this point.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Spin 1500 rpm for 5mins and remove media.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Resuspend pellet in RBC lysis buffer and incubate @ 4°C for 10mins.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 10 ml DMEM (empty) and pipette up and down thoroughly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Pass through 40 um cell strainer – pushing through with plunger.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Spin at 1500 rpm for 5 mins and remove media.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Resuspend pellet in 1 ml of cell suspension buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "In a 0.5ml tube, add 10 ul cell solution with 10 ul trypan blue.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Add resultant 20 ul mix onto disposable haemocytometer (C-Chip, FR type).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Count the cells and record cell viability",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
