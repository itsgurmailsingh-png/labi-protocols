{
  "protocol_id": "ctabchloroform_dna_extraction_from_ethanol_preserved_freshwater_phytobentos",
  "parent_protocol_id": null,
  "title": "CTAB–Chloroform DNA Extraction from Ethanol-Preserved Freshwater Phytobentos",
  "author": "Pavla Urbankova",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.dm6gpzxwdlzp/v1",
  "source_name": "protocols_io",
  "source_id": "103761",
  "source_url": "https://www.protocols.io/view/ctab-chloroform-dna-extraction-from-ethanol-preser-dhjr34m6",
  "doi": "dx.doi.org/10.17504/protocols.io.dm6gpzxwdlzp/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.dm6gpzxwdlzp/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 144,
  "materials": [
    "CTAB buffer",
    "Proteinase K",
    "Chloroform",
    "Isopropanol",
    "Microcentrifuge tubes",
    "Pipette tips",
    "Vortex mixer",
    "Centrifuge",
    "Heat block",
    "Vacuum concentrator"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Resuspend particulates in the ethanol-preserved sample container by manual shaking until homogenized.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Transfer 2 mL of homogenized ethanol mixture into a 2.0 mL microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at 13500 rpm, Room temperature, 20 minutes (max speed).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Dry the pellet for 00:10:00 using either a vacuum concentrator or a heat block (open cap), ensuring ethanol is removed.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Carefully decant the supernatant without disturbing the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 500 µL CTAB buffer (room temperature) to the dried pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Vortex continuously for 00:15:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Freeze at -20 °C until fully frozen (typically 01:00:00 ); samples may be stored at -20 °C Overnight and processed the next day.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Thaw at 65 °C for 00:15:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 4 µL 20 µL Proteinase K ( 20 mg/mL ) and vortex briefly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Incubate at 65 °C for 01:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 400 µL chloroform and mix gently with the pipette tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Centrifuge at 13500 rpm, Room temperature, 15 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Carefully transfer ~ 300 µL of the upper aqueous phase to a new 2.0 or 1,5mL tube using a fresh filter tip, avoiding the interphase.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Add 400 µL ice-cold isopropanol (stored at -20 °C ) and mix by inverting the tube several times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Incubate 00:15:00 at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Centrifuge for 13500 rpm, Room temperature, 15 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Remove supernatant carefully without losing the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Add 500 µL ice-cold 70% ethanol (stored at -20 °C ) and briefly vortex.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Centrifuge at 13500 rpm, Room temperature, 5 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Carefully remove supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Repeat etanol wash once more go to step #19 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Dry the pellet (open cap) for ~ 00:10:00 in a vacuum centrifuge or on a 65 °C heat block (avoid airborne contamination).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Dissolve DNA pellet in 30 µL EB buffer (or sterile milliQ water), vortex and spin down. Let the DNA dissolve for at least 1 hour before further analysis (or store in fridge/freeze).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
  "normalised_at": "2026-06-17T14:10:04.226417Z",
  "llm_normalised": true
}