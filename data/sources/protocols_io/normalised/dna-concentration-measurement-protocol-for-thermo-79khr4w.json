  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Open the ND-1000 V3.8.1 Program using the computer (the computer should be connected to the Nanodrop apparatus).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Click on the corresponding application module (e.g., Nucleic acid to determine the concentration and purity of nucleic acid).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Open the sampling arm and load a blank sample (e.g., TE Buffer, MQ Water, etc.). 1.5 µL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Close the sampling arm on the machine to cover the blank sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Click &#34;OK&#34; to read the blank.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Open the sampling arm and clean the blank off the upper and lower pedestals using a Kim Wipe.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Load your DNA or RNA sample and close the sampling arm. 1.5 µL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Select the sample type in the program (e.g., DNA or RNA).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Click &#34;Measure&#34;.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "When finalized, read the 260/280, 260/230 and concentration (ng/µL) measurements.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Clean the nucleic acid sample off of the upper and lower pedestals using a Kim Wipe.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Close program.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Repeat for all samples.",
