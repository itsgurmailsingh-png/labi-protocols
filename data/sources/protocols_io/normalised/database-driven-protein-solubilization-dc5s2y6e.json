  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Choose your protein of interest.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Visit www.polymerscreen.yale.edu to search for your protein in the extraction database. This will provide you with the polymer to use for optimal protein extraction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "As an example, below are representative organellar markers and the optimal polymer for extraction: TMEM192 --&gt; AASTY650 TGN46 --&gt; ChloroSMA60 OMP25 --&gt; SMA200 VAPA --&gt; AASTY650 KRas --&gt; ChloroSMA80",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Once the optimal polymer has been determined, express the protein of interest, or harvest cells for endogenous solubilization.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Resuspend cellular membranes in the chosen polymer and incubate at 4 °C with rotation for 02:00:00 hours.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Ultracentrifuge samples ay 200,000xg for 01:00:00 hours to remove insoluble material.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
