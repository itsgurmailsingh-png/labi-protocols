  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Rehydrate Primers with IDTE Buffer; resuspend to 100 µM stock",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "PCR using Q5 polymerase, Q5 buffer, 50 µL reaction, 12 samples (including NTC), 30 cycles [98°C 10s / 60°C 30s / 72°C 30s/kb]",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Perform Gel Electrophoresis with 1% agarose, 100 V, for 30 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Clean Up &amp; Concentrate using QIAquick kit, elute 30 µL in kit-provided buffer (EB)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Modular Gibson Assembly with NEBuilder HiFi, 12 fragments (including pSB1C3 backbone), 50°C, 60 minutes, 20 µL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transformation &amp; Plating using DH5α electrocompetent, 1.8 kV, 1 hour SOC recovery, plate on LB + cm 25 µg/mL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Colony PCR with 8 colonies + NTC, VR/VF2 primers, Taq, 25 cycles",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Gel Electrophoresis with 1% agarose, 100 V, for 45 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Overnight Inoculum: Pick 3 positives → 5 mL LB + cm, 37°C / 250 rpm / 16 hours",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Miniprep using QIAprep Spin, elute 50 µL EB",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "TapeStation with Genomic DNA ScreenTape, dilute to 50 ng/µL, 1 µL load",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Illumina NextSeq 2000 using Nextera XT, 2×150 paired-end, 100× coverage",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Glycerol Stock with 25% glycerol, 1 mL aliquots, −80°C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Induction in 96-well black/clear, 200 µL LB + cm + inducer, induce at OD 0.3–0.5, 5 hours at 37°C; inducer: Arabinose 0.2% (w/v) or constitutive",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Synergy H1 Fluorescence: Ex 485 nm / Em 528 nm, gain 75, kinetic 15 min × 5 hr, normalize F/OD600",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
