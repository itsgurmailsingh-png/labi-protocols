  "estimated_time_mins": 78,
  "materials": [
    "MilliQ water",
    "50mL Falcon tube",
    "Square petri dish",
    "Paper towel",
    "70% EtOH",
    "Miracloth",
    "1.5mL tube",
    "Ultrapure water",
    "Centrifuge"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 20 mL MilliQ water to pot",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Remove plant, if any. Transfer to square petri dish.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Push a 50mL Falcon into the sand up to the 35 mL mark.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Tilt pot to a horizontal position and remove the falcon tube, retaining as much sand as possible. Rotating the tube while removing it may help",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Cap and wipe down the tube exterior using a paper towel with 70% EtOH before labelling with pot ID.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Fill tube with sand to the 40mL mark with MilliQ water",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Vortex for 30 seconds",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Pour through Miracloth into new 50ml tube. Discard the old tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge tube at 5000 x G for 5 minute.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Pour away supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add 1ml water and vortex to resuspend.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer to 1.5ml tube for extraction or storage. Dispose of the 50ml tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Top up tube to 40 ml total volume with ultrapure water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
