{
  "protocol_id": "survival_analyses_protocol_for_wolf_management_and_livestock_protection",
  "parent_protocol_id": null,
  "title": "Survival Analyses Protocol for Wolf Management and Livestock Protection",
  "author": "Francisco Santiago-Ávila",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.jsscnee",
  "source_name": "protocols_io",
  "source_id": "7730",
  "source_url": "https://www.protocols.io/view/survival-analyses-protocol-killing-wolves-to-preve-jsscnee",
  "doi": "dx.doi.org/10.17504/protocols.io.jsscnee",
  "citation": "dx.doi.org/10.17504/protocols.io.jsscnee",
  "category": "Bioinformatics",
  "estimated_time_mins": 480,
  "materials": [
    "STATA 14 software",
    "computer"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Variables and Sample STATA 14 .Do file used for survival analyses at each spatial scale",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Here, we make available basic sample code for the statistical survival analyses employed in our manuscript. This code should allow for replication of analyses at all spatial scales for all datasets involved.*",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "1. VARIABLES USED (and description):",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "ID_TRS_yr --&gt; identifier for each area-year combination (please see study for more information)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Interv_dich --&gt; intervention type (lethal, non-lethal)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "wolves_killed --&gt; number of wolves killed",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Interv_dummy --&gt; dummy variable for intervention type (0 if ‘non-lethal’, 1 if ‘lethal’)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Delay_in_yrstop_time --&gt; time to recurrent event (in days) or censoring",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "status_event --&gt; failure binary variable (1 if recurrent event; 0 if censored)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "start_time --&gt; start time variable (all obs ‘0’)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "yr_stratum --&gt; order of recurrent events within a particular area-yr†",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "year --&gt; year variable (1998-2014)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "2. SAMPLE .DO FILE (Section scale)‡:",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "clear all",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "cd “/Location/Of/File”",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "log using &#34;Name.smcl&#34;, replace",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "set mem 1g",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "use &#34;Data.dta&#34;, replace",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "set more off, permanently",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "****Replacing intervention type if wolves_killed = 0§",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "replace Interv_dich=&#34;non-lethal&#34; if wolves_killed==0",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "replace Interv_dummy=0 if Interv_dich==&#34;non-lethal&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "***Set data as survival time for PWP-GT model",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "stset Delay_in_yrstop_time, failure(status_event) exit(time .) enter(start_time)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "list ID_TRS_yr _t0 _t _d _st**",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "stdescribe",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "stsum",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "***Limiting analysis to # of Strata††",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "use “Data_Strata#.dta”",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "stset Delay_in_yrstop_time, failure(status_event) exit(time .) enter(start_time)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "stdescribe",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "stsum",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 38,
      "title": "",
      "instruction": "*Comparing survival functions by group",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 39,
      "title": "",
      "instruction": "sts list, by(Interv_dich)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 40,
      "title": "",
      "instruction": "sts list, by(Interv_dich) compare",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 41,
      "title": "",
      "instruction": "*Graphing survival functions by group",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 42,
      "title": "",
      "instruction": "sts graph, by(Interv_dich)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 43,
      "title": "",
      "instruction": "sts graph, fail by(Interv_dich)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 44,
      "title": "",
      "instruction": "*Graphing smoothed hazard estimates (hazard ratio) by group",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 45,
      "title": "",
      "instruction": "sts graph, hazard by(Interv_dich)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 46,
      "title": "",
      "instruction": "sts graph, cumhaz by(Interv_dich)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 47,
      "title": "",
      "instruction": "*Testing equality of survival functions by group (Log-rank test)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 48,
      "title": "",
      "instruction": "sts test Interv_dich",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 49,
      "title": "",
      "instruction": "sts test Interv_dich, strata(yr_stratum)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 50,
      "title": "",
      "instruction": "***COX MODELS (stcox)***",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 51,
      "title": "",
      "instruction": "**STRATIFIED**",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 52,
      "title": "",
      "instruction": "stcox Interv_dummy year, strata(yr_stratum) vce(cluster ID_TRS_yr)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 53,
      "title": "",
      "instruction": "stcox Interv_dummy year, nohr strata(yr_stratum) vce(cluster ID_TRS_yr)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 54,
      "title": "",
      "instruction": "*Checking Proportional Hazard assumptions",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 55,
      "title": "",
      "instruction": "estat phtest, log detail",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 56,
      "title": "",
      "instruction": "estat phtest, plot(Interv_dummy)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 57,
      "title": "",
      "instruction": "stphplot, by(Interv_dummy)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 58,
      "title": "",
      "instruction": "estat phtest, plot(year)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 59,
      "title": "",
      "instruction": "stphplot, by(year)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 60,
      "title": "",
      "instruction": "*Adding time-varying covariate to account for proportional hazard assumption violation",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 61,
      "title": "",
      "instruction": "stcox Interv_dummy year, tvc(Interv_dummy) texp(_t) strata(yr_stratum) vce(cluster ID_TRS_yr)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 62,
      "title": "",
      "instruction": "*FRAILTY (MIXED-EFFECTS) MODEL**",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 63,
      "title": "",
      "instruction": "strmcure Interv_dummy year, shared(ID_TRS_yr) strata(yr_stratum)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 64,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 65,
      "title": "",
      "instruction": "***Correlation between delay between incidents and wolves killed (for ‘Lethal’ only)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 66,
      "title": "",
      "instruction": "************************************************",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 67,
      "title": "",
      "instruction": "spearman Delay_in_yrstop_time wolves_killed if Interv_dich==&#34;Lethal&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 68,
      "title": "",
      "instruction": "log close",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 69,
      "title": "",
      "instruction": "* This sample code does not include code lines for dropping or adding observations, which we did for the alternate datasets used. However, this should only involve basic coding, and descriptions of observations included or dropped for each dataset can be found in the study.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 70,
      "title": "",
      "instruction": "† ‘Area’ refers to the section, neighborhood or neighborhood of township area scales.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 71,
      "title": "",
      "instruction": "‡ A similar procedure was used for the township and neighborhood of township scales, using their respective spatial unit identifiers.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 72,
      "title": "",
      "instruction": "§ This section was used for our main dataset. We removed this section of code for our alternate ‘traps-placed’ dataset, to include as ‘lethal’ those cases were attempts were made to trap wolves (please see study).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 73,
      "title": "",
      "instruction": "** May need to break ties in Delay_in_yrstop_time variable to retain observations (please see stset help in Stata)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 74,
      "title": "",
      "instruction": "†† A separate dataset was created including only those area-year records with strata (yr_stratum) values with enough observations to be properly modelled (please see study).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 75,
      "title": "",
      "instruction": "---------------",
      "is_critical": false,
