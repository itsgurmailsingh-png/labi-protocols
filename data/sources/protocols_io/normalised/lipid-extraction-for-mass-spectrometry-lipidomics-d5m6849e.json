  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 200 µL of cold methanol and 800 µL of cold methyl tert-butyl ether (MTBE) to the samples.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Vortex.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 200 µL of water. Phase separation into aqueous and organic phases should occur.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge the extraction mixture at 10000 x g, 4 °C, 10 minutes to separate the organic and the aqueous phases.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Collect the upper organic phase.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Dry it in a SpeedVac and store at -80 °C until analysis.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "For mass spectrometry analysis, reconstitute the samples with 20 µL - 40 µL of acetonitrile/isopropanol/water in a 65:30:5 ratio (v/v/v). For LC-MS measurement, a C8 column (Luna 3u, 2 x 100 mm, 3.0 µm, Phenomenex) is recommended. DMPC gets stuck in the C18 column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
