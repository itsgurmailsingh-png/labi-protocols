  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Coat 3 wells of a 6-well plate with 1 mL Poly-L-Ornithine (PLO) for 02:00:00 or overnight in humidified incubator.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Aspirate off PLO and rinse 3 times with DMEM/F12.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Dilute laminin to 10 μg/mL final in cold DMEM/F12 and add 1 mL/well of solution to PLO coated plates.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate for 02:00:00 or overnight in humidified incubator.",
