  "citation": "dx.doi.org/10.17504/protocols.io.4uygwxw",
  "category": "Molecular Biology",
  "estimated_time_mins": 180,
  "materials": [
    "CTAB",
    "Phenol",
    "Chloroform",
    "LiCl",
    "Sodium acetate",
    "DEPC treated water",
    "Micro-centrifuge",
    "Vortex mixer",
    "Incubator",
    "Centrifuge"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Preheat phenol and phenol:chloroform to 65 °C . Heated phenol should not be re-used.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Collect algae cells via centrifugation for 00:10:00 at at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Re-suspend the frozen pellet in 800 µL of preheated extraction buffer .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate at 65 °C for 01:00:00 . Gently vortex every 00:15:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Cool to Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Collect the aqueous phase by centrifuging for 00:10:00 in micro-centrifuge at at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Collect aqueous phase and re-extract with an equal volume of chloroform.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Collect aqueous phase and add 10 Molarity (M) LiCl to a final concentration of 3 Molarity (M) .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Recover the RNA by centrifugation at at 4 °C for 00:20:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Dissolve pellet in DEPC treated water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Extract the aqueous phase with equal volume of phenol:chloroform (5:1).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Vortex for 00:01:00 at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Extract the aqueous phase with equal volume of chloroform.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Collect aqueous phase and add 1/30 volume of 3 Molarity (M) sodium acetate pH 5.5 and 0.1 volume of 100 % ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "To the clear supernatant add 3 Molarity (M) sodium acetate pH 5.2 to a final concentration of 0.3 Molarity (M) and 3 volumes of 100 % ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Spin in micro-centrifuge at 4 °C at top speed for 00:20:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Wash the pellet with 70 % ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Invert tubes and air dry at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Resuspend pellets in 50 µL of DEPC treated water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Flash freeze pellets with liquid nitrogen and keep at -80 °C until extractions are carried out.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add equal volume of chloroform.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Shake vigorously until 2 phases form an emulsion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Centrifuge as above.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Allow the RNA to precipitate at 4 °C overnight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Spin for 00:05:00 in a micro-centrifuge at top speed.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Mix well and keep on ice for 00:30:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Centrifuge in cold for 00:25:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "A white jelly-like pellet consisting mostly of polysaccharides is obtained and discarded.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Allow the RNA to precipitate at -80 °C for 03:00:00 to overnight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Extract once with hot acid phenol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
