{
  "protocol_id": "rna_isolation_from_plant_tissue_using_ctab_hot_acid_phenol_method",
  "parent_protocol_id": null,
  "title": "RNA Isolation from Plant Tissue Using CTAB-Hot Acid Phenol Method",
  "author": "Unknown",
