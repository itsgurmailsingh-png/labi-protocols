  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "For 20 ml or 50 ml PARIS-Medium mix: %s %s",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Inoculation of precultures: Spread B. subtilis from Glycerol stock on LB plate and incubate over night for 37°C or over the weekend at 30°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Resuspend single clones in 5 ml Paris Medium (test tube) on incubator roller or plate washer with 1 ml Paris Medium (saves one day work)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Inoculation of 2.5 ml Paris Medium (test tube) from pre-culture (wash or liquid-overnight culture) to OD 580 =0.2",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "4h incubation on incubator roller at 37°C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge 1 ml pellet cells in reaction tubes for 1 min at maximum speed. Remove the supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Resuspend the pellet in 1 ml Paris medium with 10 % (v/v) glycerol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Store 100 µl aliquots at -80 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Thaw aliquots at 37 °C, add 900 µl Paris medium and 500-1000 ng plasmid DNA (test tube)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Incubate 6 h in the incubator roller at 37°C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Pellet cells, remove 800 µl, resuspend and plate the rest (for normal transformation on LB+antibiotic)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
