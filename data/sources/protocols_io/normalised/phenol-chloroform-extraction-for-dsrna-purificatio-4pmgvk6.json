  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 166.6 uL of nuclease free water to each PCR tube. Move 187 uL of liquid to new, labeled 1.5 mL microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 200 uL of acid phenol/chloroform (50:50) to each tube. Shake vigorously for 15 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at 4C for 5 minutes at 12,000 * g or greater",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Move aqueous phase (top) to new tube (about 200 uL).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add an equal volume chloroform to the aqueous phase. Shake vigorously for 15 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge at 4C for 5 minutes at 12,000 * g or greater",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Move aqueous phase (top) to new tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add an equal volume of isopropanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate at room temperature for 10 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "To pellet: Spin at 4C for 20 minutes at 12,000 * g or greater",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Remove isopropanol and Wash pellet with 75% ethanol in nuclease free water",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Spin at 4C for 5 minutes at 7,500 * g",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Remove all ethanol from pellet and let air dry (for about 15 minutes)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Resuspend dried pellet in 50 uL of nuclease free water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Heat resuspended dsRNA to between 65 and 80 degrees C for 5 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Allow to cool at room temperature for 10 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Place on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Add 13.33 uL of ammonium acetate to each tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
