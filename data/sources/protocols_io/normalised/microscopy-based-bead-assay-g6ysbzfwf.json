{
  "protocol_id": "microscopy_based_bead_assay",
  "parent_protocol_id": null,
  "title": "Microscopy-based bead assay",
  "author": "Elisabeth Holzer",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.e6nvw4kr7lmk/v1",
  "source_name": "protocols_io",
