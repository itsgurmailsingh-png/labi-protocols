  "doi": "dx.doi.org/10.17504/protocols.io.e6nvw4kr7lmk/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.e6nvw4kr7lmk/v1",
  "category": "Immunology",
  "estimated_time_mins": 192,
  "materials": [
    "GFP-Trap agarose beads",
    "EBB",
    "SEC150",
    "ATG9A vesicles",
    "MOCK controls",
    "PLs",
    "mCherry-PI3KC3-C1",
    "ATG2A-mCherry",
    "PI3KC3-C1",
    "mCherry-2xFYVE",
    "cofactors",
    "donor liposomes"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Equilibrate 10 µL of GFP-Trap agarose beads with water and twice with EBB.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate freshly purified ATG9A vesicles (from 5x 15-cm plates) or MOCK controls (from wild-type HAP1 cells) with beads at 4 °C for 05:00:00 with gentle rotation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Store Overnight at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Wash beads twice with 200 µL SEC150 and resuspend in 5 µL – 10 µL SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Equilibrate 10 µL GFP-Trap beads with water and twice with SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate 500 µL of PLs with beads at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "After binding, wash beads with SEC150 before downstream applications.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Pipette 20 µL prey protein ( 0.1 micromolar (µM) mCherry-PI3KC3-C1 or ATG2A-mCherry) into each well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 1 µL of bead suspension (coated with ATG9A vesicles or MOCK control) per well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Incubate 00:30:00 at Room temperature prior to imaging.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Incubate vesicle/PL-coated GFP-Trap beads with 0.03 micromolar (µM) PI3KC3-C1 for 00:30:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 0.03 micromolar (µM) mCherry-2xFYVE and incubate 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add cofactors to initiate PI(3)P production.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Reaction volume: 20 µL per well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Incubate 125 µL ATG9A PLs with 10 micromolar (µM) ATG2A and 6.25 µL donor liposomes ( 0.5 mg/mL ) Overnight at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Bind to 5 µL GFP-Trap beads for 05:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Wash once with SEC150, once with SEC250 (25 mM HEPES pH 7.5, 250 mM NaCl, 1 mM DTT), once with SEC350 (25 mM HEPES pH 7.5, 350 mM NaCl, 1 mM DTT) and then twice with SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Resuspend in 3 µL SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Add PI3KC3-C1, cofactors, and mCherry-2xFYVE as above (PI3KC3-C1 activity assay).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Use 0.5 µL GFP-Trap beads coated with ATG9A vesicles per 20 µL reaction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add 250 nanomolar (nM) each of: mCherry-GABARAPΔL117 (lipidatable), ATG7 (E1), ATG3 (E2), ATG5-ATG12-ATG16L1 (E3).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Add 2 millimolar (mM) ATP and 1 millimolar (mM) MgCl₂.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Incubate for 02:30:00 at 30 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Wash beads once with SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Controls: non-lipidatable GABARAP-FL, mCherry alone, or omission of E1/E2/E3.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Equilibrate 5 µL Glutathione Sepharose beads with water and SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Incubate with 5 micromolar (µM) GST-tagged bait in SEC150 for 01:00:00 at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Wash beads 3x with SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Resuspend in 5 µL SEC150.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Dispense 20 µL of 0.5 micromolar (µM) ATG2A-mCherry or ATG2A-LIR-mCherry into wells.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Add 1 µL beads per well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Imaging: All samples were imaged using a Zeiss LSM 700 confocal microscopeequipped with a Plan Apochromat 20×/0.8 WD 0.55 mm objective.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
  "normalised_at": "2026-06-18T09:44:49.302529Z",
  "llm_normalised": true
}