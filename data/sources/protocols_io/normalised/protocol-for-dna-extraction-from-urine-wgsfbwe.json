      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Resuspend pellets in 500 uL Enzyme buffer (0.5 M Tris, 1 mM EDTA, 0.2% 2-mercaptoethanol, pH 7.5) in a 1.5 ml Eppendorf tube",
