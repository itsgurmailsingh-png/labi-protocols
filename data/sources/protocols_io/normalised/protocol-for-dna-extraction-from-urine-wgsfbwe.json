      "title": "",
      "instruction": "Cool on ice for 5 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Centrifuge at 17,000 X G for 1 minuteDNA Extraction",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "For each sample, add 350 ml to each of 2 1.5 ml tubes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Add 10 ul proteinase K mixture (Qiagen #1017738) to each sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add 250 ul Buffer AL+Carrier [Poly (A) Sigma-Aldrich #10108626001 10ng/ml] to each sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Vortex for 15 seconds",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Incubate at 70°C for 10 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Add 250 uL 100% EtOH to each sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Mix by vortexing for 5 seconds",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Transfer mixture from first tube to QIAamp Mini Spin Column (#1011706) and centrifuge at 17,000 X G for 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Change collection tube, transfer mixture from second tube to spin column and centrifuge at 17,000 X G for 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Change collection tube and add 500 uL Buffer AW1 to column",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Centrifuge at 17,000 X G for 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Change collection tube and add 500 uL AW2 to column",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Centrifuge at 17,000 X G for 3 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Remove residual EtOH by centrifuging an additional 1 min at max",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Transfer column to new 1.5 mL Eppendorf tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Add 50 uL Buffer AE to column, incubate at RT for 5 minutes and spin at 17,000 X G for 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Transfer fluid from collection tube back to spin column and repeat last step",
