      "instruction": "Vortex for 5 seconds",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Heat at 95°C for 5 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Vortex for 5 seconds",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
