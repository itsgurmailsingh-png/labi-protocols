  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Grind tissue to a powder in liquid nitrogen.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1.3 mL of cold ( 4 °C ) pBIOZOL reagent for up to 100 mg of frozen ground tissue.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate the tube for 00:05:00 at Room temperature . Lay the tube down horizontally to maximize surface area during RNA extraction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge for 00:10:00 at in a microcentrifuge at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 100 µL of 5 Molarity (M) NaCl and 300 µL chloroform.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge at for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Transfer the top aqueous phase to a new 1.5 ml RNase-free tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Vortex the tube until the phases mix and appear cloudy.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge at for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Transfer the top aqueous phase to a new 1.5 ml RNase-free tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Centrifuge at for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer the top aqueous phase to a new 1.5 ml RNase-free tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Pour the contents of the tube into a Qiagen mini RNA spin column (pink), until the column is almost filled with liquid.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Cap the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Discard the flow-through from the collection tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Repeat the previous two steps with the same mini RNA spin column, until all of the liquid in the tube(s) has been passed through the column. The nucleic acid is now bound to the silica membrane in the spin column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Apply 700 µL of solution RW1 to the spin column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Cap the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Discard the flow-through from the collection tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Apply 500 µL of solution RPE to the spin column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Discard the flow-through.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Repeat previous two steps one time. go to step #20.2",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Spin at maximum speed for 00:02:00 to remove remaining liquid from the silica membrane.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Transfer the spin column to a new 1.5 ml conical bottom microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add 30 µL – 50 µL of RNase-free water to the column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Spin at maximum speed for 00:01:00 to collect RNA solution.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Mix by briefly vortexing or flicking the bottom of the tube until the sample is thoroughly re-suspended.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Transfer the supernatant to a new 1.5 mL RNase-free tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Vortex vigorously.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Add an equal volume of 5:1 acid phenol:chloroform to the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Incubate at 20 °C for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Add to the aqueous phase equal volume of 24:1 chloroform:isoamyl alcohol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Vortex the tube until the phases mix and appear cloudy.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Then incubate at Room temperature for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Add 1/2 volume of 100 % ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Centrifuge at for 00:00:15 . The column should be empty at the end of this spin.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Centrifuge at for 00:00:15 . The column should be empty at the end of this spin.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "Cap the tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 38,
      "title": "",
      "instruction": "Centrifuge at for 00:00:15 . The column should be empty at the end of this spin.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 39,
      "title": "",
      "instruction": "Then let tube incubate at 20 °C for 00:03:00 .",
      "is_critical": false,
