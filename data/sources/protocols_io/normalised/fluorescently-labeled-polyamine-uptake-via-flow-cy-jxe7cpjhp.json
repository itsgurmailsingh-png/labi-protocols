  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "The day of the experiment, remove cell culture medium and add fluorescently labeled polyamines diluted in media to the cells in a final volume of 1000 µL, / well . Keep protected from light.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate at 37 °C with 5% CO₂ for 2h, ensuring protection from light.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Discard medium.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Wash with 500 µL, /well PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 500 µL, /well 2% of BSA (0.7% solution) in PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge for 00:05:00 at 300 g and 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Discard supernatants and resuspend cell pellets in 500 µL in BSA+PBS+DAPI (1:5000).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Keep on ice until acquisition at the flow cytometer. Record 10,000 live events per sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 200 µL, /well TrypLE. Incubate 00:05:00, at RT protected from light.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Seed cells in a 12-well plate so they reach 70-80% confluency on the day of the experiment.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Harvest cells and prepare samples for Flow Cytometry (FC).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Discard PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Filter cell suspension through Nylon filter into FC tubes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Prepare single color samples.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
