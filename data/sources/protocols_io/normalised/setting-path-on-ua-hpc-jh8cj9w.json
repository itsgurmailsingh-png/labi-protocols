  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Open your \".bashrc\" in a text editor (nano, vi, emacs): $ cd $HOME $ nano .bashrc",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add the following lines: export PATH=/rsgrps/bh_class/rakudobrew/bin:/rsgrps/bh_class/bin:$PATH export PYTHONPATH=/rsgrps/bh_class/lib/python",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Source your .bashrc $ source .bashrc",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Ensure that you environment has the new paths: $ echo $PATH $ echo $PYTHONLIB",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Try executing the following: $ seqmagick -h $ perl6 --version $ python --version",
      "is_critical": false,
