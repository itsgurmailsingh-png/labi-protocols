  "category": "Molecular Biology",
  "estimated_time_mins": 78,
  "materials": [
    "Proteinase K",
    "ATL buffer",
    "Bento Lab heat block",
    "Qiagen spin column",
    "AL buffer",
    "96–100% ethanol",
    "1.5 mL Eppendorf tube",
    "Buffer AE",
    "nuclease-free water"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 20 µL of Proteinase K to each 5 mL tube containing the filter and ATL buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Vortex briefly or manually shake to mix.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate the tubes in the Bento Lab heat block at 56 °C for 1–3 hours, or overnight for better yield. Ensurefilters are fully submerged.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "After the incubation, transfer 400 µL of the lysate (avoiding large filterfragments) into a new 1.5 mL tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 400 µL volume (1:1) of AL buffer to the lysate and mix thoroughly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 400 µL volume of 96–100% ethanol and mix again (vortex or pipette up and down).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Apply 600 µL of the mixture to a Qiagen spin column in steps; centrifuge at 6,000–8,000 rpm for 1 min in Bento Lab centrifuge.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Discard flow-through each time and repeat until all of the lysate from the 1,5 mL tubeis centrifuged through the column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Perform the wash steps according to the original protocol",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Place spin column in a new 1.5 mL Eppendorf tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add 80 µL of Buffer AE or nuclease-free water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Incubate at room temperature for 1 min, centrifuge 1 min to elute DNA.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "An Inhibitor removal can be performed on each sample or the samples can be stored at -20 °C until further analysis.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
