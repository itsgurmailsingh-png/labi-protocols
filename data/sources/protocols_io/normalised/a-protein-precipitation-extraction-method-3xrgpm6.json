  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "The frozen plasma was thawed at room temperature (25 ± 1°C).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "The thawed plasma was vortexed to ensure the sample was homogenous.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "To each 100 µL plasma sample, 50 µL of internal standard (IS) (containing 2 µg/mL of IS) was added, followed by the addition of 250 µL of acetonitrile (ACN).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "The mixture was vortexed, shaken for 5 s, and centrifuged for 2 min at 14800 rpm.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "The supernatant was filtered with a 0.2 µm syringe filter, then transferred to new a vial.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Two microliters were then injected into the LC-MS/MS system.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
