  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Wash mDANs with DPBS once.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Triturate with 1 mL tip to dissociate mDANs in Neurobasal media with 10% fetal bovine serum.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Resuspend dissociated mDANs in Neurobasal media with 10% fetal bovine serum + 10 uM Y-27632 + 5 uM Emricasan to a concentration of 1 million cells per mL.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Dissociate Day 35 mDNAs with prewarmed papain with DNAse, Y-27632 and Emricasan for 00:10:00 at 37 °C . Note: iPSCs can be used as the negative control.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Pellet mDANs by centrifugation at 400 x g, °C, 5 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Use iPSCs to define tdTomato- population and use the threshold to determine tdTomato+ population in mDAN suspension.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Filter mDAN suspension through a strainer tube and keep filtered cell suspension on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
