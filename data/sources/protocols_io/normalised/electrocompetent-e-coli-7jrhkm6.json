  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Grow 5 mL culture of LB w/o salts overnight",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Pre-cool centrifuge to 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Inoculate 400 mL LB w/o salts with 5 ml pre-culture and incubate for 3 hours to OD600 0.5-1.0.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Transfer culture volume to 8 Greiner tubes of 50 mL and leave on ice for 15 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge for 10 minutes at 2000g and 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Remove supernatant and add 5 mL + 45 mL of 10% glycerol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge for 10 minutes at 2000g and 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Remove supernatant and add 5mL + 45mL of 10% glycerol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Hold on ice for 10 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge for 10 minutes at 2000g and 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Remove supernatant and resuspend in 1 mL ice-cold 10% glycerol, pool fractions.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Centrifuge for 5 minutes at 1500g and 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Remove supernatant and add 400 μL 10% glycerol (=800 μL suspension).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Aliquot 40μL in pre-cooled eppendorfs and flash freeze with N 2 (l). Store -80ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
