{
  "protocol_id": "efficient_dna_extraction_from_cytogenetic_suspensions",
  "parent_protocol_id": null,
  "title": "Efficient DNA Extraction from Cytogenetic Suspensions",
  "author": "Geórgia iz Monteiro Sant'ana-Arruda",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.e6nvw4289lmk/v1",
  "source_name": "protocols_io",
