  "source_url": "https://www.protocols.io/view/efficient-dna-extraction-from-cytogenetic-suspensi-hcdib2s4f",
  "doi": "dx.doi.org/10.17504/protocols.io.e6nvw4289lmk/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.e6nvw4289lmk/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 78,
  "materials": [
    "Carnoy’s solution",
    "1.5 mL microcentrifuge tube",
    "NaCl",
    "Tris-HCl",
    "EDTA",
    "water bath",
    "isopropanol",
    "ethanol",
    "Milli-Q water"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Homogenize the cytogenetic suspensions fixed in Carnoy’s solution (methanol and acetic acid at a ratio of 3:1) .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Transfer 150 µL to a 1.5 mL microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at 8,000 rpm for 10 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Discard the supernatant and allow the fixative to evaporate in an incubator at 37 °C for 45 minutes (or until no odor remains).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 440 µL of extraction buffer (NaCl 5 M: 8 mL; Tris-HCl 1 M pH 8.0: 1 mL; EDTA 0.5 M pH 8.0: 400 µL; SDS 10%: 20 mL; ultrapure water: 70.6 mL; final volume: 100 mL) and 16 µL of proteinase K (10 mg/mL).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Vortex briefly and incubate in a water bath at 55 °C for 1 hour 30 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 300 µL of NaCl 5 M. Vortex for 30 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Centrifuge at 10,000 rpm for 10 minutes. Transfer 500 µL of the supernatant to a previously labeled 1.5 mL microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 500 µL of ice-cold 100% isopropanol. Mix by gentle inversion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge at 10,000 rpm for 10 minutes. Discard the supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Wash the pellet with 300 µL of ice-cold 70% ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Centrifuge at 10,000 rpm for 5 minutes. Discard the supernatant and allow the pellet to air-dry.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Resuspend the pellet in 30 µL of autoclaved Milli-Q water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
  "normalised_at": "2026-06-17T14:40:03.315496Z",
  "llm_normalised": true
}