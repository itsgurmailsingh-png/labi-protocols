  "category": "Plant Biology",
  "estimated_time_mins": 114,
  "materials": [
    "Eppendorf tube",
    "metal bead",
    "TissueLyser",
    "DMSO (HPLC grade)",
    "centrifuge",
    "LC-MS vials",
    "thin net fabric",
    "rubber band",
    "lyophiliser flasks"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Weight 25 ± 2.5 mg of lyophilized plant material into a 2.0 Eppendorf tube with round bottom",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add a metal bead to each tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Homogenize in TissueLyser 30 sec, 25 rpm",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 2 000 μL of DMSO (HPLC grade) and vortex to mix",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate 3 min at 40 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge 5 min , 14 000 rpm",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Transfer 10 μL of supernatant into LC-MS vials with insert and add 90 μL of CH3CN-H2O solution (50:50, v/v)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Homogenise in TissueLyser 60 sec, 25 rpm",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Collect a portion of fresh plant material (leaf, root, stem, flower, fruit) into a 50 mL Falcon tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Close the tubes tightly",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Put the tubes in dry ice immediately for transportation to the lab",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Unscrew the tubes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Cover the top and sides with one piece of thin net fabric",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Attach the fabric to the tube with a rubber band",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Insert the tubes into the lyophiliser flasks",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Run the lyophilisation for 3 days (follow lyophiliser instructions)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Insert all the lyophilised material into a lab grinder",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Grind the material to obtain a powder",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Store the material in dry room in a tightly closed Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
