{
  "protocol_id": "extraction_of_rna_from_soybean_leaves_using_the_trizol_method",
  "parent_protocol_id": null,
  "title": "Extraction of RNA from Soybean Leaves Using the Trizol Method",
  "author": "Ian de Paula Alves Pinto",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.kqdg32851v25/v1",
  "source_name": "protocols_io",
  "source_id": "102592",
  "source_url": "https://www.protocols.io/view/extraction-of-rna-from-soybean-leaves-using-the-tr-dge83thw",
  "doi": "dx.doi.org/10.17504/protocols.io.kqdg32851v25/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.kqdg32851v25/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 78,
  "materials": [
    "soybean leaves",
    "liquid nitrogen",
    "autoclaved mortar",
    "1.5 mL microtube",
    "Trizol reagent",
    "chloroform",
    "isopropanol",
    "75% ethanol",
    "rnase-free water",
    "centrifuge",
    "pipette",
    "ice",
    "container",
    "mixing device"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Grind 100 mg of soybean leaves in liquid nitrogen in an autoclaved mortar.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Pass the mixture into a previously autoclaved 1.5 mL microtube and add 1 mL of TriZol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Homogenize the sample for 5 minutes and keep it in a container with ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 200µL of chloroform to the sample and mix for 3 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge for 15 minutes at 12000 rpm 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Pipette off 400 µL of the supernatant and add it to a new tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 300 µL of ice-cold isopropanol and mix for 1 minute. Then leave the samples at room temperature for 10 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Centrifuge for 10 minutes at 12000 rpm 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Discard the supernatant and add 1 mL of ice-cold 75% ethanol, keeping the microtubes on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge for 5 minutes at 9500 rpm 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Repeat the previous two steps 2 times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Dry the pellet at room temperature until there is no more ethanol inside the microtube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Dilute the pellet in 35 µL of rnase-free water or water for injections followed by treatment with dnase.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
