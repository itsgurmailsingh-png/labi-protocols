  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Determine which clones to expand based on screening.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Coat 24 well plate with 250-300 ul Matrigel per well (1 well per well, from 96 well).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate at 37 °C for 01:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Remove Styrofoam box from -80 °C and remove plate. Check on plate after 00:15:00 to avoid over-thawing.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "To each well add mTesR1 supplemented with 10 uM Rock inhibitor. a. Remove desired cells from appropriate wells and transfer to 1.7 mL tube. Spin off freezing media. Plate cells in 24 well plate. -or- b. Remove desired cells from appropriate wells and dilute 1:5 (final volume of 500uL) in mTesR1 and plate in 24 well plate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate at 37 °C overnight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Change mTesR1 daily.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
