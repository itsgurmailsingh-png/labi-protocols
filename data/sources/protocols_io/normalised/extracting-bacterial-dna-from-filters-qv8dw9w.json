  "materials": [
    "lysis buffer",
    "SDS",
    "phenol:chloroform:isoamyl alcohol",
    "chloroform",
    "2mL tube",
    "5mL snap cap tube",
    "4mL 100kDa Amicon concentrator",
    "sterile water",
    "vortex mixer",
    "centrifuge"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 1mL lysis buffer to each filter in a 5mL snap cap tubea. Lysis buffer: i. 40mM EDTA ii. 50mM Tris iii. 0.75M sucrose",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate 45min at 37°C, shaking gently",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add SDS to 1% v/v (in this case, 100ul of 10% SDS solution was added to each sample)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate 1hr at 55°C, shaking gently",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Collect liquid lysate into a 2mL tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 1mL phenol:chloroform:isoamyl alcohol and mix well",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge 5min at 8000g",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Transfer aqueous phase to new 2mL tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Repeat steps 6-8",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 1mL chloroform and mix well",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Centrifuge 5min at 8000g",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer aqueous phase to upper reservoir of a 4mL 100kDa Amicon concentrator",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Centrifuge at 1000g until &lt;200ul remains",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add 2mL sterile water to upper reservoir",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Vortex for 20sec at 1500rpm",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Centrifuge at 1000g until &lt;200ul remains",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Repeat steps 14-16",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Collect sample from upper reservoir and transfer to 1.5mL tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Check concentration with Qubit HS DNA assay",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
