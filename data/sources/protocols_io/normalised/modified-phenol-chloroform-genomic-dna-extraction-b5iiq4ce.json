  "doi": "dx.doi.org/10.17504/protocols.io.b5iiq4ce",
  "citation": "dx.doi.org/10.17504/protocols.io.b5iiq4ce",
  "category": "Genomics & Sequencing",
  "estimated_time_mins": 276,
  "materials": [
    "1x TE Buffer",
    "Lysozyme",
    "SDS",
    "Proteinase K",
    "Phenol Chloroform Isoamyl alcohol",
    "Centrifuge",
    "Pipette",
    "Vortex",
    "Tube",
    "Liquid culture",
    "Filtered cells"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Start with filtered cells OR spin to get pellet from liquid culture.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Pipette off supernatant, if any.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 380 uL 1x TE Buffer + 20 uL Lysozyme to sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate for 1 h at 37˚C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 60 uL SDS + 30 uL Proteinase K + 110 uL 1x TE Buffer (total volume = 600 uL) to sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate for 2 h at 37˚C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Vortex tube thoroughly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Incubate at 37˚C for 1 h , or until samples are clear.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate at 65˚C for 30 min to inactivate Proteinase K.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Stop here and store at -20˚C or move to extraction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add equal volume (600 uL) of Phenol Chloroform Isoamyl alcohol (P/C/I) to sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Invert samples thoroughly before centrifuge step.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Spin at 10,640 rcf for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "White interface should be visible.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Transfer aqueous phase (top layer) to new tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Transfer approx. 500 - 600 uL in 100 uL increments.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Do not disturb interface.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Add equal volume of Chloroform Isoamyl alcohol (C/I) to sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Approx. 500 uL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Invert sample thoroughly before centrifuge step.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Spin at 10,640 rcf for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "White interface should be visible.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Transfer aqueous phase (top layer) to new tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Do not disturb interface.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Approx. 300 - 500 uL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Store at -20˚C or move to ethanol precipitation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Add 2 volumes of ice cold 100% Ethanol to sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "E.g. Have 50 uL of DNA solution, add 100 uL Ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Add 0.1 volumes of 3M Sodium Acetate pH 5.2 to sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "E.g. Have 50 uL DNA solution, add 5 uL Sodium Acetate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Incubate at -20˚C for at least 1 hr.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Cold incubation for a longer period of time (e.g. over night) may lead to higher yield.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Spin at 13,000 rcf for 30 min at 4˚C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Should see small white pellet. If tube is placed hinge-side outward, the pellet should be found below the hinge and almost to the bottom.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Pipette off supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Gently add 150 uL of 70% ethanol to remove salts.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Do not dislodge pellet. Keeping the samples on ice or in cold tube racks will help pellet stay in place.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "Spin at 13,000 rcf for 10 min at 4˚C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 38,
      "title": "",
      "instruction": "Pipette off supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 39,
      "title": "",
      "instruction": "Spin at 13,000 rcf for 1 min to bring down any excess ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 40,
      "title": "",
      "instruction": "Pipette off any remaining liquid.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 41,
      "title": "",
      "instruction": "Dry pellet for 5 min MAX.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 42,
      "title": "",
      "instruction": "Any longer makes resuspending difficult.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 43,
      "title": "",
      "instruction": "Resuspend pellet in 50 uL Molecular Bio water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 44,
      "title": "",
      "instruction": "Use 1- 3 uL of DNA to quantify using Qubit HS dsDNA assay kit.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 45,
      "title": "",
      "instruction": "Store at -20˚C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
  "normalised_at": "2026-06-18T09:47:06.719255Z",
  "llm_normalised": true
}