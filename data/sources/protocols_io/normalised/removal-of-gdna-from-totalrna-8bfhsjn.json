  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "pipet components into a RNase-free 1.5 ml tube (following order: H2O, buffer, total RNA, DNaseI)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "incubate reaction at 37°C 00:30:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "add 1 µl 50 mM EDTA and incubate at 65°C 00:10:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "add 1/10 Volume NaOAc and 3 Volumes 100% EtOH",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "freeze at -20°C over night or at -80°C for at least 1h",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "centrifuge at 13000 rpm at 4°C 00:30:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Discard supernatant RNA pellet may be invisible, make sure to align tube lid so you remember where the pellet is located",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "add 500 µl 70% EtOH",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "centrifuge at 13000 rpm at 4°C 00:10:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "discard supernatant, remove as much ethanol as possible",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "dry tubes at RT under the hood (~5min), do not overdry!",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "resuspend pellet in 20 µl RNase-free water",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "measure concentration",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
