  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Weigh 1 g of agar into flask and add 100 ml H 2 O.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Melt the agar by heating in microwave. Keep an eye on it so that it does not boil over. Make certain that all of the agar is melted and that it has come to a rolling boil.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "While agar cools mash up approximately 100 ml of fruit in the beaker.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "When agar is cool to the touch add in the fruit and mix. You now need to work quickly before the agar sets.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 2ml propionic acid plus 0.8 ml Nipigin solution",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Mix all well and portion to bottles (about 10 to 12 ml).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Plug bottles and allow to cool. Store 4°",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
