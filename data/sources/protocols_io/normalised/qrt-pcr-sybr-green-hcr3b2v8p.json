  "category": "Molecular Biology",
  "estimated_time_mins": 78,
  "materials": [
    "TRIzol",
    "chloroform",
    "isopropanol",
    "70% ethanol",
    "RNase-free water",
    "PrimeScript RT Mix",
    "SYBR Mix",
    "cDNA",
    "primers"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Lyse/Homogenize: Add 1 mL TRIzol per 50–100 mg tissue or 5–10×10^6 cells. Homogenize thoroughly; incubate 5 min at RT.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Phase Separation: Add 0.2 mL chloroform per 1 mL TRIzol, vortex 10 s, incubate 10 min at RT. Centrifuge 12,000×g, 10 min, 4 °C. Transfer aqueous phase.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "RNA Precipitation: Add 0.5 mL isopropanol per 1 mL TRIzol, invert gently, incubate 10 min RT. Centrifuge 12,000×g, 10 min, 4 °C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Wash: Wash pellet 3× with 70% ethanol, centrifuge each time. Air-dry 30 min RT.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Resuspend &amp; QC: Dissolve in 50 µL RNase-free water, measure purity (A260/A280 &gt; 1.8). Store at −80 °C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Reaction (20 µL): 1 µg RNA, 4 µL 5× PrimeScript RT Mix, water to 20 µL. Program: 37 °C 15 min, 85 °C 5 s, 4 °C hold. Dilute to 100 µL, store at −20 °C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Reaction mix (10 µL): 5 µL SYBR Mix, 1 µL cDNA, 0.5 µL primers each, 3 µL water. Set up triplicates, NTCs. Seal, centrifuge plate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Option A (Tm ≥ 60 °C): 50 °C 2 min; 95 °C 2 min; 40× (95 °C 15 s, 60 °C 1 min). Option B (Tm &lt; 60 °C): 50 °C 2 min; 95 °C 2 min; 40× (95 °C 15 s, 55–60 °C 15 s, 72 °C 1 min). Melt Curve: 95 °C 15 s; 60 °C 1 min; slow ramp to 95 °C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Export CT values.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "ΔCT = CT(target) − CT(housekeeping).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "ΔΔCT = ΔCT(experimental) − ΔCT(control).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Expression = 2^-ΔΔCT.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "5. Confirm single melt peak. Plot in Prism.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
