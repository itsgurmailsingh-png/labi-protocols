  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "The seedlings were cultured in Kimura’s culture solution B until six-leaf stage.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "200 mg of fresh leaf tissue subjected to alkaline treatment of pH 9.5 for 0, 3, 5 days was extracted in 2.0 ml of TCA (0.1% w/v) on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "The homogenate was then centrifuged at 12,000 rpm for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "add 0.3 mL of 10 mM sodium phosphate buffer (pH 7.5).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "add 0.6 mL of 1 M potassium iodide to 0.3 mL of the above supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "the absorbance of the samples was measured at 390 nm.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "H2O2 content, expressed as nmol g-1 fresh weight, was determined based on the standard curve generated from known concentrations of H2O2.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
