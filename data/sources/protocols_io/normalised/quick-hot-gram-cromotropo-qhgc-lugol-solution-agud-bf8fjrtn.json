  "estimated_time_mins": 78,
  "materials": [
    "wooden toothpick",
    "container",
    "absolute methanol",
    "Crystal violet",
    "acid alcohol solution",
    "95% ethanol",
    "microscope",
    "immersion oil",
    "xylene",
    "cover slide",
    "Entellan®"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Homogenize the sample well with a wooden toothpick in the container that contains it",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Make a grade spread of approximately 2 cm long by 2 cm wide, sliding the stick impregnated with fecal matter onto a new degreased, dry, or used but clean and scratch-free slide.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Remove excess stool with a clean, chopped wooden toothpick and repeat this procedure with another clean chopped toothpick, until the spread is as thin as possible and with the least amount of lumps of stool",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Let to dry at room temperature",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Fix the plate in absolute methanol for 5 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Let it dry at room temperature to proceed with staining or store it in a box wrapped in absorbent paper until staining.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Cover the spread with Crystal violet for 1 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Wash under running water to remove excess dye",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Cover with an acid alcohol solution for 3 min until discolored",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Go through 95% ethanol for 1 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Visualize under a microscope with immersion oil at 100X",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Permanent fixation use xylene for 1 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Let to dry and cover with a cover slide and Entellan®",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
