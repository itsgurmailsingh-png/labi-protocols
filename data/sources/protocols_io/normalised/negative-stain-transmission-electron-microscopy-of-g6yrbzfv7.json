  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Use carbon-coated copper-palladium EM grids.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Glow discharge grids for 00:01:00 immediately before sample application to increase hydrophilicity.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Apply purified ATG9A vesicle suspension to the glow-discharged grid.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Stain by applying 5 µL of 2% uranyl acetate solution to the grid.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate for 00:00:30 , then blot.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Repeat the staining step once more with fresh 2% uranyl acetate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Allow grids to air-dry completely.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Store dried grids under vacuum until imaging.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Image stained grids using a FEI Morgagni 268D transmission electron microscope equipped with a tungsten filament emitter , operated at 80 kV .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Images were acquired at 44,000× magnification using an 11- megapixel Morada CCD camera (Olympus).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
