  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Wash the worms off the plates using few milliliters of M9 and collect in a 15ml falcon tube and fill up till 15ml with M9",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Centrifuge the tube at 1500rpm for 2mins followed by removal of the supernatant using a pasteur pipette and addition of another 15ml of M9",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Repeat the steps 2 more times",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "After the final wash remove the supernatant as much as leaving behind 10ml in the falcon tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Consolidate all the worm liquid in a 50ml tube and dilute if necessary, for the COPAS",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Ideally make 2x50ml Falcon tubes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Dispense the worms using the COPAS following the protocol COPAS wormsorter",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
