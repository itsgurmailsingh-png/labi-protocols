  "citation": "dx.doi.org/10.17504/protocols.io.4r3l2774jg1y/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 120,
  "materials": [
    "1.5 ml tube",
    "steel bead",
    "CD1",
    "scalpel",
    "TissueLyzer II",
    "PowerBead Pro plate",
    "proteinase K",
    "film seal",
    "vortex",
    "S-block"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add steel bead to 1.5 ml tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 800 µL CD1 to tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Weigh tube (with bead and solution)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Dissect approximately 25 mg (3 mm 3 ) piece of tissue Fragment tissue with scalpel Add tissue to tube (with bead and solution)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Weigh tube and calculate net tissue weight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Process tubes on TissueLyzer II, 2 min at 30 Hz Rotate block 180º and repeat",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge tubes briefly to collapse foam",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Spin PowerBead Pro plate to ensure beads are settled at the bottom",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add contents of each specimen tube (except steel bead) to a PowerBead plate well",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 5 µL of 20 mg/ml proteinase K to each well",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Seal plate with film Vortex briefly to mix",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Incubate plate at 65º C for 60 min or until tissue is mostly digested",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Process plate on TissueLyser II, 5 min at 25 Hz Rotate plate 180º and repeat",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Centrifuge plate at 3000 x g for 7.5 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Transfer approximately 350 µL supernatant from each well to fresh S-block using well-vator",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "add 300 µL of solution CD2 to each well and mix thoroughly by pipetting",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Seal the plate with film Centrifuge at 3000 x g for 7.5 min at room temperature",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Avoiding the pellet, transfer 500 µL of supernatant to fresh S-block using well-vator",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Follow DNeasy 96 PowerSoil Pro Protocol for QIAcube HT (page 17 onward) Elute in maximum volume (120 µL) Incude vacuum performance check",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Seal plate and freeze at -20ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
