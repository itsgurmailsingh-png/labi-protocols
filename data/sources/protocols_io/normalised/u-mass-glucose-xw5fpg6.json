  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Check waste and fill glucose reagent reservoir.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Prepare ~0.1ml of standard solution (~144 mg/dl).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Press “Enter”, and then “No” to cycle the Analox Analyzer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "When cycling is finished, wait for reading to return to ~0 mg/dl (±1mg/dl).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Enter calibration mode.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Using precision pipet, inject 10 µl of standard solution.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Rinse pipet with dH 2 O.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "When value is reached, accept calibration.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "When reading has returned to ~0 mg/dl, inject 10 µl of standard solution, and ensure that the value is ~144 mg/dl.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Repeat steps #5~#9 until calibration value is stable.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Check calibration by injecting 5 µl of standard and multiplying reported value by 2.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "The final calculated value should be ~144 mg/dl.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Instrument is now ready for sample measurement. Use 5 or 10 µl of plasma sample for glucose concentration measurement.",
