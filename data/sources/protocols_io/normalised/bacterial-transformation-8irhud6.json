  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Thaw a tube of NEB 10-beta Competent E. coli cells on ice for 10 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1-5 µl containing 1 pg-100 ng of plasmid DNA to the cell mixture. Flick the tube 4-5 times to mix cells and DNA but do not vortex.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Place the mixture on ice for 30 minutes. Do not mix.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Heat shock at exactly 42°C for exactly 30 seconds. Do not mix.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Place on ice for 5 minutes. Do not mix.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Pipette 950 µl of room temperature NEB 10-beta/Stable Outgrowth Medium into the mixture.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Place at 37°C for 60 minutes. Shake vigorously (250 rpm) or rotate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Warm selection plates to 37°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Spread 50-100 µl of each dilution onto a selection plate and incubate overnight at 37°C. Alternatively, incubate at 30°C for 24-36 hours or 25°C for 48 hours.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Purify the DNA from selected cultures using a DNA miniprep kit",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
