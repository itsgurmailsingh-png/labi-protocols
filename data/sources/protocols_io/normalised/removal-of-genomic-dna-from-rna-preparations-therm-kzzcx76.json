  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "%s %s Add to an RNase free tube: RNA 1 µg 10X reaction buffer with MgCl2 1 µl DNase I, RNase-free 1 µl (1U) Water to 10 µl",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate at 37 °C for 30 min Undetermined 00:30:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add EDTA, Water and PCI and vortex thoroughly. undetermined, EDTA undetermined, Water undetermined, PCI (phenol chloroform isoamyl alcohol)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge for 10 min at 10000 rpm and 4 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "transfer the upper phase into a fresh tube and add 3 volumen EtOH/ 3M Natrumacetat (30:1, ph 5.2 )",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "precipitate RNA over night at -20 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge 30 min at 13000 rpm and 4 ° C Undetermined 00:30:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Discard supernatant and wash pellet with 75% EtOH ( do not resuspend the pellet)",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge 10 min at 13000 rpm and 4 °C Undetermined 00:10:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "go to step #8 go to step #9",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Discard supernatant and dry pellet for 10 - 15 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "resupend pellet with 30 µl H 2 0",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
