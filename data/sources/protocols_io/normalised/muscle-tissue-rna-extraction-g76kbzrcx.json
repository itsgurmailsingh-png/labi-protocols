{
  "protocol_id": "muscle_tissue_rna_extraction",
  "parent_protocol_id": null,
  "title": "Muscle Tissue RNA Extraction",
  "author": "Joesph B Lesnak",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.bp2l6zxo1gqe/v1",
  "source_name": "protocols_io",
