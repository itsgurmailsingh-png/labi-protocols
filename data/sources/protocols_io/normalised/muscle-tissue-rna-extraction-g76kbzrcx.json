  "doi": "dx.doi.org/10.17504/protocols.io.bp2l6zxo1gqe/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.bp2l6zxo1gqe/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 276,
  "materials": [
    "1.5 ml tube",
    "dry ice",
    "Lysis buffer",
    "β-mercaptoethanol (BME)",
    "heat block",
    "Corvaris TT1 bag",
    "liquid nitrogen",
    "pipette tips",
    "DNA/RNAse free water",
    "proteinase K"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Remove tissue, cut off a section, and place in a 1.5 ml tube on dry ice. Measure the weight of each tissue and write down",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Roughly 30-50 mg of tissue",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Try to avoid really blood sections",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Can be stored in tubes long term till ready to extract",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Prepare Lysis buffer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "300 ul needed per sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 10 ul of β-mercaptoethanol (BME) per 1 mL of Buffer RLT",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Turn on heat block to 55°C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Place tissue pieces in Corvaris TT1 bag and leave on dry ice till ready to pulverize",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Dip bag into liquid nitrogen and impact with Corvaris till powder is formed",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Pulverize all samples before continuing",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 300 uL of Buffer RLT + BME lysis buffer to bag to retrieve frozen, pulverized samples, and place back in 1.5 mL tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Mix up and down with pipette tip to get all powdered sample around bag",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add 590 uL of DNA/RNAse free water to each sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Add 10 uL of proteinase K to each sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Mix with hand by turning over and place in heat block at 55°C for 15 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Centrifuge sample for 10,000g at room temp for 3 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Transfer supernatant to new tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Add 0.5 volume of 100% ETOH (~450 ul) to each sample and mix by hand, do not vortex",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Load 700 uL of sample onto RNeasy spin column",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Centrifuge for 15 seconds &gt;8,000g at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Discard the flow through.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Repeat loading until the whole sample has gone through the column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Add 350 uL Buffer RW1 to the RNeasy spin column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Centrifuge for 15 seconds &gt;8,000g at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Discard the flow through.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Perform DNAase clean up step",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Add 70 uL of Buffer RDD (fridge) to aliquots of Qiagen DNAse (10 uL) (-20°C)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Add the total volume from tube (~80 uL) directly on to column",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Incubate at room temperature for 15 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Add 350 uL Buffer RW1 to the RNeasy spin column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Centrifuge for 15 seconds &gt;8,000g at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Discard the flow through.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Add 500 uL Buffer RPE onto RNeasy spin column",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Centrifuge for 15 seconds &gt;8,000g at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Discard the flow through.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Pipette 500 uL Buffer RPE onto the RNeasy spin column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "Centrifuge 2 minutes &gt; 8,000g at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 38,
      "title": "",
      "instruction": "Discard the flow through.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 39,
      "title": "",
      "instruction": "Transfer RNeasy spin column to new 2 mL collection tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 40,
      "title": "",
      "instruction": "Centrifuge RNeasy spin column for 1 minute to dry at full speed (16,000g) at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 41,
      "title": "",
      "instruction": "Transfer the RNeasy column to new 1.5 mL collection tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 42,
      "title": "",
      "instruction": "Pipette 40 uL of RNase-free water; incubate 1 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 43,
      "title": "",
      "instruction": "Centrifuge RNeasy column for 15 seconds &gt; 8,000g at room temperature",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 44,
      "title": "",
      "instruction": "Measure concentration and A260/A280 and A260/A230 ratios on nanodrop",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 45,
      "title": "",
      "instruction": "Store RNA in -80°C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
