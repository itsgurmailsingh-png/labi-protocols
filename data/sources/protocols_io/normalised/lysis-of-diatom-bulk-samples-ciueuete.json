  "citation": "dx.doi.org/10.17504/protocols.io.x54v9ddkpg3e/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 102,
  "materials": [
    "50 mL Falcon tubes",
    "EtOH (96%)",
    "2.0 mm beads",
    "2 mL twist-top tubes",
    "TNES",
    "ProtK",
    "centrifuge",
    "vortex mixer",
    "incubator",
    "pipette tips"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Centrifuge 50 mL falcon tubes containing the diatom samples 4000 x g, °C, 10 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Discard supernatant EtOH (can be poured from the falcon tube).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 10 mL, fresh EtOH (96%) denatured to each sample (in falcon tube). Vortex samples to elute pellets again.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Prepare each one 2 mL twist-top tube with each one spoon of 2.0 mm (ca. 10) and 1.0 mm (ca. 30) Zirconia beads. Label tubes both on the side and the lid.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 1 mL, sample to each twist-top tube. Either use wide-bore tips or cut off the tips. Otherwise tips tend to clock when pipetting the sample.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge samples 6000 x g, °C, 5 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Discard supernatant EtOH (use 1000 µL tips).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 900 µL, TNES and 100 µL, ProtK to each sample. Depending on the amount of samples this can be prepared as premix. We usually prepare TNES + Proteinase K in batches for 24 samples. Proteinase K tends to self-digest if the time for samples preparation takes too long.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Bead-beat for 00:02:00 at 2400 rpm, °C, .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Incubate samples at 55 °C for 00:20:00 at 1400 rpm, °C, .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Store samples at -20 °C until DNA extraction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Perform multi-habitat diatoms sampling (depending on the protocol).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Prepare one sterile 50 mL Falcon tube for each sample. Label the Falcon tube with EtOH resistant labels (e.g. printed labels).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add 10 mL, diatom sample (e.g. scrape sample) to the Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Add 40 mL, EtOH (96%) denatured to the Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Mix sample by inverting the Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Store samples under dark conditions at Room temperature or at 4 °C until lysis.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
