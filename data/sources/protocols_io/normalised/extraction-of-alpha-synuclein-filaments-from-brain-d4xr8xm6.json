  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Homogenize and release the filaments from the tissue.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Cut and weight the tissue (0.2g-0.5g).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Tissues were homogenized in 20 vol(v/w) extraction buffer of 10 mM Tris-HCl, pH 7.5, 0.8 M NaCl, 10-20% sucrose and 1 mM EGTA.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Homogenates were brought to 2% sarkosyl and incubated for 60 min at 37 °C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Following 10 min centrifugation at 10,000g, the supernatants were spun at 100,000g (45,000rpm) for 40-60 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Further enrich for filamentous α-synuclein and remove other components.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "The supernatants were diluted threefold in buffer 2: 50 mM Tris-HCl, pH 7.5, containing 0.15 M NaCl, 10% sucrose and 0.2% sarkosyl, and spun at 45,000 rpm for 30 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Resuspend the pellet with buffer 3 (100 ul/g tissue). Current concentration is for Cryo-EM, 1:10 dilution for Western Blot or negative staining.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "For further analysis, the samples were centrifuged at 3,000 g for 2 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "The pellets were resuspended in 500 μl/g extraction buffer and centrifuged at 3,000g for 5 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
