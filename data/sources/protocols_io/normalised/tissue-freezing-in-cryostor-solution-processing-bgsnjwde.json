  "materials": [
    "Cryostor solution (CS10)",
    "Hyperthermosol",
    "RPMI",
    "10% FBS",
    "scapels",
    "50ml falcon tube",
    "CoolCell",
    "cryovial",
    "water bath"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Chill Cryostor solution (CS10) on ice (C2874-Sigma).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Most tissue is collected in Hyperthermosol and kept on ice or at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Place tissue in petri dish, add enough ice cold RPMI/10% FBS to cover the tissue (depend on tissue size).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Mince tissue with 2 scapels, just like what we would do for enzymatic digestion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Carefully transfer minced tissue into a 50ml falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Wash and rinse the petri dish with plenty of RPMI/10% FBS. Transfer the RPMI/10%FBS and remaining tissue pieces into the falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge at 1500 rpm for 3 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Discard supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Resuspend the tissue in 1 ml of ice cod CS10 and transfer into a cryovial.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Rinse the falcon tube with 0.8 ml of extra cold CS10 and transfer into the cryovial.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Place cryovial in CoolCell and leave in -80 °C freezer overnight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Remove cryovial from CoolCell next day, and store cryovial in designated box in -80 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "To process cryopreserved tissue, thaw cryovials in water bath at 37 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Transfer thawed tissue into a falcon tube containing 20ml warm RPMI/10% FBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Centrifuge at 500 x g for 4 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Discard supernant. Proceed with preferred tissue digestion protocol",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
