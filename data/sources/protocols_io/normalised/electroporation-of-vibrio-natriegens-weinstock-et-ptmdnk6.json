  "category": "Microbiology",
  "estimated_time_mins": 120,
  "materials": [
    "BHI (Brain heart infusion)",
    "v2 salts",
    "Electroporation-Buffer",
    "Micro-Reaction-Tubes",
    "liquid nitrogen",
    "centrifuge"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Preparation of electrocompetent cells",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "10 mL BHI (Brain haert infusion) + v2 salts Overnight culture",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Inoculation of a new BHI + v2 media with 1% of the overnight culture as inoculum.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Grow at 37°C shaking to an OD of 0.5",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Chill the culture on ice for 15 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Use a chilled (4°C) centrifuge at 4,500 r.p.m. for 20 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Decant the supernatant diligently and carefully",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Resuspend gently in 5-10 mL Electroporation-Buffer (680 mM sucrose, 7 mM K2HPO4, pH 7), then fill the falcon tube to the top.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "To wash, spin again at 4.500 r.p.m. for 15 min at 4 °C, then resuspend gently in 5 mL Electroporation-Buffer. Repeat washing twice for a total of three times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Spin again at 4.500 r.p.m. for 15 min at 4 °C, decant supernatant and resuspend carefully in the residual buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Adjust volume for a OD of 16",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Aliquot in chilled Micro-Reaction-Tubes, then snap freeze in liquid nitrogen",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Store at –80°C Electroporation",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "remove one aliquot with electrocompetent cells from storage",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "keep on ice until thawed",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "add plasmid and mix gently",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Transfer to chilled electroporation cuvette",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Electroporation is done with the following parameters: 700 (–900) V, 25 μF, 200 Ω in a 1mm cuvette",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Recover for one hour at 37°C in brain heart infusion with v2 salts",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Plate on LB2 agar plates.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
