  "category": "Cell Biology",
  "estimated_time_mins": 84,
  "materials": [
    "10 cm petri dish",
    "ice cold PBS",
    "blade",
    "50ml tube",
    "Base media",
    "Liberase",
    "serological pipet",
    "TryplE",
    "resuspension media",
    "SytoxBlue",
    "flow cytometer"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Transfer the tissue onto a 10 cm petri dish",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Rinse 1x briefly with ice cold PBS and aspirate PBS off.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Use a blade to carefully cut the sample into small pieces, approximately 3-4 mm in diameter.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Transfer pieces into 50ml tube and Resuspend in 5ml of Base media + Liberase (200ug/ml)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate 2 hours at 37C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Mix with a 5 ml serological pipet 5 times to break up the pieces.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Let the pellet settle at the bottom of the tube, and transfer supernatant to a new falcon tube (Filter supernatant using 40um mesh)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Resuspend remaining tissue in 2mL of TryplE, incubate for 10 min at 37C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Repeat Step 6 and 7",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Spin cells down (300g for 10min at 4C) and Resuspend cells in resuspension media",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Count cells",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Stain cells with SytoxBlue (1ul/ml)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Incubate at room temperature for 15 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Transfer to ice and proceed to flow sorting",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
