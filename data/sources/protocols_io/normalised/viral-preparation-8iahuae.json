  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Coat the plates with 1% Poly-L-Lysine solution and leave in dry incubator overnight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Plate 6E6 HEK293 T cells overnight in DMEM media",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "In 2 1.5 mL epindorph tube add 150 uL of OptiMEM. In one of them add 15 uL of lipofectamine. In the other add 10 uL of packaging plasmid and 10 uL of the plasmid of interest.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate for 5 minute. 00:05:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Combine the two tubes together for total volume ~ 300 uL and incubate for 5 minutes 00:05:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Remove the media from the plate and add the 300 uL dropwise. Add 1 ML of plain DMEM.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Leave in incubator for 30 minutes 00:30:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 5 mL of DMEM based media.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Remove the media and add to an eppendorf tube stored in 4 degrees. Add another 5 mL of DMEM based media. 4 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Collect all the media.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
