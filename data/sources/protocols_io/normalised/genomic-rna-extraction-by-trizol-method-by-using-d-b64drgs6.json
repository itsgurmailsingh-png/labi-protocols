  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Dissection was used to isolate the larval gut of Drosophila 3rd Instar. (around 10-15 gut was taken)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "The dissected gut was taken in a 1.5ml ependorf tube which contained 200μL of TRIzol. (For a total of 800μL or 0.8 mL of TRIzol needed for the extraction)To avoid spurt, 200μL were taken.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Homogenize by using a micropistle",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 600μL or 0.6mL of TRIzol followed up by adding 200μL or 0.2mL of Chloroform (after adding vortex it) and keep it for 5 minutes incubation",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge at 12000x for 10minutes at 4ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Take supernatant into new tube and add equal amount of isopropanol",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge at 12000x for 10minutes at 4ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "discard the supernatant and retain the pellet",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "wash the pellet by using 1ml of 75% cold ethanol (twice) (after adding ethanol vortex the solution and centrifuge at 7500x for 5 minutes)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Retain the pellet, add RNase free water and check the purity",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
