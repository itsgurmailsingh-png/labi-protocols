  "category": "Molecular Biology",
  "estimated_time_mins": 96,
  "materials": [
    "sodium hydroxide",
    "Tris HCl",
    "sodium acetate",
    "molecular grade ethanol",
    "DNeasy PowerSoil DNA Isolation Kit",
    "50 mL tubes",
    "centrifuge",
    "vortex",
    "thermostatic incubator"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "INTO a 50 mL tube add: 10 g of sediment sample 6 mL sodium hydroxide (0.33M) 3 mL Tris-EDTA (pH 8)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "VORTEX for 00:01:00 INCUBATE at 65 °C for 00:50:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "ALLOW samples to cool to Room temperature CENTRIFUGE at 15000 x g for 01:00:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "TRANSFER 7.5 mL of supernatant to a new 50 mL tube ADD 7.5 mL of Tris HCl (1M, pH 6.7) to neutralize",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "ADD 1.5 mL sodium acetate (3M, pH 5.2) ADD 30 mL of molecular grade 100% ethanol INCUBATE samples at -20 °C for &lt; 01:00:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "CENTRIFUGE samples at 10000 x g for 01:00:00 DISCARD supernatant RETAIN precipitated pellet",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "EXTRACT the total pellet using multiple DNeasy PowerSoil DNA Isolation Kit extractions following the manufacturer&#39;s instructions 0.25-0.5 g of pellet per extraction POOL resultant DNA elutes DNA is now ready for downstream applications",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
