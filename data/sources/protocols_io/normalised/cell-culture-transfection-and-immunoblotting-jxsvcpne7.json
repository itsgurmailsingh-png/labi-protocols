  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Maintain N27 cells in complete DMEM medium",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate at 37 °C in 5% CO2 and 95% humidified air",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Seed cells to appropriate density prior to transfection.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Follow the specific manufacturer’s protocol (Promega) for reagent-to-DNA ratios.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate cells for 48 hours post-transfection.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Perform transient DNA transfection of pAAV using FuGENE6 reagent.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Prepare samples by normalizing to an equal amount of protein (100ug per sample).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Quantify protein concentration using a BCA assay .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge lysates to remove debris and collect the supernatant (whole cell lysate).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Lyse cells using the prepared Lysis Buffer (chilled).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Aspirate medium and wash cells with PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Load 100ug of protein into each lane of an SDS-PAGE gel.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Transfer proteins from the gel to a PVDF membrane .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Run electrophoresis at desired voltage.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Block the membrane with 5% milk in TBST for 1 hour at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Wash the membrane again with TBST.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Incubate with HRP-coupled secondary antibodies for 1 hour at room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Wash the membrane with TBST (typically 3 times for 10 minutes).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Incubate with primary antibodies in blocking buffer or TBST overnight at 4 degrees .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Apply Lumigen chemiluminescent reagents to the membrane according to the manufacturer’s instructions.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Analyze protein band density using Quantity One software.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
