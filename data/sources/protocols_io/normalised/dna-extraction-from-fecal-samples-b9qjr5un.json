{
  "protocol_id": "dna_extraction_from_fecal_samples",
  "parent_protocol_id": null,
  "title": "DNA extraction from fecal samples",
  "author": "Yoshiyuki Matsuo",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.3byl4k912vo5/v3",
  "source_name": "protocols_io",
