  "doi": "dx.doi.org/10.17504/protocols.io.3byl4k912vo5/v3",
  "citation": "dx.doi.org/10.17504/protocols.io.3byl4k912vo5/v3",
  "category": "Molecular Biology",
  "estimated_time_mins": 150,
  "materials": [
    "PBS",
    "EZ-beads tube",
    "Vortex mixer",
    "Micro Smash instrument",
    "MN Bead Tube Holder",
    "Vortex-Genie mixer",
    "Lysis Buffer",
    "Proteinase K Solution",
    "Fecal samples",
    "1.5 mL tube",
    "Centrifuge"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Place 50-100 mg of fecal sample into tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1 mL of PBS per 100 mg of feces.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Mix thoroughly by vortexing.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Allow the sample to stand for 00:02:00 to sediment large debris.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Transfer 300 µL of the suspension to 1.5 mL tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge at 10000 x g, °C, 3 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Discard the supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Resuspend the pellet (~ 30 mg of feces) in 300 µL of PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate at 70 °C for 00:10:00 on the block heater.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Transfer 300 µL of the suspension to EZ-beads tube. The EZ-Beads tube contains zirconium oxide beads of two different sizes (0.2 mm spheres and a large 5 mm bead) that can facilitate efficient cell lysis by bead beating.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Lyse cells either by using disruption device (12.1) or vortex mixer (12.2).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Place the EZ-beads tube in Micro Smash instrument and disrupt cells by shaking at 2500 rpm, °C, 2 minutes . Micro Smash Beads Cell Disrupter (TOMY Digital Biology, MS-100) Caution: Avoid using a disruption device with a high-speed linear reciprocating motion, as this may potentially result in breakage of the EZ-Beads tubes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Place the EZ-beads tube on MN Bead Tube Holder attached to Vortex-Genie mixer and vortex for 00:05:00 at maximum speed. MN Bead Tube Holder (Rubber-foam adapter for processing bead tubes with Vortex-Genie instrument, MACHEREY-NAGEL, 740469)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Briefly spin the tube to collect contents.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Add 300 µL of Lysis Buffer and 30 µL of Proteinase K Solution to the sample in EZ-beads tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Mix by inverting the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Incubate at 56 °C for 00:20:00 on the block heater.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Briefly spin the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Transfer the supernatant (~ 500 µL ) to 1.5 mL tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Centrifuge at 18000 x g, °C, 3 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Transfer the cleared lysate to Maxwell RSC Cartridge.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Add 50 µL of Elution Buffer to elution tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Start the extraction run following the manufacturer&#39;s instructions. Maxwell RSC instrument (Automated nucleic acid purification platform, Promega, AS4500)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Cool to Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Briefly spin the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
