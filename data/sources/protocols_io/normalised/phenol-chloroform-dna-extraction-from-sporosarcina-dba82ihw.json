{
  "protocol_id": "phenol_chloroform_dna_extraction_from_sporosarcina_pasteurii",
  "parent_protocol_id": null,
  "title": "Phenol-chloroform DNA extraction from Sporosarcina pasteurii",
  "author": "Michael S. Carter",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.kqdg324eev25/v1",
  "source_name": "protocols_io",
