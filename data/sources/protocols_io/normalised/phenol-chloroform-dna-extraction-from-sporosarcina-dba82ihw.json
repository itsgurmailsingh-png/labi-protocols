  "source_url": "https://www.protocols.io/view/phenol-chloroform-dna-extraction-from-sporosarcina-dba82ihw",
  "doi": "dx.doi.org/10.17504/protocols.io.kqdg324eev25/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.kqdg324eev25/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 102,
  "materials": [
    "BHI",
    "urea",
    "Resuspension Buffer",
    "Lysis Buffer",
    "lysozyme",
    "SDS",
    "sodium acetate",
    "ethanol",
    "TE buffer",
    "phenol",
    "chloroform",
    "isoamyl alcohol",
    "70% ethanol"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Grow Sporosarcina pasteurii cells in 150 mL of BHI/330 mM urea at 30°C with 200 rpm shaking to an OD600 of 3.5.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Concentrate cells by centrifugation at 15,000 x g for 10 min and pour off the supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Resuspend cells in 10 mL of Resuspension Buffer (50 mM Tris pH 8.0, 10% sucrose).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 2.5 mL Lysis Buffer (Tris pH 8.0, 10 mg/mL lysozyme), 1.5 mL 10% SDS, 5 µL 100 mg/mL RNase A, and 25 µL 50 mg/mL proteinase K to lyse cells and stabilize DNA.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate for 1 h at 37°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 1.3 mL of 3.0 M sodium acetate (pH 5.5) and 30 mL of 100% ethanol to separate DNA from other biomacromolecules by precipitation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Spool DNA onto a glass hook and transfer to 20 mL of TE buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Dissolve DNA in TE buffer for 1 h at 37°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add a 5 mL aliquot of DNA to 7 mL of phenol:chloroform:isoamyl alcohol (25:24:1, Saturated with 10mM Tris, pH 8.0, 1mM EDTA) and mix by inversion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Separate phases by centrifugation at 10,000 x g for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Pipette off the aqueous phase and add to 5 mL of chloroform. Mix by vortexing.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Separate phases by centrifugation at 10,000 x g for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Pipette off the aqueous phase and add to 30 mL of 100 % ethanol. Mix by inversion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Collect precipitated DNA by centrifugation at 10,000 x g for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Wash pelleted DNA twice by adding 5 mL of 70% ethanol, mixing by inversion, centrifuging at 10,000 x g for 5 min, and removing the supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Allow the pellet to dry.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Dissolve the final pellet in 500 µL of TE buffer at 37°C for 1 h.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
