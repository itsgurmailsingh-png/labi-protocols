  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Chop tissues into small pieces, weigh",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add &lt;5.0g per miltenyi C tube with 5mL 1x liberase/DNase in xvivo15 + 1%FCS",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Run on GentleMACS Octo 30 mins/37oC cycle",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Stop liberase with 2mM EDTA",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Mash through smart strainer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "PBS wash/spin cells to pellet at 500g/10 minutes. Resuspend pellet in PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Layer onto ficoll and spin at RT 400g/25 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Remove MNCs from ficoll later and wash with PBS",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Filter through 0.2uM filter",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Count viable cells and resuspend at concentration of 1000/uL in 10X buffer (chilled PBS + 0.05% FBS) for loading to 10X",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
