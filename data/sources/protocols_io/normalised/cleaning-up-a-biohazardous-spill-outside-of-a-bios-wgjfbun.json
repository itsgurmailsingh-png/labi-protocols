  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Close off the area and allow aerosols to settle.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Notify others including supervisor.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Assemble all spill cleanup materials and review procedure.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Don appropriate PPE: laboratory coat, safety glasses or chemical splash goggles (depending on risk of splashes), Nitrile gloves.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Cover spill with paper towels.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Pour (don’t spray) disinfectant to contaminated surface that is covered with paper towels by pouring it around the periphery of the spill area moving inward. Allow the appropriate contact time for the disinfectant and agent.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Wipe up spill. Dispose of the waste in the biohazardous waste containers.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Re-apply disinfectant to contaminated surface and allow it to stand for proper contact time.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Wipe up disinfectant, repeat if necessary.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Segregate contaminated cleanup materials into the appropriate biohazardous waste containers.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
