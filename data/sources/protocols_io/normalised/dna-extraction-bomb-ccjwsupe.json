  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 200 µL of 1mm beads to 1.5ml enppendorf tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 200 µL of 0.5mm beads to 1.5ml enppendorf tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 225 µL of TE buffer to 2ml enppendorf tube TE buffer is in 4°C fridge",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 375 µL of lysis buffer to 2ml enppendorf tube Lysis buffer is in 4°C fridge",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Collect 10-20 mg of sample to 2ml enppendorf tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Put 2ml eppendorf tube in mixmill for sample crush, at this condition: 30 rpm/s, for 4mins 00:04:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Put 2ml eppendorf tube in centrifuge for centrifugation, at this condition: 17.0 x g, 25 °C, 3 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 350 µL of isopropanol to the 1st well of 96 well plate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 125 µL of magnetic beads (10 mg/ml) to the 1st well of 96 deep well plate Shake the bottle and pipetting before using magnetic beads",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 200 µL of the sample (lysate) from the 2ml centrifuged tube to the 1st well of 96 deep well plate USUALLY ADD at LAST",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add 400 µL of isopropanol to the 2nd well of 96 deep well plate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 300 µL of 80% enthanol to the 3rd well of 96 deep well plate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add 300 µL of 80% enthanol to the 4th well of 96 deep well plate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add 100 µL of DD water to the 5th well of 96 deep well plate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Put the prepared 96 deep well plate in the automated DNA extraction machine",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Add 267 µL of 10M ammonium acetate to 2ml enppendorf tube 10M ammonium acetate is in 4°C fridge",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "After the extraction is done, collect 100 µL of the eluted sample as the DNA template for downstream experiments",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
