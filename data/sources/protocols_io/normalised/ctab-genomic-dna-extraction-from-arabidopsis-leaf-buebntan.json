{
  "protocol_id": "ctab_genomic_dna_extraction_from_arabidopsis_leaf_material",
  "parent_protocol_id": null,
  "title": "CTAB genomic DNA extraction from Arabidopsis leaf material",
  "author": "Diep R R Ganguly",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.8epv5y2dl1bz/v3",
  "source_name": "protocols_io",
