  "doi": "dx.doi.org/10.17504/protocols.io.8epv5y2dl1bz/v3",
  "citation": "dx.doi.org/10.17504/protocols.io.8epv5y2dl1bz/v3",
  "category": "Genomics & Sequencing",
  "estimated_time_mins": 120,
  "materials": [
    "CTAB buffer",
    "chloroform",
    "2-propanol",
    "70% ethanol",
    "RNase A",
    "nuclease-free H2O",
    "low EDTA TE buffer",
    "water bath",
    "centrifuge",
    "vortex",
    "clean tubes"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Aliquot required volume of CTAB buffer and heat in water bath at 60 ºC for 5-10 minutes immediately before use.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Cool samples to room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 300 µL chloroform and mix thoroughly with a vortex or vigorous shaking for 15 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge samples for 10 minutes at 20,000 rcf.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add equal volume of ice-cold 2-propanol and mix by inversion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge for 15 min @ 20,000 rcf.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Wash pellet with 1 mL of 70 % ethanol (mix by inversion).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Resuspend gDNA in nuclease-free H 2 O or low EDTA TE buffer (10 mM Tris-Cl pH 8, 0.1 mM EDTA).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Prepare 2% CTAB buffer. A B 1 Reagent [Cf] 2 hexadecyltrimethylammonium bromide 2% (w/v) 3 NaCl 1.4 M 4 EDTA (pH 8) 20 mM 5 Tris-Cl (pH 8) 100 mM 2% CTAB buffer recipe",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 300 µL / 100 mg leaf tissue of CTAB buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add RNase A solution to a concentration 50-100 µg/mL.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Mix well with a vortex. Invert samples by hand to ensure that all ground tissue is in solution.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Incubate in water bath at 60 ºC for 30 - 60 minutes. Mix tubes periodically by inversion.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Transfer upper aqueous (approx. 200 µL) phase to clean tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Repeat steps 9-10 for a cleaner extract.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Incubate for 30-60 min @ -20 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Discard supernatant using pipette.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Centrifuge samples @ 9,200 rcf for 5 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Remove as much ethanol as possible using a pipette, then allow pellet to air dry for 5 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Test yield and purity of samples using a Nanodrop and running samples on a 1 % agarose gel.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
  "normalised_at": "2026-06-17T14:10:42.641494Z",
