  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Thaw cells stored in TRIzol to Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 200 µL of chloroform to the samples and invert to mix.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge the samples at 12000 x g, 4 °C, 15 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Carefully collect the aqueous phase (top clear layer) and dispense into a 1.5 ml RNase free eppendorf tube. Be careful not to disturb the interphase!",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 2 µL GlycoBlue Coprecipitant and 500 µL isopropanol to precipitate the RNA. Incubate for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Wash the RNA pellet with 1 mL of 75% ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Air-dry the RNA pellet for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Isolate the RNA using the Zymo Research RNA Clean &amp; Concentrator-5 kit.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Use the qScript cDNA SuperMix for cDNA library preparation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 20 µL of ultra pure water to the 10 µL cDNA reaction. Pipette up and down 10 times to thoroughly mix.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Resuspend cells in 800 µL of TRIzol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Centrifuge the samples at 12000 x g, 4 °C, 10 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Carefully aspirate the TRIzol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Centrifuge the samples at 7500 x g, 4 °C, 5 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Resuspend the RNA in 40 µL of nuclease-free water.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Add 5 µL of Zymosan DNaseI and 5 µL of DNA digestion buffer to the 40 µL of RNA.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Incubate at Room temperature for 00:15:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Add 2 volumes ( 100 µL ) RNA binding buffer to each sample and mix.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Add equal volume ( 150 µL ) of 200-proof 100% ethanol and mix.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Transfer sample to column. Centrifuge at 16000 rcf, °C, for 00:00:30 . Discard flowthrough.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add 400 µL RNA Prep buffer to column and centrifuge at 16000 rcf, °C, for 00:00:30 . Discard flowthrough.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Add 700 µL RNA Wash buffer to column and centrifuge at 16000 rcf, °C, for 00:02:00 . Discard flowthrough.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Transfer column to nuclease-free tube and add 6 µL of UP-water directly to column. Centrifuge at 16000 rcf, °C, for 00:00:30 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Measure RNA concentration using Nanodrop.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Combine: %s %s",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Incubate using the following rxn: 00:05:00 at 25 °C 00:30:00 at 42 °C 00:05:00 at 85 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Aliquot your samples into labeled PCR tubes (~10uL per tube).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Store samples at -80 °C until ready for qPCR.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
