      "instruction": "·Transfer supernatant into fresh tube. Label tube “Supernatant 1”",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 44,
      "title": "",
      "instruction": "·Discard pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 45,
      "title": "",
      "instruction": "·Adjust balance volume to new sample volume.",
