      "instruction": "Using 5mL serological pipette add to mitochondria pellet up to 5 mL of Cell Lysis Buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 80,
      "title": "",
      "instruction": "·Using",
