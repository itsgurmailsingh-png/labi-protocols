  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": ")\" target=\"_blank\" rel=\"noopener\">Tissue preparation",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "For 5 mL of 15-20 mg/mL of liver mitochondria protein we need 10-15 gm of frozen mouse liver tissue. If more of less protein needed scale these numbers up or down.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Cool down centrifuge and Rotor F-35-6-30 for 6 x 50 mL and 5 x 15 mL tubes. Set temperature +4 0 C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "·Take livers from -80 0 C freezer put on dry ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "·Measure weight of a 10x10 cm square of aluminum foil using )\" target=\"_blank\" rel=\"noopener\">Mettler Toledo Analytical Balance and write it down.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "·Put on the foil unwrapped frozen livers up to 15 gm (about 10 livers)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "·Subtract foil weight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "·Write number.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "·Keep livers on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "·Bring liquid nitrogen in special 1 L liquid nitrogen container.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "·Take ceramic mortar and pestle",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "·Fill mortar with liquid nitrogen and put pestle on dry ice cool down.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "·Put metal spatula on dry ice to )\" target=\"_blank\" rel=\"noopener\">cool down .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "·After liquid nitrogen evaporate mortar is cold enough.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "·Prepare 50 mL conical tube and put int on dry ice",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "·Put 1 st frozen liver in the mortar and add ½ liquid nitrogen up to ½ mortar volume.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "·Wrap pestle with paper towel to avoid frost bite and cover mortar with paper towel.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "·Grind liver till there is only powder in the mortar.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "·With cold spatula put grinded tissue in the 50 mL tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "·Repeat with next liver until all of them are ground.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "·Put mortar and pestle aside to warm up.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "·Clean the bench with 70% ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "·Prepare fresh 50 mL conical tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "·Measure weight using Mettler Toledo Analytical Balance and wright it down.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "·Transfer in fresh tube 10 gm of grinded liver powder (subtract weight of empty tube from weight of the tube with tissue).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "·Extra grinded liver store in -80 0 C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "·To the tube with 10 gm of frozen liver add Tissue lysis Buffer up to 50 mL.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "·Wait till all tissue thawed. Vortex from time to time.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "·Prepare 25 Matrix A 2mL tubes for MP Homogenizer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "·When tissue is fully thawed using transfer pipettes aliquot 50 mL in Martix A tubes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "·Following instruction for MP Homogenizer choose on touch screen",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "-Recommended Settings (Animal: mouse, organ: liver)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "-Run",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "·After program finished put tubes with homogenized liver on regular ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "·Clean and turn off MP Homogenizer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "·Using transfer pipette transfer homogenate into fresh 50ml tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
