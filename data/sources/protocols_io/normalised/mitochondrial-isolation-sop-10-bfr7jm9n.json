      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 41,
      "title": "",
      "instruction": "1 st slow centrifugation. Close rotor lid tightly Close centrifuge Set centrifuge: 2000 rpm, 10 min, 4 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 42,
      "title": "",
      "instruction": "·After centrifugation finished, take tube from centrifuge and put on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 43,
