  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Clean the polydimethylsiloxane molds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Heat deionised water to 100 degrees Celsius 100 °C using a becher.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Put the mold(s) into the water and stir softly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Remove the molds and let them dry in a chemical hood for 1-2 hours.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Fabricate the Microneedles",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Stick the molds on the bottom of an adequate recipient using double-sided tape.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 4g of poly(vinyl alcohol) (30− 70 kDa, 10 wt %) powder and stir until transparent.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Heat 28g of deionised water to 110 degrees Celsius 110 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Prepare the PVA solution",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 1.5 mL of PVA solution on top of the mold.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Centrifuge at 4000 rmp for 20 minutes at 40 degrees Celsius.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Let the microneedles dry under a chemical hood overnight.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Remove the microneedles from the molds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "The microneedles are ready for use.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
