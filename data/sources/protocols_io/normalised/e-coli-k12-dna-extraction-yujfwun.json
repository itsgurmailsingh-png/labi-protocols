{
  "protocol_id": "e_coli_k12_dna_extraction",
  "parent_protocol_id": null,
  "title": "E. coli K12 DNA Extraction",
  "author": "Kenneth Schackart",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.yujfwun",
  "source_name": "protocols_io",
  "source_id": "21099",
  "source_url": "https://www.protocols.io/view/e-coli-k12-dna-extraction-yujfwun",
  "doi": "dx.doi.org/10.17504/protocols.io.yujfwun",
  "citation": "dx.doi.org/10.17504/protocols.io.yujfwun",
  "category": "Molecular Biology",
  "estimated_time_mins": 174,
  "materials": [
    "E. coli K12",
    "BHI broth",
    "microcentrifuge tube",
    "Nuclei Lysis Solution",
    "Protein Precipitation Solution",
    "RNase Solution",
    "heating block",
    "centrifuge",
    "vortex mixer",
    "ice"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Culture E. coli K12 in BHI broth overnight. 2 mg lyophilized E. coli K12 in 10 mL BHI broth.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1 mL cell suspension to 2 mL microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at 13,000-16,000 × g for 00:02:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Remove supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 600 µL of Nuclei Lysis Solution. Nuclei Lysis Solution is marked &#34;NL&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Gently pipet until the cells are resuspended.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate at 80 °C on heating block for 00:05:00 to lyse the cells.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Cool to room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 200 µL of Protein Precipitation Solution to the RNase-treated cell lysate. Protein Precipitation solution is marked &#34;P&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Vortex vigorously at high speed for 00:00:20 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add 3 µL RNase Solution to the cell lysate. RNAse solution is marked &#34;R&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Invert 2-5 times to mix.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Incubate at 37 °C for 00:15:00 to 01:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Incubate on ice for 00:05:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Cool to room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Transfer the supernatant containing the DNA to a clean 1.5 mL microcentrifuge tube containing 600 µL isopropanol. Some supernatant may remain in the original tube conatining the protein pellet. Leave this residual to avoid contaminating the DNA solution with the precipitated protein. Isopropanol is marked &#34;IPA&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Centrifuge at 13,000-16,000 × g for 00:03:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Gently mix by inversion until the thread-like strands of DNA form a visible mass.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Centrifuge at 13,000-16,000 × g for 00:02:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Carefully pour off the supernatant and drain the tube on clean absorbent paper.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add 600 µL of 70% ethanol and gently invert the tube several times to wash the DNA pellet. 70% ethanol solution is marked &#34;Et&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Centrifuge at 13,000-16,000 × g for 00:02:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Carefully pour off the ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Drain the tube on clean absorbent paper and allow to air-dry for 10-15 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add 100 µL of DNA rehydration solution to the tube. DNA Rehydration solution is marked &#34;DR&#34;",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Rehydrate by incubating the solution overnight at room temperature or 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Store DNA at 2 °C to 8 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Label centrifuge tube with your group number.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Label centrifuge tube with your group number.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
