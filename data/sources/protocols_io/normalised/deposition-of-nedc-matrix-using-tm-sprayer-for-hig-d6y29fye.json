  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Remove slides from freezer (-80C) and place in a desiccator for 30 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Collect autofluorescence scan using a Zeiss AxioScan Z1: ( https://www.protocols.io/edit/autofluorescence-microscopy-data-acquisition-b39kqr4w )",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Set nitrogen flow to 10 psi. turn on TM sprayer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Open HTX software.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Set nozzle temperature to 55 o C, and heated stage temperature to 30 o C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Clean sample loop with 3mL of methanol with sprayer set to &#34;load&#34;. Switch to &#34;spray&#34; and allow to spray for 2 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Make the matrix solution at a concentration of 14 mg/mL in a solution of 90% methanol. Sonicate solution for 2 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Switch sprayer to &#34;load&#34; and load sample loop with 2 mL of matrix solution using a syringe.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Switch sprayer to &#34;spray&#34; and allow to spray for ~1 min. Check that matrix is spraying by placing a glass slide under the nozzle.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Tape slide onto heated stage, and adjust the spray area in the HTX software.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Set the method in the HTX software:",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "1350 mm/min nozzle velocity",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "2.0 mm track spacing",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "0.05 mL/min flow rate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "CC pattern",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "14 passes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "40 mm nozzle height",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "2 seconds drying time",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Ensure that the method is highlighted. Press start under the Cycle tab. Click Continue. Wait for purge delay and confirm that the nozzle is moving.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "When matrix deposition is finished, remove the slides and store them in a slide box. Press &#34;valve load confirm&#34; in the software.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Spray the nozzle tip with methanol and acetonitrile, not touching the tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Set both TM sprayer nozzle and stage temperatures to 30 o C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "With sprayer set to &#34;load&#34;, load loop with 3 mL of methanol methanol. Set sprayer to &#34;spray&#34; and allow to flow for ~5 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Clean the stage with Kimwipes tissue that is sprayed with methanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Shut down HTX software and close the computer. Turn off the TM sprayer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Shut off the nitrogen flow.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Dispose of syringes in biohazard container.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
