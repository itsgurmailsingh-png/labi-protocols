  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Shake the sample well. Transfer 800 µL of the small size fraction and 200 µL of the large size fraction to a 2 mL screwcap tube. It might be beneficial to use wide-bore tips or cut off the tip when using regular pipette tips.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "11.000 x g, °C, 3 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Remove as much ethanol as possible with a 1000 µL pipette.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "For each sample prepare a screwcap tube pre-filled with a few 2 mm zirconia beads.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 900 µL of TNES buffer and 100 µL of Proteinase K working solution . Vortex shortly. Depending on the amount of samples this can be prepared as a mastermix. We usually prepare TNES + Proteinase K in batches for 24 samples. Proteinase K tends to self-digest if the time for samples preparation takes too long.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Bead-beat for 00:02:00 at 2400 rpm, °C,",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate 1400 rpm, 56 °C, 20 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Store at -20 °C until DNA extraction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
