      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Streak the bacteria onto agar plates without inhibitor.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate plates for 18-24h at 37ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "For each isolate, select three to five morphologically similar colonies from the agar plates and transfer them to a glass tube with 5ml MH-Broth. Incubate for 18-24h at 37ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Measure OD450 on cultures from step 4, and make dilutions in x mL MHB to OD450 = 0,01",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Use the setup shown in the following figure. a",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Pipette 50µl of MHB into column 2-11",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 100µl MBH into column 12",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 100µl of the antibiotic into column 1",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Withdraw 50µl from each well in column 1, add this to the corresponding wells in column 2. Mix by pipetting up and down 4-6 times. (this makes column 2 a twofold dilution of column 1)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Repeat step 10 down to column 10 - discard the withdrawn solution from column 10.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Vortex the bacteria suspension from step 5. Add 50µl of the suspension to each well in columns 1-11.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Cover the plates with film, make sure to create a tight seal to prevent any evaporation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Incubate the plate at 37ºC for 16-24h.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Measure the growth by determinating OD 450. Compare the data from the three triplicates, and exclude any deviations",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "To exclude any errors repeat every plate setup three times (triplicates).",
