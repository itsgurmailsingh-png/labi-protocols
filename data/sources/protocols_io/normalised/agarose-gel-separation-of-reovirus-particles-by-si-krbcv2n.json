  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Combine 0.4 g of agarose with 40 ml of TAE",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Microwave until agarose is thoroughly melted",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add water to replace water lost during boiling up to 40 ml and mix well",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Pour 35 ml agarose to clean casting rig (7x10 cm)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Mix purified reovirus and loading dye 1:1 at 1x1011 particles per well (25 ul max)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Run at constant 25V for 18 h",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Stain gel with colloidal blue as directed",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Destain gel in water overnight",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Image gel by on Licor Odyssey Imaging System",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
