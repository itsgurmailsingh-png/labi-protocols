  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Use the following cell lines: HAP1 ATG9A-GFP (RRID:CVCL_E2TR) HAP1 ATG9A-GFP ATG2 DKO (RRID:CVCL_F0LE)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Seed cells in 15 cm dishes (two dishes per condition).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Treat cells with: Earle’s Balanced Salt Solution (EBSS). 100 nanomolar (nM) Bafilomycin A1 (BafA).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate for 02:00:00 prior to harvesting.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Harvest cells by trypsinization and pellet via centrifugation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Wash once with PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Resuspend pellets in 800 µL Vesicle Isolation Buffer (VIB): A B 1 HEPES pH 7.5 20 mM 2 NaCl 150 mM 3 Sucrose 250 mM 4 1× cOmplete™ EDTA-free protease inhibitors (Roche) 5 β-glycerophosphate 20 mM 6 Sodium orthovanadate 1 mM 7 NaF 1 mM 8 EDTA pH 8.0 1 mM",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Transfer to LoBind tubes (Eppendorf, Cat# 0030108116).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Lyse cells by passing suspension through a 26G needle 30×.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Chill lysates On ice for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Repeat needle passage another 30×.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Clear nuclei and debris:",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Re-extract pellet:",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Centrifuge at 1000 x g, °C, for 00:10:00 at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Collect supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Add 700 µL VIB to the pellet of the previous step, repeat 1000 x g, °C, spin.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Pool both supernatants.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Remove residual debris:",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Centrifuge pooled supernatants at 2000 x g, °C, for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Collect supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Enrich autophagosomes:",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Centrifuge supernatant at 10000 x g, °C, for 00:20:00 at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Collect pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Wash pellet with 500 µL Wash Buffer (WB): A B 1 HEPES pH 7.5 20 mM 2 NaCl 150 mM 3 1× cOmplete EDTA-free protease inhibitors",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Re-pellet at 10000 x g, °C, for 00:20:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Resuspend final pellet in 500 µL WB + 1 mM DTT %s %s",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Use this AP-enriched fraction for downstream applications.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Use 150 µL of AP suspension.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Add 10 μg/ml proteinase K (Thermo Scientific, Cat# EO0491).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Incubate for 00:20:00 at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Add 1 millimolar (mM) PMSF (Santa Cruz Biotechnology, Cat# sc-482875).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Incubate On ice for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Centrifuge at 10000 x g, °C, for 00:10:00 at 4 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Resuspend pellet in 15 µL WB %s %s 6× SDS loading buffer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Analyze by SDS-PAGE and Western blotting.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
