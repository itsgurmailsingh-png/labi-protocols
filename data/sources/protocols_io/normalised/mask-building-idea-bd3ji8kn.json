  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Make your pattern. Cut out your first set and use them for tracing. No need for perfection. The felt is around 9 x 12 inches. It's not wildly important that the measurements are exact. It's the shapes really. As long as it fits your face.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Glue bottom to front. Match up curved edges.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Glue top to front so that it can be tucked under the bottom. Glue along edges.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Cut 6 1/2 inches of beading wire. Use pliers to curl ends.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Glue wire into bottom part of mask. Glue to edge.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Fold over",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Apply glue to wire curls liberally. Allow time to dry.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Cut 2 1/2 inches of flat wire and glue to front. This will be used to adjust over the nose.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Cut about 12 to 14 inches of elastic x 2",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Glue elastic to mask.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Tuck inner front into mask. No need for perfection.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Fit snuggly to face. Use wires to form. Apply like n95. YouTube “n95 mask application” if needed",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
