  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Inoculate starter culture of 1.5 mL LB medium in ~13 mL test tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate at 37°C on shaking device (&gt; 200 rpm)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "After 1.5 – 2 hours culture should become slightly turbid (exponential growth)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 0.5 – 1.0 µL plasmid from mini prep (high copy: rather 0.3 µL)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate on ice for 20-30 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate 45-60 min at 37°C on shaking device (&gt; 200 rpm) – addition of LB is not requested",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Plate on LB-Agar (incl. appropriate antibiotic)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Work on ice: add 200 mL of culture to 1.5 mL tube and mix with 200 mL 2 x TSS ( dx.doi.org/10.17504/protocols.io.gt3bwqn )",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
