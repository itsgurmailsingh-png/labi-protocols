  "category": "Molecular Biology",
  "estimated_time_mins": 54,
  "materials": [
    "NlaIV enzyme",
    "rCutSmart Buffer",
    "0.5mL microcentrifuge tubes",
    "mtORF amplicons",
    "heat block",
    "mini spinner"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Turn on heat block and set to 37ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Label clean 0.5mL microcentrifuge tubes with SampleID by writing on the tube lid directly with a fine point Sharpie",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Remove one aliquot each of stock NlaIV enzyme and rCutSmart Buffer from the freezer. Vortex gently to mix. Spin down in mini spinner, if necessary",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Prepare NlaIV working solution by combining 62µL rCutSmart Buffer and 62µL stock NlaIV enzyme in a 1.5mL microcentrifuge tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Aliquot 1µL NlaIV working solution into the bottom of each labeled 0.5mL microcentrifuge tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer 5µL mtORF amplicons to each 0.5mL tube. Always double check that you are adding the correct sample to the correct tube",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Flick each tube gently to mix. Spin down tubes in mini spinner",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Incubate all tubes at 37ºC for 60 minutes , then 65ºC for 20 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "If possible, visualize digests immediately on gel. Otherwise, store in fridge",
      "is_critical": true,
      "timers": [],
      "substeps": []
    }
  ],
