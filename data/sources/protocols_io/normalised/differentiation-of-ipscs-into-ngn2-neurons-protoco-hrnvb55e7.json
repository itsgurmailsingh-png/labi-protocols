  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Transfect iPSCs with PiggyBac plasmids using Lipofectamine Stem Transfection Reagent.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Dissociate iPSCs and seed at 104,000 cells/cm² onto Geltrex™-coated plates in StemFlex™ media supplemented with 10 µM Y27632 and 5 µg/mL doxycycline.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transition media to Neurobasal N2B27 with specific supplements.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "On day 1, replace media with Neurobasal N2B27 containing 10 µM SB431542, 100 nM LDN193189, 5 µg/mL doxycycline, and 5 µg/mL puromycin.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "From days 3 to 6, change media daily with Neurobasal N2B27 supplemented with 1 µg/mL puromycin and 5 µg/mL doxycycline.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "On day 6, treat cells with Ara-C and harvest for co-culture.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 0.5 µM Ara-C to the culture for 24 hours.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Use Accutase to dissociate cells and collect for co-culture.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
