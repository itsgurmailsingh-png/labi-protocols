  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Weigh 1.6 g PFA powder",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Dissolve in 20 mL of DI water",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate in water bath at 60 °C to help dissolve PFA powder for 00:40:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 20 µL of 1 M NaOH to further help dissolve PFA powder",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Place back in 60 °C water bath for 00:10:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Pull out of water bath and cool to Room temperature",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add two tablets of PBS to a 100 mL volumetric flask",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Mix 20 mL of each solution to get 4% formaldehyde",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 400 µL of glycerol to fixative",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Ensure pH 7.5",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Place fixative in a hot water bath till 60 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
