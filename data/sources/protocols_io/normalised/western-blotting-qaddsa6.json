  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Incubate E.coli cells 1:100 in 10 ml LB medium with antibiotics.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "OD600=0.4 , collect all cells at 4 ℃, 8000 rpm for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Wash with 1 ml 1*PBS one time.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Resuspend in 500 ul 1 * PBS and sonicate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Spin at 10000 rpm for 15 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer supernatant into a new 1.5 ml tube and sit on ice.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Load into 120% SDS-PAGE gel , run at 200v for 45 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Get the PVDF membrane and filter paperPVDF: Put in methanol (5s) then in transfer bufferFilter: transfer bufferGel: transfer buffer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Sit on Room Temperature for 20 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Transfer membrane at 25 V for 30 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Blook woth 5% skim milk RT for 1 hour.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "1:1000 Ab1 DnaA Ab.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "4 ℃ over night rotation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Wash the membrane with 1* PBST for 3 times (15 min , 10 min, 5 min).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Dillute AB2 1:10000 in 50 ml PBST.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Incubate with Ab2 for 1 h.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Wash the membrane with 1* PBST for 3 times (15 min , 10 min, 5 min).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Mix solution 1 and 2 (1:1).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Incubate the membrane with Mix solution for 5 s.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Develop the membrane with ChemiDoc MP Imaging system (BIO-RAD).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
