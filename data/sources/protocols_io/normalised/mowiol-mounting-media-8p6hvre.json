  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "1.Mix glycerol and Mowiol; dissolve with frequent agitation for 1 h at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "2.Add H 2 O. Stir for 1 h at room temperature.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "3.Add Tris-Cl. Incubate for 2 h at 50°C with occasional stirring (e.g., for 2 min every 20 min).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "4.Centrifuge at 5000 g for 15 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "5.Store 3-mL aliquots of the supernatant for up to 12 mo at -20°C. Mowiol often does not dissolve completely.",
