  "materials": [
    "12 mm #1.5 glass coverslips",
    "EBSS",
    "cold methanol",
    "4% PFA",
    "PBS",
    "blocking buffer",
    "primary antibodies",
    "secondary antibodies",
    "DAPI Fluoromount-G®",
    "glass microscopy slides",
    "Zeiss LSM900",
    "Airyscan 2 module",
    "Plan-Apochromat objective",
    "Zeiss Zen Blue software"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Seed 100,000 cells per well on 12 mm #1.5 glass coverslips (Marienfeld, Cat# 0117520) in a suitable 6-well plate.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate Overnight at 37 °C with 5% CO₂.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Treat cells for 02:00:00 with one of the following (as per figure legend): EBSS (Sigma-Aldrich, Cat# E3024- 500 mL ) + 100 nanomolar (nM) Bafilomycin A1 (Santa Cruz Biotechnology, Cat# sc-201550) 2 micromolar (µM) VPS34-IN1 (ApexBio, Cat# APE-B6179)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Fix cells in cold methanol for 00:05:00 at -20 °C or 4% PFA for 00:10:00 at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Wash cells with PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate coverslips for 01:00:00 at Room temperature in blocking/permeabilization solution: PBS 0.25% (v/v) Triton‱ X-100 (Sigma-Aldrich, Cat# T8787) 5% (v/v) BSA (Sigma-Aldrich, Cat# A9647)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate cells with primary antibodies diluted in blocking buffer for 02:00:00 at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Wash 3× with PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate with secondary antibodies (1:500 in blocking buffer) for 02:00:00 at Room temperature .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Wash 3× with PBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Mount coverslips onto glass microscopy slides using DAPI Fluoromount-G® (Southern Biotech, Cat# 0100-20).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Store mounted slides at -20 °C until imaging.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Acquire confocal images using a Zeiss LSM900 with Airyscan 2 module and a Plan-Apochromat 63×/1.4 Oil DIC, WD 0.19 mm objective.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Process images using 2D Airyscan processing plug-in in Zeiss Zen Blue software.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
