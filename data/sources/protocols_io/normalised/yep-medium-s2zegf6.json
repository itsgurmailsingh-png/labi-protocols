      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "To 300 mL of seawater, add : 1 g Difco bacto-peptone 1 g Bacto yeast extract 10 g D-glucose anhydrous",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Complete final volume to 500mL of seawater",
