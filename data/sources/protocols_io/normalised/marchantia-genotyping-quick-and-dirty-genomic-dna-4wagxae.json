      "step_id": 0,
      "title": "",
      "instruction": "Take small pieces (3x3 mm) of thalli from individual plants and place in a 1.5 mL Eppendorf tube (A in Figure).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Place the tube(s) at 80 °C for 10 min.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 380 μL of sterile water to each tube (D in Figure).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Use 5 μl aliquot of the extract as a template for PCR using preferably the KOD Hot start polymerase. We found KOD to be more reliable amplyfing fragments from a crude genomic DNA extract such as the one used here.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 100 μl genotyping buffer (B in Figure).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Crush with an autoclaved micro-pestle (C in Figure).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Check PCR products on a 1.5% (w/v) agarose gel.",
