  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Pipette 10 mL BHI broth into 15 mL centrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Place tube in incubator or water bath to warm.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 2 mg lyophilized E. coli K-12 to warm BHI broth.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Close lid and shake gently.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate at 37 °C for several hours.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Dispense 1 mL BHI broth into cuvette. This should be broth without bacteria and will serve as your reference for calculating absorbance.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Carefully insert cuvette into spectrometer. Wipe cuvette with delicate task wipes if necessary.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Measure intensity at 600 nm.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Repeat Steps 6-8 with the samples cultured for different durations. Avoid pipetting any precipitation at the bottom of the culture tube. Draw only supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Using the BHI broth without bacteria as I 0, calculate the absorbance of each of the samples.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Plot Absorbance as a function of time cultured. Include this plot, and the table of intensities and calculated absorbances in the &#39;Results&#39; section of your lab report.",
