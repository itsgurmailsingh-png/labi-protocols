  "materials": [
    "40 µg protein",
    "10X Glycoprotein Denaturing Buffer",
    "10X GlycoBuffer 3",
    "10X GlycoBuffer",
    "0.1X Sample Buffer (Bio-Techne)",
    "10K Amicon Ultra Centrifugal Filter"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "In an eppendorf tube, add 40 µg protein, 2 µL 10X Glycoprotein Denaturing Buffer, and water for a total reaction volume of 20 µL . Mix well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Denature glycoprotein by heating reaction at 100 °C for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Split reaction volume into 2 eppendorf tubes with 10 uL in each tube. One tube will be used for the EndoH reaction, while the other will be used for the PNGaseF reaction.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add the following to one reaction tube from step 3: 2 µL 10X GlycoBuffer 3, 2 µL Endo H, 6 µL water. Total volume will be 20 µL .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Mix gently.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate reaction at 37 °C for 01:00:00",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add the following to the second reaction tube from step 3: 2 µL 10X GlycoBuffer 2, 2 µL NP-40, 6 µL water, 1 µL PNGaseF. Total volume will be 21 µL .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Mix gently.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate reaction at 37 °C for 01:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Add 480 µL and 479 µL of 0.1X Sample Buffer (Bio-Techne) to the Endo H and PNGaseF reaction tubes respectively to make the final volume 500 µL .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add all 500 µL of each reaction to a 10K Amicon Ultra Centrifugal Filter",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Spin at 14000 x g, °C, for 00:20:00 . You will recover a final volume of 20 µL , and the protein concentration recovered will be ~ 1 mg/mL .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add 4 parts of the washed Endo H/ PNGaseF sample from step 12 with 1 part of 5X Fluorescent Master Mix (Bio-Techne).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Vortex to mix",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Incubate sample at 95 °C for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Load into JESS microplate (Bio-techne) to be detected by the Automated Western Blot System.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
