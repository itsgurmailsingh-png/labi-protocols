  "materials": [
    "1X PBS",
    "RIPA buffer",
    "cell scraper",
    "microcentrifuge",
    "centrifuge tubes"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Carefully remove all culture media from the flask and add enough ice-cold 1X PBS to wash the cells",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Carefully remove the ice-cold 1x PBS and add ice-cold lysis buffer (RIPA buffer) according to the estimated number of cells: 1 mL for 10^7 cells (roughly a T75 flask).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Use a cell scraper to dissociate the cells from the bottom of the flask.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Resuspend the cells in the lysis buffer and transfer the suspension to a microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge at 13,000 x g for 20 min at 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Carefully transfer the supernatant containing the soluble protein to a new tube and keep on the ice. Discard the pellet. Note: The protein solution can be kept in the freezer for longer storage periods until further use.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Agitate for 20 minutes at 4ºC.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
