  "citation": "dx.doi.org/10.17504/protocols.io.ewov141xpvr2/v1",
  "category": "Genomics & Sequencing",
  "estimated_time_mins": 144,
  "materials": [
    "E.Z.N.A. Blood Mini Kit",
    "microcentrifuge tubes",
    "HiBind DNA Mini Column",
    "2 mL Collection Tube",
    "100% Ethanol",
    "DNA Wash Buffer",
    "nuclease-free microcentrifuge tubes",
    "Proteinase K Solution",
    "BL Buffer",
    "HBC Buffer",
    "isopropanol",
    "centrifuge",
    "vortex mixer",
    "water bath",
    "pipettes"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Transfer the Sample into a sterile microcentrifuge tube and bring the volume up to 250 µL with 10mMTris-HCl, PBS, or Elution Buffer (provided).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 260 µL 100% Ethanol Contributed by users . Vortex at maximum speed for 00:00:20 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Insert a HiBind DNA Mini Column (provided) into a 2 mL Collection Tube. Green HiBind columns to be placed in clear collection tubes. Can label samples on cap.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 700 µL DNA Wash Buffer (provided). DNA Wash Buffer must be diluted with 100% ethanol before use.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Centrifuge the empty HiBind DNA Mini Column at 13000 x g, 21 °C, 2 minutes . It is important to dry the column membrane before elution. Residual ethanol may interfere with downstream applications.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer the HiBind DNA Mini Column into a nuclease-free 2 mL microcentrifuge tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 25 µL Proteinase K Solution (provided), 250 µL BL Buffer (provided), and 5 µL RNase I - 25,000 units New England Biolabs Catalog #M0243L (50 mg/mL).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Vortex at maximum speed for 00:00:15 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate at 65 °C for 00:10:00 minutes. Vortex briefly once during incubation. Heating block set to 65 degrees Celsius.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge briefly to collect any drops from the inside of the lid.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Transfer the entire sample to the column.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Centrifuge at 11000 x g, 21 °C, 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add 500 µL HBC Buffer. HBC Buffer must be diluted with 100% isopropanol before use.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Discard the filtrate and the Collection Tube. Insert the HiBind DNA Mini Column into a new 2 mL Collection Tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Centrifuge at 11000 x g, 21 °C, 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Discard the filtrate and reuse Collection Tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Centrifuge at 10000 x g, 21 °C, 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Discard the filtrate and reuse the Collection Tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "go to step #14",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Add 50 µL Elution Buffer heated to 65 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Incubate the HiBind DNA Mini Column at 65 °C for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Centrifuge at 13000 x g, 21 °C, 2 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Optional: Apply filtrate to column and repeat centrifugation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Store eluted DNA at -20 °C . Samples extracted using this protocol were submitted to NCBI BioSample and linked to BioProject PRJNA737185 . Nanodrop One results for samples: Sample A260 A280 A260/A230 A260/A280 ng/uL 1 1 0.185 0.096 0.359 1.934 9.26 2 2 0.125 0.059 0.732 2.131 6.26 3 3 0.159 0.102 0.528 1.558 7.94 4 4 0.082 0.047 0.405 1.723 4.08 5 5 0.107 0.058 0.815 1.838 5.33 6 6 0.110 0.063 1.020 1.742 5.51 7 7 0.143 0.070 0.518 2.033 7.14 8 8 0.077 0.029 1.443 2.615 3.83 9 9 0.060 0.039 1.156 1.534 2.99 10 10 0.059 0.032 0.398 1.844 2.95 11 11 0.082 0.044 1.039 1.855 4.10 12 12 0.119 0.073 1.025 1.637 5.96 13 13 0.072 0.032 0.938 2.237 3.60 14 14 0.098 0.051 1.051 1.918 4.88 15 15 0.092 0.049 1.475 1.869 4.59 The extractions yielded pure DNA (A260/A280 approximately 1.6 to 1.8) with sufficiently high concentrations of around 4 ng/uL.",
