  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Melt X% times 42 mg of agarose in 42 ml of 1X TAE buffer in microwave oven until the liquid is fully transparent.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 3.5 to 4 μl Midori green gel stain in the melted agarose.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Pour the melted agarose in the gel cast with the comb set.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Wait 30 minutes until the gel solidifies (faster in the 4°C fridge).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Cover the gel with 1X TAE buffer and remove the combs carefully.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Load the samples in the wells: 5 μl of 1 kb DNA ladder Mix 5 μl of DNA with 1 μl of 6X times loading buffer",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Run the gel at 100 volts for 30 minutes or 110 volts without letting the bands run out of the gel.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Remove the gel from the chamber.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Visualize the DNA fragments using a UV transilluminator.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
