  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Make a sample by adding 25% glycerol to cells Samples can be stored at -20ºC for 30 days. Glycerol growcells.com Catalog #MRGE-4002",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add DAPI at 50 µg/mL in dH 2 O",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add PI at 500 µg/mL in dH 2 O",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Filter sterilize with 0.2 µm Millipore filter and store in the dark at 4ºC",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Dilute cells appropriately according to your sample",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add DAPI at a final concentration of 5 µg/mL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add PI at a final concentration of 3 µg/mL",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Incubate in the dark for 30 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Filter sample onto a 0.2 µm black polycarbonate filter under low vacuum (&lt;15 mmHg)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Mount the filter onto a glass slide with low fluorescence immersion oil",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "View the sample under the Leica DM4000-6000 epifluorescent microscope under the Texas Red N3 filter at green excitiation = 546 nm and emission = 600 nm",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
