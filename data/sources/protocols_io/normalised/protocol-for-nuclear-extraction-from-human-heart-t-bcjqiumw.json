  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Put on dry ice: flat bottom mortar and pestle, hammer and foreceps sample-flash frozen heart tissue scale plate",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Pulverize tissue in mortar using pestle and hammer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transfer pulversized tissue in 6 cm dish containing 4 mL, cell lysis buffer On ice .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Assemble scale and cover plate with weighing paper.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Weigh 300 mg tissue.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Transfer tissue immediately into mortar and cover with pestle.",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Hammer gently, scrape off tissue stuck to pistill.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Start timer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Hammer again 3-6 x.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Segregate particles and transfer into douncer A with transfer pipette.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Wash plate with 2 mL, cell lysis buffer and transfer into douncer A .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Dounce carefully 30x .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Filter through 100 µm mesh in 50 ml Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Wash douncer A with 2 mL, cell lysis buffer and filter as well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Keep 10 µL for QC #1.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Transfer into douncer B .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Dounce 20x .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Filter through 40 µm mesh in 50 ml Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Wash douncer B with 2 mL, cell lysis buffer and filter as well.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Transfer into 15 ml Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Take time: should take 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Spin 400 x g, 4 °C, 7 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Aspirate supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "During testing, collect all 3 phases of Optiprep centrifugation, add same volume of nuclear buffer and spin to check for quality and quantity of seperation of nuclei and cell debris. Adjustments may be required. Resupend pellet in 600 µL, homogenization buffer (D) .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add 1 mL, Optiprep working solution and mix carefully (C) - 30 % iodixanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Keep 10 µL for QC #2.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Transfer into centrifugation tube (40ml).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Underlayer carefully nuclear sample with 8 mL 35 %, iodixanol using serological pipette.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Underlayer carefully both layers with 4 mL 40 %, iodixanol .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Centrifuge at 8.000 x g, 4 °C, 20 minutes ; no breaks.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Collect ring of nuclei at 35 % - 40 % iodixanol interface.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Add same volume of nuclear buffer .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Spin at 500 x g, 4 °C, 10 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Aspirate carefully and resuspend in nuclear buffer .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Stain 5 µL of sample as well as all fractions of QC with DAPI .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Check nuclei for complete lysis, nuclei morphology, purity and count.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Resuspend nuclei in 100 µL, nucelar buffer .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "Add drop wise 400 µL 100 % ( -20 °C ) methanol to suspension and transfer into -80 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
