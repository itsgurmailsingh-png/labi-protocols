{
  "protocol_id": "tca_protein_extraction_from_diatoms",
  "parent_protocol_id": null,
  "title": "TCA Protein Extraction from Diatoms",
  "author": "Anna Santin",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.bc7rizm6",
  "source_name": "protocols_io",
  "source_id": "33745",
  "source_url": "https://www.protocols.io/view/tca-protein-extraction-from-diatoms-bc7rizm6",
  "doi": "dx.doi.org/10.17504/protocols.io.bc7rizm6",
  "citation": "dx.doi.org/10.17504/protocols.io.bc7rizm6",
  "category": "Protein Science",
  "estimated_time_mins": 90,
  "materials": [
    "TCA 20%",
    "TCA 5%",
    "Glass-Beads",
    "3X SDS Laemmli Buffer",
    "Tris Base",
    "Eppendorf tubes",
    "Centrifuge",
    "Vortex mixer",
    "Ice",
    "Water bath"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Pellet of around 50 ml of culture in exponential phase (2 million of cells)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Wash pellet with 1 ml of TCA 20%",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at maximum speed for 1 minute",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Pour off the supernatant and dilute in 100 µl of TCA 20%",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add Glass-Beads till meniscus and vortex for 7 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 400 µl of TCA 5% and transfer the supernatant in new eppendorf (1.5 ml)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge at 3000 rpm for 10 minutes (chiarification phase)",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "(now quickly!) Add 100 µl of 3X SDS Laemmli Buffer (see Materials) and vortex very well to dissolve",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 50 µl Tris Base and vortex very well to dissolve",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Boil at 100°C for 3 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Centrifuge at maximum speed for 5 minutes",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer supernatant containing proteins in a new eppendorf",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Put tubes on ice",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Stock at -20°C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Pour off supernatant by aspiration",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
