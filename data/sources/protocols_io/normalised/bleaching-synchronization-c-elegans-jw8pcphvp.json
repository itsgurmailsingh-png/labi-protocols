  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Lavar con M9 (Importante utilizar M9 frío) y recuperar gusanos y embriones de la/s cajas Petri para colocarlos en tubo de 15ml para centrifugar",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Centrifugar a 3000 rpm por 1 minuto.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Descartar sobrenadante sin mover el pellet de gusanos y embriones.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Repetir el lavado nuevamente por 2 ocasiones más.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Descartar el sobrenadante del último lavado y colocar 6 ml de solución de bleaching_.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Agitar moderadamente por inversión por 4 minutos, importante revisar constantemente la disolución de los cuerpos de los gusanos adultos y no pasarse de los 4 minutos.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Colocar excedente de M9 para detener el bleaching (aforar hasta los 15 ml).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Centrifugar a 3000 rpm por 1 minuto con 15 ml de M9.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Descartar sobrenadante sin mover el pellet de embriones.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Repetir el lavado con M9 nuevamente por 5 ocasiones más.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Resuspender en 1ml de M9.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Tomar 10 ul de la suspensión y colocarla en un portaobjeto para contabilizar la cantidad de embriones, realizarlo por triplicado.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Dejar el tubo de costado a 20º C y agitación rotatoria a 120 rpm.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Al día siguiente contabilizar nuevamente la cantidad de gusanos en L1 presentes en la solución.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
