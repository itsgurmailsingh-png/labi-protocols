  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Measure 950 mL dH 2 O into a 1 L glass bottle.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 10 mL primary stock solution of biotin (vit. H) (0.1 g/L in dH 2 O) into the bottle.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 1 mL primary stock solution of cyanocobalamin (vit. B12) (1.0 g/L in dH 2 O) into the bottle.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Bring the final volume to 1 L with dH 2 O.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Filter sterilize final vitamin solution through a 0.2 micron PES membrane.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Dissolve 200 mg thiamine·HCl (vit. B1) into the bottle.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Store frozen in 0.5 mL aliquots.",
      "is_critical": false,
