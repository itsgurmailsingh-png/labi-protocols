  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Wash monolayer with Phosphate-buffered saline (PBSx1) for 3 times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add enough trypsin to cover monolayer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate at 28ºC for 3 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add enough fetal bovine serum (FBS) to cover the monolayer in order to inhibit trypsinization process.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Remove excess of FBS.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Dislodge cells from plastic substrate by slapping the side of the flask with the heel of your hand a few times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Aliquot cells in microcentrifuge tubes containing 500 µl of glutaraldehyde 1% diluted in sodium cacodylate buffer 0,2M.",
