  "category": "Biochemistry & In Vitro",
  "estimated_time_mins": 168,
  "materials": [
    "saliva",
    "Milli-Q water",
    "15 mL Falcon tube",
    "20% TCA solution",
    "cold 90% acetone"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Collect a minimum of 5 mL of saliva into a 15 mL Falcon tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add an equal volume of Milli-Q water to the saliva sample (1:1 v/v ratio).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Vortex the mixture for 30 seconds to ensure homogeneity.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge at 3500 rpm for 25 minutes at 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Carefully collect the supernatant and aliquot into four 1000 µL portions.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Store the aliquots at -40°C until further analysis.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "To each 1000 µL saliva aliquot, add 1000 µL of 20% TCA solution.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Vortex the mixture for 30 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Incubate the samples at -20°C for 30 minutes to facilitate protein precipitation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge at 5000 rpm for 30 minutes at 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Discard the supernatant carefully without disturbing the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Add 200 µL of cold 90% acetone to the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Vortex for 30 seconds to wash the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Incubate at -20°C for 20 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Centrifuge at 8000 rpm for 5 minutes at 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Discard the supernatant.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Add 200 µL of cold 80% acetone to the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Vortex for 30 seconds.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Incubate at -20°C for 10 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Centrifuge at 8000 rpm for 10 minutes at 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Carefully discard the supernatant completely.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Allow the pellet to air-dry for 5 minutes to remove residual acetone.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Resuspend the dried protein pellet in 10 µL of 0.2 M NaOH.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Incubate the solution for 2 minutes at room temperature to solubilize the proteins.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add 50 µL of 2D buffer (Urea 7 M, Thiourea 2 M, CHAPS 4%) to the solution.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Vortex the mixture for 30 seconds to ensure complete dissolution.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Collect the supernatant for protein quantification.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Determine the protein concentration using the Bradford assay according to the manufacturer&#39;s instructions.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
