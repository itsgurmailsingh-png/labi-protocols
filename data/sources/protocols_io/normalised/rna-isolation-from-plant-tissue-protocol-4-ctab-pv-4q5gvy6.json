{
  "protocol_id": "rna_isolation_from_plant_tissue_using_ctab_pvp_trizol_method",
  "parent_protocol_id": null,
  "title": "RNA Isolation from Plant Tissue Using CTAB-PVP-TRIzol Method",
  "author": "Unknown",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.4q5gvy6",
  "source_name": "protocols_io",
