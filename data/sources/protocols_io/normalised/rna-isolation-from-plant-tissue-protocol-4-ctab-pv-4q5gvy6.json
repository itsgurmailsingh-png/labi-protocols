  "source_url": "https://www.protocols.io/view/rna-isolation-from-plant-tissue-protocol-4-ctab-pv-4q5gvy6",
  "doi": "dx.doi.org/10.17504/protocols.io.4q5gvy6",
  "citation": "dx.doi.org/10.17504/protocols.io.4q5gvy6",
  "category": "Molecular Biology",
  "estimated_time_mins": 234,
  "materials": [
    "liquid nitrogen",
    "extraction buffer",
    "centrifuge",
    "chloroform",
    "isoamyl alcohol",
    "ethanol",
    "RNase free tubes",
    "vortex mixer"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Grind tissue to a powder in liquid nitrogen.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 200 mg – 500 mg of ground tissue to 3.0 mL of pre-heated extraction buffer in a 5 ml tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Vortex the tube until the tissue is mixed with the buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate the tube at 65 °C for 00:30:00 , vortexing briefly ( 00:00:15 ) every 2–3 min during the incubation.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Aliquot the mixture into four 2 ml RNase free tubes, 1 mL in each tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Spin the tube at for 00:10:00 in a centrifuge. All of the insoluble matter should form a pellet at the bottom of the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Pour the supernatant into a new 2 ml tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add an equal volume of 24:1 chloroform:isoamyl alcohol to fill the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Vortex tubes until the phases mix and appear cloudy.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Spin the tubes at for 00:10:00 in a centrifuge.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Transfer the upper aqueous phase to new 2 ml RNase free tubes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer the upper, aqueous phase to new 2 ml RNase free tubes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Spin tubes at for 00:20:00 in a centrifuge and decant the supernatant, taking care not to lose the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add 1 mL 75 % cooled ethanol to the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Spin the tube at maximum speed for 00:05:00 in a centrifuge.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Open cap and air-dry the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Add 30 µL RNase free water to dissolve the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Centrifuge at &gt; for 00:10:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Transfer the upper, aqueous phase to a new 2 ml RNase free tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Spin tubes at &gt; for 00:20:00 at 4 °C in a centrifuge.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Decant the supernatant taking care not to lose the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Centrifuge at 4 °C for 00:05:00 at &gt; .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Repeat steps 21 and 22 one more time. go to step #21",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Open cap and air dry the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add 10 µL – 30 µL RNase free water to dissolve the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Decant the supernatant carefully.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Repeat steps 14 and 15 one more time. go to step #14",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Incubate at 20 °C for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Repeat steps 8 to 10 one more time. go to step #8",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Add 1/3 volume of 10 Molarity (M) LiCl to each tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Mix and let stand at 4 °C for 06:00:00 – 08:00:00 or overnight to precipitate RNA.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Then add 300 µL TRIzol reagent and equal volume of chloroform to TRIzol reagent (Invitrogen).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Vortex vigorously and store at 20 °C for 00:05:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Add 2 volumes of cooled 100% ethanol, 1/10 volume of NaAc and 2 µL of glycogen.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Mix and incubate at -20 °C for 02:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Add 1 mL 75 % ethanol to the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Let tube stand at 20 °C for 00:03:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "Decant the liquid carefully, taking care not to lose the pellet.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 38,
      "title": "",
      "instruction": "Briefly centrifuge to collect the residual liquid and remove it with a pipette.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
