{
  "protocol_id": "high_molecular_weight_hmw_dna_extraction_protocol_for_tissue_sample",
  "parent_protocol_id": null,
  "title": "High Molecular Weight (HMW) DNA Extraction Protocol for Tissue Sample",
  "author": "Aswini Leela Loganathan",
  "license": "CC-BY 4.0",
  "license_verified": true,
  "license_note": "Confirmed via CrossRef DOI metadata: dx.doi.org/10.17504/protocols.io.kqdg3xdrpg25/v1",
  "source_name": "protocols_io",
  "source_id": "93868",
  "source_url": "https://www.protocols.io/view/high-molecular-weight-hmw-dna-extraction-protocol-c7wkzpcw",
  "doi": "dx.doi.org/10.17504/protocols.io.kqdg3xdrpg25/v1",
  "citation": "dx.doi.org/10.17504/protocols.io.kqdg3xdrpg25/v1",
  "category": "Molecular Biology",
  "estimated_time_mins": 108,
  "materials": [
    "lysis buffer",
    "Proteinase K",
    "RNAse",
    "P:C:IA",
    "Sodium Ac",
    "100% Ethanol",
    "70% ethanol"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Lysis the tissue sample. Add 500 µL of lysis buffer to 50 - 150 mg of Sample of sample. Make sure the tissue sample has been finely cut.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Denatures and digest proteins that are subsequently hydrolyzed with Proteinase K. Add 10 µL of Proteinase K and vortex for 00:00:10 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate on a shaking incubator at 55 °C for 02:00:00 ( or till dissolved).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Remove RNA with RNAse . Add 5 µL of RNAse and vortex briefly.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate in a shaking incubator for at 37 °C .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Partitioning of lipids and debris into an organic phase using P:C:IA. Add 500 µL of P:C:IA (25:24:1). Vortex until an emulsion is formed.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge at Room temperature for 00:10:00 at 10000 x g, °C, .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Pipette 200 µL of the aqueous layer into a new tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Neutralize the charges on the sugar-phosphate backbone of the DNA with Sodium Acetate. Add 1/10th : 20 µL 3M Sodium Acetate. Vortex gently (avoid creating bubbles).",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Precipitation Step. Add 2 Vol : 440 µL of ice-cold 100% Ethanol. Mix gently and slowly by inverting the tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Incubate at -20 °C for 02:00:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Centrifuge at 10000 x g, Room temperature, 2 minutes .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Wash Step. Wash with ice-cold 70% ethanol.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Centrifuge for 00:02:00 at 10000 x g, °C, .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Repeat Wash Step (Step 13 and 14) 2 more times.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Air dry for at least 00:30:00 .",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Final elution. Add 35 µL of elution buffer (EB) and mix gently using a wide bore tips or by tapping.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Storage. Store the gDNA at 4 °C",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
  "verification_status": "verified",
