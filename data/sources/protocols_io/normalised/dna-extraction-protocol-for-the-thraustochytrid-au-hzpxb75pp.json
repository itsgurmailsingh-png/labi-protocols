  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Colonies should be grown on an agar-media plate for 4 days, and no older than 2 months.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 20 µL of DNA Extraction Buffer to a PCR tube.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Scrape some colony using a plastic pipette tip.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Resuspend the colony in the 20 µL DNA Extraction Buffer.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Heat at 95°C for 10 minutes.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Immediately remove PCR tube from thermocycler, and allow to cool to room temperature on the benchtop. [Room temperature cooling is important for several reasons. It allows for re-annealing of DNA to the more stable dsDNA form, as well as the precipitation of cellular debris.]",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Allow 15-30 minutes for cooling.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Once cooled to room temperature, add 80 µL of sterile nuclease-free deionized water, and mix by gently pipetting up and down.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge cellular debris.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Sample is now ready for use. 1-2 µL should be sufficient for a 50 µL PCR reaction. If not using, freeze at -20°C. For temporary storage, keep on ice, or in ice water, or at 4°C.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "%s %s Note: Filter sterilize.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
