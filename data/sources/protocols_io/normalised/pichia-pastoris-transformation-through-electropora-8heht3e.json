  "doi": "dx.doi.org/10.17504/protocols.io.8heht3e",
  "citation": "dx.doi.org/10.17504/protocols.io.8heht3e",
  "category": "Microbiology",
  "estimated_time_mins": 60,
  "materials": [
    "plasmid DNA",
    "electrocompetent Pichia cells",
    "0.2 cm electroporation cuvette",
    "BioRad MicroPulser",
    "1 M sorbitol",
    "YPD media",
    "plastic culture tube",
    "YPDS plates",
    "antibiotic"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Prior to transformation plasmid DNA containing the gene(s) of interest was linearized in restriction digests using an enzyme that only cuts once following the manufacturers manual !",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Mix approx. 150 ng of linearized vector DNA with electrocompetent Pichia cells",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Tranfer mixture to ice-cold 0.2 cm electroporation cuvette",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate cuvette for 2 min",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Electroporate using a BioRad MicroPulser with a charging voltage of 1.5 kV",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Immediately add 1 mL of 1:1 1 M sorbitol and YPD (v/v) to recover the cells",
      "is_critical": true,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Transfer mixture to a plastic culture tube and incubated at 30°C for 1 hour at 225 rpm.",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Centrifuge culture tube at 3.000 x g for 5 min to pellet the cells",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Resuspend pellet in 200 μL YPD media",
      "is_critical": false,
      "timers": [],
      "substeps": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Plate out cells on YPDS plates containing desired antibiotic and incubated at 30°C for 3 days",
      "is_critical": false,
      "timers": [],
      "substeps": []
    }
  ],
