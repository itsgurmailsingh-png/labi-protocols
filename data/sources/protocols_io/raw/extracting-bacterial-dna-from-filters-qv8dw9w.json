  "peer_reviewed": false,
  "steps_raw": [
    {
      "title": "",
      "instruction": "Add 1mL lysis buffer to each filter in a 5mL snap cap tubea. Lysis buffer: i. 40mM EDTA ii. 50mM Tris iii. 0.75M sucrose"
    },
    {
      "title": "",
      "instruction": "Incubate 45min at 37°C, shaking gently"
    },
    {
      "title": "",
      "instruction": "Add SDS to 1% v/v (in this case, 100ul of 10% SDS solution was added to each sample)"
    },
    {
      "title": "",
      "instruction": "Incubate 1hr at 55°C, shaking gently"
    },
    {
      "title": "",
      "instruction": "Collect liquid lysate into a 2mL tube"
    },
    {
      "title": "",
      "instruction": "Add 1mL phenol:chloroform:isoamyl alcohol and mix well"
    },
    {
      "title": "",
      "instruction": "Centrifuge 5min at 8000g"
    },
    {
      "title": "",
      "instruction": "Transfer aqueous phase to new 2mL tube"
    },
    {
      "title": "",
      "instruction": "Repeat steps 6-8"
    },
    {
      "title": "",
      "instruction": "Add 1mL chloroform and mix well"
    },
    {
      "title": "",
      "instruction": "Centrifuge 5min at 8000g"
    },
    {
      "title": "",
      "instruction": "Transfer aqueous phase to upper reservoir of a 4mL 100kDa Amicon concentrator"
    },
    {
      "title": "",
      "instruction": "Centrifuge at 1000g until &lt;200ul remains"
    },
    {
      "title": "",
      "instruction": "Add 2mL sterile water to upper reservoir"
    },
    {
      "title": "",
      "instruction": "Vortex for 20sec at 1500rpm"
    },
    {
      "title": "",
      "instruction": "Centrifuge at 1000g until &lt;200ul remains"
    },
    {
      "title": "",
      "instruction": "Repeat steps 14-16"
    },
    {
      "title": "",
      "instruction": "Collect sample from upper reservoir and transfer to 1.5mL tube"
    },
    {
      "title": "",
      "instruction": "Check concentration with Qubit HS DNA assay"
    }
  ]
}