  "title": "Extracting Bacterial DNA from filters",
  "author": "Natalie Solonenko",
  "doi": "dx.doi.org/10.17504/protocols.io.qv8dw9w",
  "source_url": "https://www.protocols.io/view/extracting-bacterial-dna-from-filters-qv8dw9w",
