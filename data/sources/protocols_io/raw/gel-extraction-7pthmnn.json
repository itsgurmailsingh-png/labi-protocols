  "steps_raw": [
    {
      "title": "",
      "instruction": "Add 450 µL Buffer QG into 2ml tube containing gel slice Buffer QG Contributed by users"
    },
    {
      "title": "",
      "instruction": "Incubate at 50 °C for 00:10:00"
    },
    {
      "title": "",
      "instruction": "Add 150 µL isopropanol to the sample and mix Isopropanol Contributed by users"
    },
    {
      "title": "",
      "instruction": "Transfer entire volume into QIAquick spin column"
    },
    {
      "title": "",
      "instruction": "Centrifuge at 13000 rpm for 00:01:00"
    },
    {
      "title": "",
      "instruction": "Discard flow through"
    },
    {
      "title": "",
      "instruction": "Add 750 µL Buffer PE to QIAquick spin column Buffer PE Contributed by users"
    },
    {
      "title": "",
      "instruction": "Centrifuge at 13000 rpm for 00:01:00"
    },
    {
      "title": "",
      "instruction": "Discard flow through"
    },
    {
      "title": "",
      "instruction": "Repeat steps 7 - 9"
    },
    {
      "title": "",
      "instruction": "Place spin column onto a new eppendorf tube"
    },
    {
      "title": "",
      "instruction": "Elute DNA by adding 30 µL Buffer EB to the center of QIAquick membrane Buffer EB Qiagen Catalog #19086"
    },
    {
      "title": "",
      "instruction": "Incubate at Room temperature for 00:04:00"
    },
    {
      "title": "",
      "instruction": "Centrifuge at 13000 rpm for 00:01:00"
    },
    {
      "title": "",
      "instruction": "Collect eluted DNA"
    }
