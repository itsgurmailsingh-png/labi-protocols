      "title": "",
      "instruction": "1. Add 1 µL of 70 ng Template DNA. °C"
    },
    {
      "title": "",
      "instruction": "2. Add three fold excess of PCR-Fragment. °C"
    },
    {
      "title": "",
      "instruction": "3. Add 0.5 µL Esp3I. °C"
    },
    {
      "title": "",
      "instruction": "4. Add 0.5 µL T7-Ligase. °C"
    },
    {
      "title": "",
      "instruction": "5. Add 1 µL T4-Ligase Buffer. °C"
    },
    {
      "title": "",
      "instruction": "6. Fill with Nuclease-free water to 10 µL. °C"
    },
    {
      "title": "",
      "instruction": "Thermocycling conditions:"
    },
    {
