  "steps_raw": [
    {
      "title": "",
      "instruction": "Seed cells into a 10 cm dish at a density appropriate to achieve 70–80% confluence by the following day. Allow the cells to attach and grow for approximately 24:00:00 ."
    },
    {
      "title": "",
      "instruction": "Collect medium."
    },
    {
      "title": "",
      "instruction": "Wash cells with DPBS."
    },
    {
      "title": "",
      "instruction": "Incubate cells with TrypLE, 37 °C ."
    },
    {
      "title": "",
      "instruction": "Collect cells."
    },
    {
      "title": "",
      "instruction": "Centrifuge for 00:05:00 at 400 x g, 4 °C, ."
    },
    {
      "title": "",
      "instruction": "Decant supernatant."
    },
    {
      "title": "",
      "instruction": "Wash pellet with DPBS."
    },
    {
      "title": "",
      "instruction": "Centrifuge for 00:05:00 at 400 x g, 4 °C, ."
    },
    {
      "title": "",
      "instruction": "Decant supernatant."
    },
    {
      "title": "",
      "instruction": "Add RIPA lysis buffer (supplemented with protease inhibitors)."
    },
    {
      "title": "",
      "instruction": "Incubate for at least 00:30:00 On ice , or alternatively store at -20°C until further processing."
    },
    {
      "title": "",
      "instruction": "Centrifuge 15000 x g, 4 °C, 30 minutes to pellet DNA and non-solubilized material."
    },
    {
      "title": "",
      "instruction": "Keep supernatant."
    },
    {
      "title": "",
      "instruction": "Determine protein concentration via BCA assay."
    }
