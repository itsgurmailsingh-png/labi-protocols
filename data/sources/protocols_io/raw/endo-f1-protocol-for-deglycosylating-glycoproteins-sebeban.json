  "steps_raw": [
    {
      "title": "",
      "instruction": "Add up to 200 μg of glycoprotein to an Eppendorf tube. Adjust to 38 μl final volume with de-ionized water."
    },
    {
      "title": "",
      "instruction": "Add 10 μl 5x Reaction Buffer 5.5"
    },
    {
      "title": "",
      "instruction": "Add 2.0 μl of Endo F1 to the reaction"
    },
    {
      "title": "",
      "instruction": "Incubate 3 hours at 37°C."
    },
    {
      "title": "",
      "instruction": "Monitor cleavage by SDS-PAGE."
    }
  ]
}