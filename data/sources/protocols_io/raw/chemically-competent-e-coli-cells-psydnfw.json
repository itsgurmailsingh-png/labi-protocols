  "steps_raw": [
    {
      "title": "",
      "instruction": "Grow 50ml over night culture in TYM medium"
    },
    {
      "title": "",
      "instruction": "Tansfer 10ml cells to 500ml TYM medium"
    },
    {
      "title": "",
      "instruction": "Incubate: OD=0.55, 37°C, 200rpm"
    },
    {
      "title": "",
      "instruction": "Cool cells on ice"
    },
    {
      "title": "",
      "instruction": "Centrifuge: 3500g, 15min., 4°C"
    },
    {
      "title": "",
      "instruction": "Remove supernatant completely"
    },
    {
      "title": "",
      "instruction": "Resuspend pellets in 100ml ice cold TfB1 buffer"
    },
    {
      "title": "",
      "instruction": "Centrifuge: 3500g, 15min., 4°C"
    },
    {
      "title": "",
      "instruction": "Resuspend pellets in 30ml ice cold TfB2 buffer"
    },
    {
      "title": "",
      "instruction": "Aliquot the cells into chilled tubes (50µl aliquots)"
    },
    {
      "title": "",
      "instruction": "Freeze the cells in liquid nitrogen"
    },
    {
      "title": "",
      "instruction": "Store at -80°C"
    }
  ]
}