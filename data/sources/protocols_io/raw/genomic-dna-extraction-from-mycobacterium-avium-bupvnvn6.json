  "steps_raw": [
    {
      "title": "",
      "instruction": "Suspend colonies on 7H11 agar into 300 µl of TE."
    },
    {
      "title": "",
      "instruction": "Centrifuge at 5,000 g for 10 min."
    },
    {
      "title": "",
      "instruction": "Discard supernatant, followed by suspension in 300 µl of acetone."
    },
    {
      "title": "",
      "instruction": "Centrifuge at 5,000 g for 10 min."
    },
    {
      "title": "",
      "instruction": "Discard acetone, followed by suspension in 200 µl of TE."
    },
    {
      "title": "",
      "instruction": "Add lysozyme at the final concentration of 100 µg/ml."
    },
    {
      "title": "",
      "instruction": "Incubate at 37°C overnight."
    },
    {
      "title": "",
      "instruction": "Add proteinase K at the final concentration of 0.2 mg/ml."
    },
    {
      "title": "",
      "instruction": "Incubate at 50°C for 3 hrs."
    },
    {
      "title": "",
      "instruction": "Add 1/10 volume of 3 M NaOAc."
    },
    {
      "title": "",
      "instruction": "Add equal volume of phenol/chloroform/isoamyl-alcohol and shake vigorously."
    },
    {
      "title": "",
      "instruction": "Centrifuge at 12,000 g for 10 min."
    },
    {
      "title": "",
      "instruction": "Transfer aquatus phase to a new tube."
    },
    {
      "title": "",
      "instruction": "Add equal volume of 2-propanol."
    },
    {
      "title": "",
      "instruction": "Centrifuge at 12,000 g for 10 min."
    },
    {
      "title": "",
      "instruction": "Remove supernatant and wash with 70% ethanol."
    },
    {
      "title": "",
      "instruction": "Suspended in 400 µl of TE, followed by adding RNase at the final concentration of 100 µg/ml."
    },
    {
      "title": "",
      "instruction": "Incubate at 37°C for 30 min."
    },
    {
      "title": "",
      "instruction": "Repeat steps 10 to 16."
    },
    {
      "title": "",
      "instruction": "Suspended in 100 µl of TE."
    }
  ]
}