  "title": "Skeletal muscle extraction from AllProtect Tissue Reagent",
  "author": "Elisabeth Heuston",
  "doi": "dx.doi.org/10.17504/protocols.io.j8nlk8dp1l5r/v1",
  "source_url": "https://www.protocols.io/view/skeletal-muscle-extraction-from-allprotect-tissue-df893rz6",
  "steps_raw": [
    {
      "title": "",
      "instruction": "Thaw tissue stored in AllProtect® Tissue Reagent on ice Sample"
    },
    {
      "title": "",
      "instruction": "Serially dilute and exchange AllProtect® Tissue Reagent with PBS until all storage reagent has been removed"
    },
    {
      "title": "",
      "instruction": "Resuspend in 0.5 mL pBSA"
    },
    {
      "title": "",
      "instruction": "Pulverize tissue to single cell suspension with single-use microtube homogenizer"
    },
    {
      "title": "",
      "instruction": "Filter through 70 µm strainer into fresh 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Rinse strainer with 0.5 mL pBSA"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300xg, 4C"
    },
    {
      "title": "",
      "instruction": "Remove supernatant and resuspend in 0.5 mL pBSA"
    },
    {
      "title": "",
      "instruction": "Filter through 40 µm strainer into fresh 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Rinse strainer with 0.5 mL pBSA"
    },
    {
      "title": "",
      "instruction": "This preparation will subsequently be referred to as filtered cells"
    },
    {
      "title": "",
      "instruction": "Start with filtered cells"
    },
    {
      "title": "",
      "instruction": "Remove ~60,000 cells to fresh 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend 60,000 cells in 30 µL pBSA"
    },
    {
      "title": "",
      "instruction": "Proceed to Chromium Single Cell 5’ Library &amp; Gel Bead Kit v2 sample capture"
    },
    {
      "title": "",
      "instruction": "Start with filtered cells"
    },
    {
      "title": "",
      "instruction": "Remove 250,000 cells to fresh 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend in 100 µL Nuclei Extraction Buffer"
    },
    {
      "title": "",
      "instruction": "Incubate on ice, 5 min"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend in 30 µL Nuclei Buffer"
    },
    {
      "title": "",
      "instruction": "Proceed to Chromium Single Cell 5’ Library &amp; Gel Bead Kit v2 sample capture"
    },
    {
      "title": "",
      "instruction": "Start with filtered cells"
    },
    {
      "title": "",
      "instruction": "Remove 50,000 cells as an unstained cell control (bring minimum volume to 100 µL)"
    },
    {
      "title": "",
      "instruction": "Stain 500,000 cells with a final concentration of 25 µg/mL NPC-AF594"
    },
    {
      "title": "",
      "instruction": "Incubate on ice, 30 min"
    },
    {
      "title": "",
      "instruction": "Bring all volumes to 1 mL"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend in 300 µL pBSA"
    },
    {
      "title": "",
      "instruction": "Sort NPC-AF594+ cells on a Becton Dickinson FACS Aria Fusion using 70 µm nozzle into a collection tube on ice"
    },
    {
      "title": "",
      "instruction": "This preparation will subsequently be referred to as sorted cells"
    },
    {
      "title": "",
      "instruction": "Start with sorted cells"
    },
    {
      "title": "",
      "instruction": "Remove ~100,000 cells to fresh 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend 60,000 cells in 30 µL pBSA"
    },
    {
      "title": "",
      "instruction": "Proceed to Chromium Single Cell 5’ Library &amp; Gel Bead Kit v2 sample capture"
    },
    {
      "title": "",
      "instruction": "Start with sorted cells"
    },
    {
      "title": "",
      "instruction": "Remove 250,000 cells to fresh 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend in 100 µL Nuclei Extraction Buffer"
    },
    {
      "title": "",
      "instruction": "Incubate on ice, 5 min"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend in 30 µL Nuclei Buffer"
    },
    {
      "title": "",
      "instruction": "Proceed to Chromium Single Cell 5’ Library &amp; Gel Bead Kit v2 sample capture"
    },
    {
      "title": "",
      "instruction": "Start with up to 50,000 sorted cells (sorted cell capture preparation) or 50,000 sorted nuclei (sorted nuclei capture preparation) in 100 µL pBSA"
    },
    {
      "title": "",
      "instruction": "Stain with a final concentration of 100 µg/mL NPC-AF594 + 50 µg/mL DAPI"
    },
    {
      "title": "",
      "instruction": "Incubate on ice, 20 min"
    },
    {
      "title": "",
      "instruction": "Centrifuge for 5 min at 300 xg, 4C"
    },
    {
      "title": "",
      "instruction": "Resuspend in 300 µL pBSA"
    },
    {
      "title": "",
      "instruction": "Transfer suspension to a 35 mm 1.5 coverslip dish"
    },
    {
      "title": "",
      "instruction": "Imaging was performed on an LSM 880 Airyscan Confocal microscope (Zeiss) with a 63x/1.4 oil objective and captured with Zen_2.3 software (Zeiss)."
    }
  ],
