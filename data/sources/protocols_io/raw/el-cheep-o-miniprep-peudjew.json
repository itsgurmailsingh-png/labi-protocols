  "steps_raw": [
    {
      "title": "",
      "instruction": "·Spin 3ml of the overnight culture to pellet cells (1.5-ml for time) @13000 rpm for 5 min"
    },
    {
      "title": "",
      "instruction": "·Remove the supernatant"
    },
    {
      "title": "",
      "instruction": "·Add 250 ml of sol P1+Rnase 5ml and vortex to resuspend cells"
    },
    {
      "title": "",
      "instruction": "·Take 15 min @ room temperature"
    },
    {
      "title": "",
      "instruction": "·Add 250 ml of sol P2 and mix gently"
    },
    {
      "title": "",
      "instruction": "·Take 5 min @ room temperature"
    },
    {
      "title": "",
      "instruction": "·Add 350 ml of sol P3 and mix gently"
    },
    {
      "title": "",
      "instruction": "·Leave 10 min on ice"
    },
    {
      "title": "",
      "instruction": "·Spin @ the max speed for 10 min"
    },
    {
      "title": "",
      "instruction": "·Take 750 ml of the supernatant and put in a new eppendorf tube and add in this tube 750 ml of isopropanol"
    },
    {
      "title": "",
      "instruction": "·Mix well"
    },
    {
      "title": "",
      "instruction": "·Spin for 30 min @ 14000 rpm"
    },
    {
      "title": "",
      "instruction": "·Remove the supernatant"
    },
    {
      "title": "",
      "instruction": "·Spin again for other 10 min"
    },
    {
      "title": "",
      "instruction": "·Take @ 37°C for 10 min"
    },
    {
      "title": "",
      "instruction": "·Add 50 ml of H2O"
    },
    {
      "title": "",
      "instruction": "·Store @ -20°C"
    }
  ]
}