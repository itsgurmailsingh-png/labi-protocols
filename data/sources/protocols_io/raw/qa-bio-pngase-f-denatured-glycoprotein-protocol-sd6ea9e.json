  "title": "QA-Bio PNGase F Denatured Glycoprotein Protocol",
  "author": "Mike Gibson",
  "doi": "dx.doi.org/10.17504/protocols.io.sd6ea9e",
  "source_url": "https://www.protocols.io/view/qa-bio-pngase-f-denatured-glycoprotein-protocol-sd6ea9e",
  "steps_raw": [
    {
      "title": "",
      "instruction": "Add up to 200 µg of glycoprotein to an Eppendorf tube."
    },
    {
      "title": "",
      "instruction": "Adjust to 35 µl final volume with de-ionized water."
    },
    {
      "title": "",
      "instruction": "Add 10 µl 5x Reaction Buffer 7.5 and 2.5 µl of Denaturation Solution."
    },
    {
      "title": "",
      "instruction": "Heat at 100°C for 5 minutes."
    },
    {
      "title": "",
      "instruction": "Cool."
    },
    {
      "title": "",
      "instruction": "Add 2.5 µl of Triton X-100 and mix."
    },
    {
      "title": "",
      "instruction": "Add 2.0 µl of enzyme to the reaction."
    },
    {
      "title": "",
      "instruction": "Incubate 3 hours at 37°C."
    }
  ],
