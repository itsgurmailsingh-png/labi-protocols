  "title": "Immunocytochemistry, Confocal Imaging, and Quantitative Analysis of iNeurons",
  "author": "Felix Kraus",
  "doi": "dx.doi.org/10.17504/protocols.io.bp2l6jyj1vqe/v1",
  "source_url": "https://www.protocols.io/view/immunocytochemistry-confocal-imaging-and-quantitat-jv7ucn9nx",
  "steps_raw": [
    {
      "title": "",
      "instruction": "Pre-warm 4% paraformaldehyde (PFA) in PBS to 37 °C."
    },
    {
      "title": "",
      "instruction": "Prepare the following buffers:"
    },
    {
      "title": "",
      "instruction": "**PBST**: PBS + 0.02% Tween-20"
    },
    {
      "title": "",
      "instruction": "**Permeabilization buffer**: PBS + 0.5% Triton X-100"
    },
    {
      "title": "",
      "instruction": "**Blocking buffer**: 3% BSA in PBS"
    },
    {
      "title": "",
      "instruction": "Prepare primary and secondary antibody dilutions in 3% BSA-PBS**."
    },
    {
      "title": "",
      "instruction": "Ensure that the confocal microscope and lasers are properly calibrated."
    },
    {
      "title": "",
      "instruction": "Remove culture medium from differentiated iNeurons."
    },
    {
      "title": "",
      "instruction": "Add 4% PFA in PBS (pre-warmed to 37 °C)."
    },
    {
      "title": "",
      "instruction": "Incubate cells for 30 minutes at 37 °C."
    },
    {
      "title": "",
      "instruction": "Remove PFA and rinse cells once with PBS."
    },
    {
      "title": "",
      "instruction": "Incubate cells in 0.5% Triton X-100 in PBS for 15 minutes at room temperature."
    },
    {
      "title": "",
      "instruction": "Wash cells three times with PBST (0.02% Tween-20 in PBS)."
    },
    {
      "title": "",
      "instruction": "Incubate cells in 3% BSA in PBS for 10 minutes at room temperature."
    },
    {
      "title": "",
      "instruction": "Wash cells three times with PBST."
    },
    {
      "title": "",
      "instruction": "Dilute primary antibodies in 3% BSA-PBS."
    },
    {
      "title": "",
      "instruction": "Add antibody solution to cells."
    },
    {
      "title": "",
      "instruction": "Incubate for 3 hours at room temperature."
    },
    {
      "title": "",
      "instruction": "Wash cells three times with PBST."
    },
    {
      "title": "",
      "instruction": "Dilute secondary antibodies 1:400 in 3% BSA-PBS."
    },
    {
      "title": "",
      "instruction": "Incubate cells with secondary antibodies for 1 hour at room temperature."
    },
    {
      "title": "",
      "instruction": "Add Hoechst 33342 (1:10,000 in PBST)."
    },
    {
      "title": "",
      "instruction": "Incubate for 5 minutes."
    },
    {
      "title": "",
      "instruction": "Wash cells three times with PBST."
    },
    {
      "title": "",
      "instruction": "Cells are now ready for imaging."
    },
    {
      "title": "",
      "instruction": "Images are acquired at room temperature using a Yokogawa CSU-W1 spinning disk confocal system mounted on a Nikon Eclipse Ti2-E microscope."
    },
    {
      "title": "",
      "instruction": "Lasers are applied sequentially using a Nikon LUN-F XL laser combiner."
    },
    {
      "title": "",
      "instruction": "Camera: Hamamatsu ORCA-Fusion BT CMOS (16-bit acquisition)."
    },
    {
      "title": "",
      "instruction": "Laser excitation settings:"
    },
    {
      "title": "",
      "instruction": "405 nm: 80 mW"
    },
    {
      "title": "",
      "instruction": "488 nm: 80 mW"
    },
    {
      "title": "",
      "instruction": "561 nm: 65 mW"
    },
    {
      "title": "",
      "instruction": "640 nm: 60 mW"
    },
    {
      "title": "",
      "instruction": "Dichroic mirror: Semrock Di01-T405/488/568/647"
    },
    {
      "title": "",
      "instruction": "Emission filters:"
    },
    {
      "title": "",
      "instruction": "405 nm: Chroma ET455/50m"
    },
    {
      "title": "",
      "instruction": "488 nm: Chroma ET525/50m"
    },
    {
      "title": "",
      "instruction": "561 nm: Chroma ET605/52m"
    },
    {
      "title": "",
      "instruction": "640 nm: Chroma ET705/72m"
    },
    {
      "title": "",
      "instruction": "Software: NIS-Elements"
    },
    {
      "title": "",
      "instruction": "Time-lapse calcium imaging datasets are analyzed using a custom Python pipeline_."
    },
    {
      "title": "",
      "instruction": "ND2 stacks are read using the nd2 Python package_."
    },
    {
      "title": "",
      "instruction": "Maximum intensity projections are generated."
    },
    {
      "title": "",
      "instruction": "Segmentation is performed using CellposeSAM with a pretrained model optimized for neuronal soma."
    },
    {
      "title": "",
      "instruction": "Segmentation masks are filtered by area (100–10,000 pixels)."
    },
    {
      "title": "",
      "instruction": "For each valid region:"
    },
    {
      "title": "",
      "instruction": "Centroid coordinates are extracted."
    },
    {
      "title": "",
      "instruction": "Mean fluorescence intensity is calculated across all frames."
    },
    {
      "title": "",
      "instruction": "Output files include:"
    },
    {
      "title": "",
      "instruction": "16-bit TIFF segmentation masks"
    },
    {
      "title": "",
      "instruction": "Visualization overlays"
    },
    {
      "title": "",
      "instruction": "CSV files containing centroid coordinates and fluorescence traces"
    },
    {
      "title": "",
      "instruction": "Synaptic puncta from markers such as Synaptophysin (SYP) and Bassoon (BSN) are quantified using a custom Python pipeline_."
    },
    {
      "title": "",
      "instruction": "Maximum-intensity projection images are parsed for experimental metadata."
    },
    {
      "title": "",
      "instruction": "Cytoskeletal channels generate neuronal masks."
    },
    {
      "title": "",
      "instruction": "Background subtraction and segmentation detect synaptic puncta."
    },
    {
      "title": "",
      "instruction": "Object morphology and fluorescence intensity are measured."
    },
    {
      "title": "",
      "instruction": "Object-level colocalization analysis is performed between SYP and Bassoon puncta."
    },
    {
      "title": "",
      "instruction": "Output files include:"
    },
    {
      "title": "",
      "instruction": "Cleaned processed images"
    },
    {
      "title": "",
      "instruction": "QC overlays"
    },
    {
      "title": "",
      "instruction": "CSV files containing per-object and per-image measurements"
    },
    {
      "title": "",
      "instruction": "Downstream statistical analysis and visualization are performed in R_."
    },
    {
      "title": "",
      "instruction": "Successful staining should reveal:"
    },
    {
      "title": "",
      "instruction": "MAP2-positive neuronal morphology"
    },
    {
      "title": "",
      "instruction": "TH-positive dopaminergic neurons where applicable"
    },
    {
      "title": "",
      "instruction": "Synaptic puncta labeled by SYP and Bassoon"
    },
    {
      "title": "",
      "instruction": "Quantitative outputs include:"
    },
    {
      "title": "",
      "instruction": "Per-cell fluorescence measurements"
    },
    {
      "title": "",
      "instruction": "Synaptic puncta counts and intensities"
    },
    {
      "title": "",
      "instruction": "Colocalization metrics"
    },
    {
