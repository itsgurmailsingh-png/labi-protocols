  "title": "U Michigan - Massons Trichrome staining",
  "author": "Jeff Hodgin",
  "doi": "dx.doi.org/10.17504/protocols.io.56ug9ew",
  "source_url": "https://www.protocols.io/view/u-michigan-massons-trichrome-staining-56ug9ew",
  "steps_raw": [
    {
      "title": "",
      "instruction": "Wash 2x for 5 minutes in Xylene"
    },
    {
      "title": "",
      "instruction": "Wash 2x for 3 minutes in 100% EtOH"
    },
    {
      "title": "",
      "instruction": "Wash 1x for 2 minutes in 95% EtOH"
    },
    {
      "title": "",
      "instruction": "Wash 1x for 1 minutes in 70% EtOH"
    },
    {
      "title": "",
      "instruction": "Wash in running tap water for 3 minutes"
    },
    {
      "title": "",
      "instruction": "Place in Bouins for one hour in 55 -56 degree oven or overnight at room temperature if needed."
    },
    {
      "title": "",
      "instruction": "Wash well in running water for 5-10 minutes or until yellow is gone."
    },
    {
      "title": "",
      "instruction": "Stain in Weigerts Hematoxylin for 10-20 minutes (usually 10 minutes)."
    },
    {
      "title": "",
      "instruction": "Wash well in running water for 10 minutes."
    },
    {
      "title": "",
      "instruction": "Rinse distilled water."
    },
    {
      "title": "",
      "instruction": "Place slides in Biebrich Scarlet-Acid Fuchsin for 5-10 minutes."
    },
    {
      "title": "",
      "instruction": "Rinse in distilled water."
    },
    {
      "title": "",
      "instruction": "Place slides in the Phosphomolybdic-Phosphotungstic Acid Solution in a plastic coplin jar for 10-15 minutes or until collagen fibers are not red."
    },
    {
      "title": "",
      "instruction": "Place slides in Aniline Blue solution for 10 minutes."
    },
    {
      "title": "",
      "instruction": "Rinse in distilled water."
    },
    {
      "title": "",
      "instruction": "Place in 1% Acetic acid for 3 minutes."
    },
    {
      "title": "",
      "instruction": "Wash 2x for 3 minutes in 100% EtOH"
    },
    {
      "title": "",
      "instruction": "Wash 1x for 2 minutes in 95% EtOH"
    },
    {
      "title": "",
      "instruction": "Wash 2x for 5 minutes in Xylene"
    },
    {
      "title": "",
      "instruction": "Mount slides with mounting medium- 1 drop"
    },
    {
      "title": "",
      "instruction": "Insert Coverslip carefully, avoid bubble"
    }
  ],
