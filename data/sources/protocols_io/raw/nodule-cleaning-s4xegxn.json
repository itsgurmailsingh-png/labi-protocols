  "steps_raw": [
    {
      "title": "",
      "instruction": "Cleanly cut nodules from plant roots and drop into a 2ml Eppendorf tube per plant."
    },
    {
      "title": "",
      "instruction": "Add 1ml 100% EtOH to each tube"
    },
    {
      "title": "",
      "instruction": "Incubate for 5 seconds"
    },
    {
      "title": "",
      "instruction": "Remove as much liquid as possible without removing loose nodules"
    },
    {
      "title": "",
      "instruction": "Add 1ml 6% sodium hypochlorite"
    },
    {
      "title": "",
      "instruction": "Remove as much liquid as possible"
    },
    {
      "title": "",
      "instruction": "Add 2ml sterile water"
    },
    {
      "title": "",
      "instruction": "Remove as much liquid as possible go to step #7"
    },
    {
      "title": "",
      "instruction": "Close tube, move to sequencing/culturing"
    }
  ],
