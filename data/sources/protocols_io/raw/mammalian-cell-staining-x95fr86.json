      "instruction": "Remove blocking buffer."
    },
    {
      "title": "",
      "instruction": "Wash twice with washing buffer."
    },
    {
      "title": "",
      "instruction": "Incubate for 00:30:00 ."
    },
    {
      "title": "",
      "instruction": "Remove stains."
    },
    {
      "title": "",
      "instruction": "Add 100 µL of DAPI solution, cover in foil."
    },
    {
      "title": "",
      "instruction": "Wash twice."
    },
    {
      "title": "",
      "instruction": "Remove anti-vinculin blocking buffer mixture."
    },
    {
      "title": "",
      "instruction": "Incubate for 00:05:00"
    },
