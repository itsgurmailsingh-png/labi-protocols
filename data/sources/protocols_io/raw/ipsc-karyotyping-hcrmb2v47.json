      "title": "",
      "instruction": "iPSCs were dissociated with Accutase and plated at 1x106 cells/well in 6 well plates in StemFlex with 10 μM Y-27632."
    },
    {
      "title": "",
      "instruction": "24 hours after seeding. iPSCs were treated with Colcemid (1:100, Roche, 10295892001) for 12 hours."
    },
    {
      "title": "",
      "instruction": "Treated iPSCs were transferred to NHGRI Cytogenetics Core for karyotyping."
    }
