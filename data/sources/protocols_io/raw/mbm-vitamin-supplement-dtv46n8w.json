  "steps_raw": [
    {
      "title": "",
      "instruction": "Measure some amount &lt;100 mL dH 2 O into a bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 2 mg biotin into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 2 mg folic acid into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 10 mg pyridoxine-HCl into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 5 mg riboflavin into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 5 mg thiamine into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 5 mg nicotinic acid into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 5 mg pantothenic acid into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 0.1 mg cyanocobalamin into the bottle."
    },
    {
      "title": "",
      "instruction": "Dissolve 5 mg p -aminobenzoic acid into the bottle."
    },
    {
      "title": "",
      "instruction": "Bring final volume to 100 ml with dH 2 O."
    },
    {
      "title": "",
      "instruction": "Filter sterilize final vitamin solution through a 0.2 micron PES membrane."
    },
    {
      "title": "",
      "instruction": "Store frozen in 1 mL aliquots."
    }
  ],
