  "steps_raw": [
    {
      "title": "",
      "instruction": "Add 140 µL saliva to 560 µL lysis buffer."
    },
    {
      "title": "",
      "instruction": "Shake the tubes violently by hand."
    },
    {
      "title": "",
      "instruction": "Incubate at 61 ºC for 5 min."
    },
    {
      "title": "",
      "instruction": "Apply entire 700 µL to spin column."
    },
    {
      "title": "",
      "instruction": "Spin at 8 kRCF for 1 min."
    },
    {
      "title": "",
      "instruction": "Remove flowthrough with a pipette."
    },
    {
      "title": "",
      "instruction": "Add 500 µL wash 1 to the column."
    },
    {
      "title": "",
      "instruction": "Spin at 8 kRCF for 1 min."
    },
    {
      "title": "",
      "instruction": "Remove flowthrough with a pipette."
    },
    {
      "title": "",
      "instruction": "Add 500 µL wash 2."
    },
    {
      "title": "",
      "instruction": "Spin at 8 kRCF for 2 min."
    },
    {
      "title": "",
      "instruction": "Transfer column to a new tube and add 50 µL elution buffer."
    },
    {
      "title": "",
      "instruction": "Spin at 8k RCF for 1 min."
    },
    {
      "title": "",
      "instruction": "Add to LAMP reactions."
    }
