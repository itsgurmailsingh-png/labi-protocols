  "steps_raw": [
    {
      "title": "",
      "instruction": "Extract the sponge liquid by squizing the sponge."
    },
    {
      "title": "",
      "instruction": "Move (pour) the liquid content extracted from the sponge into 50 mL tubes (expect 15 mL eg. Longmire&#39;s buffer)"
    },
    {
      "title": "",
      "instruction": "Add 33 mL of pure ethanol and 1.m mL of Sodium Acetate 3M to the sample tube (achieving approx. 50 mL of liquid voulme)."
    },
    {
      "title": "",
      "instruction": "incubate the samples overnight at -20 °C"
    },
    {
      "title": "",
      "instruction": "Cool down the centrifuge to 4-8 °C"
    },
    {
      "title": "",
      "instruction": "Centrifuge at 4000g for 80 min at 6°C."
    },
    {
      "title": "",
      "instruction": "Discard the supernatant and take up to 250 mg of the sediment into PowerBead tubes (Qiagen, Hilden, Germany)"
    },
    {
      "title": "",
      "instruction": "Follow the DNeasy PowerSoil kit instruction for the DNA extraction."
    }
  ]
}