  "title": "Lyophilized plant extraction for LC-MS Analysis",
  "author": "Kateřina Kučerová",
  "doi": "dx.doi.org/10.17504/protocols.io.e6nvwe8zwvmk/v1",
  "source_url": "https://www.protocols.io/view/lyophilized-plant-extraction-for-lc-ms-analysis-eb7ebarjf",
  "steps_raw": [
    {
      "title": "",
      "instruction": "Weight 25 ± 2.5 mg of lyophilized plant material into a 2.0 Eppendorf tube with round bottom"
    },
    {
      "title": "",
      "instruction": "Add a metal bead to each tube"
    },
    {
      "title": "",
      "instruction": "Homogenize in TissueLyser 30 sec, 25 rpm"
    },
    {
      "title": "",
      "instruction": "Add 2 000 μL of EtOH-H 2 O (75:25) and vortex to mix"
    },
    {
      "title": "",
      "instruction": "Incubate 3 min at 40 °C"
    },
    {
      "title": "",
      "instruction": "Centrifuge 5 min , 14 000 rpm"
    },
    {
      "title": "",
      "instruction": "Transfer 500 μL of supernatant into a new 2.0 Eppendorf tube"
    },
    {
      "title": "",
      "instruction": "Homogenise in TissueLyser 60 sec, 25 rpm"
    },
    {
      "title": "",
      "instruction": "Dry in SpeedVac"
    },
    {
      "title": "",
      "instruction": "Resuspend in 2 000 μL of H 2 O-CH 3 CN (50:50)"
    },
    {
      "title": "",
      "instruction": "Sonicate 15 sec and vortex 30 sec"
    },
    {
      "title": "",
      "instruction": "Centrifuge 5 min, 14 000 rpm"
    },
    {
      "title": "",
      "instruction": "Transfer supernatant into LC-MS vials"
    }
  ],
