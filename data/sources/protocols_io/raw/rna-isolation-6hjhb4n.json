  "title": "RNA Isolation",
  "author": "Natalie Brown",
  "doi": "dx.doi.org/10.17504/protocols.io.6hjhb4n",
  "source_url": "https://www.protocols.io/view/rna-isolation-6hjhb4n",
  "steps_raw": [
    {
      "title": "",
      "instruction": "●Get plates, aspirate media"
    },
    {
      "title": "",
      "instruction": "●Add 2mL ice cold DPBS"
    },
    {
      "title": "",
      "instruction": "○Aspirate DPBS"
    },
    {
      "title": "",
      "instruction": "●Add 500uL Trizol/well in chemical hood"
    },
    {
      "title": "",
      "instruction": "●Bring yellow tubes to hood, collect trizol and add to tubes"
    },
    {
      "title": "",
      "instruction": "●Add 100uL chloroform to tubes"
    },
    {
      "title": "",
      "instruction": "○hand shake 15s"
    },
    {
      "title": "",
      "instruction": "○Place on ice 5min until see layers (aq/lipids/bottom)"
    },
    {
      "title": "",
      "instruction": "●Spin full speed 20min cold centrifuge"
    },
    {
      "title": "",
      "instruction": "○During, make 70% ethanol on ice (3mL RNAse-free water + 7mL ethanol)"
    },
    {
      "title": "",
      "instruction": "○Make new ep set 1-9"
    },
    {
      "title": "",
      "instruction": "●In hood, collect top layer after spinning and place into eppendorfs"
    },
    {
      "title": "",
      "instruction": "○**take note of first volume and make all the same"
    },
    {
      "title": "",
      "instruction": "○Mix 1:1 ethanol with supernatant, use same tip to transfer from eppendorfs into pink spin tubes"
    },
    {
      "title": "",
      "instruction": "●Spin 9000x 1min bench centrifuge"
    },
    {
      "title": "",
      "instruction": "○Discard flowthrough in hood, keep tube"
    },
    {
      "title": "",
      "instruction": "●Add 350uL RW1 buffer to tubes"
    },
    {
      "title": "",
      "instruction": "○Spin 1 min"
    },
    {
      "title": "",
      "instruction": "○During, prepare DNAse soln (with syringe)"
    },
    {
      "title": "",
      "instruction": "●Add 70uL DNAse soln to middle of each column, leave 15min RT"
    },
    {
      "title": "",
      "instruction": "●Repeat RW1 and spin"
    },
    {
      "title": "",
      "instruction": "○Discard collection tube and get new"
    },
    {
      "title": "",
      "instruction": "●Wash RPE 500uL"
    },
    {
      "title": "",
      "instruction": "○Spin 1min"
    },
    {
      "title": "",
      "instruction": "○Discard collection and keep tubes"
    },
    {
      "title": "",
      "instruction": "●Repeat RPE, spin 2min"
    },
    {
      "title": "",
      "instruction": "○Discard tubes"
    },
    {
      "title": "",
      "instruction": "●Spin 1min empty to dry"
    },
    {
      "title": "",
      "instruction": "○Get new eppendorfs, label"
    },
    {
      "title": "",
      "instruction": "●Place pink tubes on top of eppendorfs"
    },
    {
      "title": "",
      "instruction": "●Add 30uL RNAse free water, centrifuge 1min"
    },
    {
      "title": "",
      "instruction": "○Close tubes as quickly as possible and keep on ice→ nanodrop"
    }
  ],
