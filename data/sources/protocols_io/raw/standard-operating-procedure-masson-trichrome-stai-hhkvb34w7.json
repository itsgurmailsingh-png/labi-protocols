  "steps_raw": [
    {
      "title": "",
      "instruction": "Melt sections for 30 min 60 °C"
    },
    {
      "title": "",
      "instruction": "Deparaffinize: Histoclear"
    },
    {
      "title": "",
      "instruction": "Bouin’s solution: Preheat and incubate at 60 °C in fume hood."
    },
    {
      "title": "",
      "instruction": "Rinse in running water."
    },
    {
      "title": "",
      "instruction": "Stain with Weigert-Lillie’s Iron Hematoxylin"
    },
    {
      "title": "",
      "instruction": "Rinse in running water"
    },
    {
      "title": "",
      "instruction": "Stain with Biebrich Scarlet/Fuchsin Acid"
    },
    {
      "title": "",
      "instruction": "Dip in water twice."
    },
    {
      "title": "",
      "instruction": "Treat with molybdotungstophosphoric/tungstophosphoric acid"
    },
    {
      "title": "",
      "instruction": "Stain with 2% Aniline Blue"
    },
    {
      "title": "",
      "instruction": "Rinse in water 5–10 dips."
    },
    {
      "title": "",
      "instruction": "Dehydrate: 96% ethanol 5 dips"
    },
    {
      "title": "",
      "instruction": "Mount with Dako Mounting Media."
    },
    {
      "title": "",
      "instruction": "Deparaffinize: 99% ethanol"
    },
    {
      "title": "",
      "instruction": "Deparaffinize: 96% ethanol"
    },
    {
      "title": "",
      "instruction": "Deparaffinize: 70% ethanol"
    },
    {
      "title": "",
      "instruction": "Deparaffinize: Water"
    },
    {
      "title": "",
      "instruction": "Dehydrate: Histoclear"
    },
    {
      "title": "",
      "instruction": "Dehydrate: 99% ethanol 5 dips"
    }
