  "steps_raw": [
    {
      "title": "",
      "instruction": "Thaw bacteria on ice"
    },
    {
      "title": "",
      "instruction": "Dispense 50μl in a microtube"
    },
    {
      "title": "",
      "instruction": "Add 1 to 5 μl of DNA, and carefully flick the tube to mix cells and DNA"
    },
    {
      "title": "",
      "instruction": "Place the mixture on ice for 10 minutes"
    },
    {
      "title": "",
      "instruction": "Heat shock at 42°C for 30 seconds"
    },
    {
      "title": "",
      "instruction": "Place on ice for 5 minutes"
    },
    {
      "title": "",
      "instruction": "Pipette 450 μl of room temperature SOC (or LB) into the mixture"
    },
    {
      "title": "",
      "instruction": "Incubate at 37°C for 1 hour. Shake vigorously at 250 rpm."
    },
    {
      "title": "",
      "instruction": "Warm selection plates at 37°C"
    },
    {
      "title": "",
      "instruction": "Spread desired volume (150-350 μl) onto selection plate"
    },
    {
      "title": "",
      "instruction": "Incubate overnight at 37°C"
    },
    {
      "title": "",
      "instruction": "Store at 4°C after incubation of needed"
    }
  ]
}