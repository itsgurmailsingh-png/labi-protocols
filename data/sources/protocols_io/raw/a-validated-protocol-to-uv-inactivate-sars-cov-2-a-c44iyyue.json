  "steps_raw": [
    {
      "title": "",
      "instruction": "Wash each well with 1 mL PBS"
    },
    {
      "title": "",
      "instruction": "Scrape each well (2x10 6 cells) into 1 mL PBS"
    },
    {
      "title": "",
      "instruction": "Transfer cells into a 1.5 mL tube"
    },
    {
      "title": "",
      "instruction": "Pellet cells at 16000 x g, 4 °C, 1 minute"
    },
    {
      "title": "",
      "instruction": "Resuspend cells in 200 μL PBS"
    },
    {
      "title": "",
      "instruction": "Transfer cells to a tissue vial"
    },
    {
      "title": "",
      "instruction": "254 nm UV irradiation of vials"
    },
    {
      "title": "",
      "instruction": "Irradiate vials with 2,500 mJ/cm 2"
    },
    {
      "title": "",
      "instruction": "Mix the cell solution with a micropipette"
    },
    {
      "title": "",
      "instruction": "Repeat irradiation 3 additional times for a total of 10,000 mJ/cm 2"
    },
    {
      "title": "",
      "instruction": "Screw the lids on the vials"
    },
    {
      "title": "",
      "instruction": "Disinfect the outside of the tissue vials by wiping with Incidin Plus"
    }
  ]
}