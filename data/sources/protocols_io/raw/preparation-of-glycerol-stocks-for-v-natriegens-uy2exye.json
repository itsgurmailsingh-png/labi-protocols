  "steps_raw": [
    {
      "title": "",
      "instruction": "Prepare LBv2 medium (LB medium supplemented with 204mM NaCl, 4.2mM KCl and 23.14mM MgCl2)"
    },
    {
      "title": "",
      "instruction": "Grow overnight (ON) culture of V. natriegens."
    },
    {
      "title": "",
      "instruction": "Centrifuge 1 mL of ON culture at 3000 rcf, 1min."
    },
    {
      "title": "",
      "instruction": "Wash with fresh LB medium."
    },
    {
      "title": "",
      "instruction": "Add 1mL Medium/Glycerol (80/20)."
    },
    {
      "title": "",
      "instruction": "Vortex quickly and store at -80°C."
    }
  ],
