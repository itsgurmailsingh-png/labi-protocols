  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Coat 96 well plate with 50 µL Matrigel per well.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate at 37 °C for 01:00:00 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Prepare plate for expansion by aspirating Matrigel from plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 50 µL mTesR1 + 10 uM Rock Inhibitor to appropriate wells.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Aspirate media from original plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Wash with 200 µL PBS and aspirate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 25 µL of 0.05% Trypsin.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Incubate at 37 °C for 00:05:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Tap to lift cells from plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Check under microscope to ensure that cells have detached from plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Add 50 µL FBS and tap to mix.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer 50 µL to 96 well PCR plate, while maintaining the location of each sample (this plate will be used for gDNA extraction).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Transfer remaining cells (~30uL) to 96 well plate containing mTesR1.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Incubate at 37 °C .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "After 24:00:00 , complete daily media changes with mTesR1.",
      "is_critical": false,
      "timers": []
    }
  ],
