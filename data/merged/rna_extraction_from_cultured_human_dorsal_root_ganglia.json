  "quality_score": 23.0,
  "category": "Molecular Biology",
  "estimated_time_mins": 276,
  "materials": [
    "RLT Plus lysis buffer",
    "Beta mercaptoethanol",
    "70% ETOH",
    "80% ETOH",
    "1X DPBS",
    "cell scraper",
    "gDNA eliminator spin column",
    "2ml collection tube",
    "vortex",
    "centrifuge"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Cell cultures are prepared as described in dx.doi.org/10.17504/protocols.io.kxygxyd64l8j/v1",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Prepare RLT Plus containing Beta mercaptoethanol in separate tube in fume hood",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Prepare 350 ul of RLT Plus lysis buffer for each sample",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add Beta mercaptoethanol 1:100 in RLT Plus Buffer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Example: Add 10 ul of Beta mercaptoethanol to 1ml of RLT Plus",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Vortex",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Prepare 70% ETOH by diluting 100% ETOH in Ultrapure Distilled Water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Prepare 80% ETOH by diluting 100% ETOH in Ultrapure Distilled Water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Aspirate media and wash cells 1x with 500ul of 1X DPBS",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Performing one well at a time, aspirate out DPBS and add 350ul of RLT plus buffer with Beta mercaptoethanol to each well",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Be careful when pipetting as this is soapy and will form a lot of bubbles if not careful",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Scrape down cells using cell scraper and collect RLT plus buffer and place in 1.5ml tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Vortex all samples for 30 seconds",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Transfer the lysate to a gDNA eliminator spin column place in a 2ml collection tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Centrifuge for 30 seconds at ≥8000g at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Discard column and SAVE flow-through",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Add 1 volume of 70% ETOH (usually around 350ul) to the flow-through and mix well by pipetting",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Transfer the sample to an RNeasy MinElute spin column placed in 2ml collection tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Centrifuge for 15 seconds at ≥8000g at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Discard flow-through",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Add 350 ul of RW1 to RNeasy MinElute spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Centrifuge for 15 seconds at ≥8000g at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Discard flow-through",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "DNAse clean up step",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Add 70ul of RDD buffer to 10ul aliquots of reconstituted DNase",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Add 80ul of RDD buffer + DNase directly to spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Incubate for 15 minutes at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "Add 350 ul of RW1 to RNeasy MinElute spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "Centrifuge for 15 seconds at ≥8000g at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 29,
      "title": "",
      "instruction": "Discard flow-through",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 30,
      "title": "",
      "instruction": "Add 500 ul of RPE RNeasy MinElute spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 31,
      "title": "",
      "instruction": "Centrifuge for 15 seconds at ≥8000g at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 32,
      "title": "",
      "instruction": "Discard flow-through",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 33,
      "title": "",
      "instruction": "Add 500 ul of 80% ETOH to RNeasy MinElute spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 34,
      "title": "",
      "instruction": "Centrifuge for 2 minutes at ≥8000g at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 35,
      "title": "",
      "instruction": "Discard flow-through and collection tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 36,
      "title": "",
      "instruction": "Place MinElute spin column in new 2ml collection tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 37,
      "title": "",
      "instruction": "Open lid of spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 38,
      "title": "",
      "instruction": "Centrifuge for 5 minutes at full speed (16,000g) at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 39,
      "title": "",
      "instruction": "Discard flow-through and collection tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 40,
      "title": "",
      "instruction": "Place MinElute spin column in new 1.5ml collection tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 41,
      "title": "",
      "instruction": "Place 14ul of DNA/RNA free water directly to center of spin column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 42,
      "title": "",
      "instruction": "Incubate for 1 minute at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 43,
      "title": "",
      "instruction": "Centrifuge for 1 minute at full speed (16,000g)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 44,
      "title": "",
      "instruction": "Keep collection tube, and discard column",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 45,
      "title": "",
      "instruction": "Freeze and store RNA by placing in -80°C freezer",
      "is_critical": false,
      "timers": []
    }
  ],
  "verification_status": "verified",
  "merged_at": "2026-06-18"
}