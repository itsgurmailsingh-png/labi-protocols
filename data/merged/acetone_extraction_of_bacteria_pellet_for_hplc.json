  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 4 times the volume -20°C acetone (3 mL in our case) to the extract, and vortex.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate sample at -20°C for 1 hour. 01:00:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at 13500 rpm for 10 minutes at 4°C. Collect the supernatant without touching the protein pellet.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Store the acetone extracted sample at -80°C for long term use, or -20°C for short term use.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Grow bacteria in in 150 mL 2xYT media overnight. Harvest by centrifugation at 4000 rpm for 10 minutes. Discard the supernatant.",
      "is_critical": false,
      "timers": []
    }
