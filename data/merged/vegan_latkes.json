  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Peel and wash 6 Russet potatoes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1 teaspoon of salt.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add \\frac{1}{4} cup of flour to the potatoes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Cut up the potatoes and grate in a food processor.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Cover bottom of a frying pan with oil and heat to medium-high.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Use a spoon to remove the water; keep doing this as you fry. Put the spoon onto the surface of the batter, pressing it down a little bit. Let the liquid seep in.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Fry for 3-5 minutes until crisp. 00:03:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Flip, add more oil, and fry another 3-5 minutes. 00:03:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Process quickly again to mix the salt and flour.",
