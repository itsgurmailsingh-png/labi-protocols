  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add plasmid DNA (1 µL of miniprep/2 µL of ligation mixture/...µL of cesium-purified DNA).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate on ice for 30 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Heat shock at exactly 42ºC for exactly 1:30 minutes, then chill on ice again for 5 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Culture in 1 mL SOC for 1 hour at 37ºC and pre-warm the agar plates in the meantime.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Spin the culture down at 3000rpm for 3 minutes, discard 900 µL and resuspend the pellet in the remaining 100 µL.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Plate accordingly on agar plates with the appropriate antibiotic, if applicable.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Repeat Step 3, once.",
      "is_critical": false,
      "timers": []
    }
