  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Cut tissue (25-50 mg) into small pieces.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 500 µl Lyse 1. undetermined, Lyse 1",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 50 µl Lyse 2. undetermined, Lyse 2",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 10 µl Proteinase K. undetermined, Proteinase K",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate in a thermomixer at 65°C for 12 hours. 12:00:00, Incubation at 65°C",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge for 10 min at 13000rpm. 00:10:00, Centrifugation",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Discard supernatant without disturbing the pellet.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Add 375 µl Lyse 3 undetermined, Lyse 3",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Vortex for 20 sec. 00:00:20, Vortex",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Leave it for 5 min in the freezer (-20°C) 00:05:00, Freezer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Centrifuge 20 min at 13000rpm. 00:20:00, Centrifugation",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Transfer the supernatant in a new tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add 640 µl isopropanol. undetermined, Isopropanol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Centrifuge for 15 min at 13000 rpm. 00:15:00, Centrifugation",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Remove the supernatant (don´t touch the pellet).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Add 150 µl ethanol. undetermined, Ethanol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Centrifuge for 5 min at 13000 rpm. 00:05:00, Centrifugation",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Remove the ethanol with a pipette (don´t touch the pellet).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Dry the pellet (37°C open lid max 5 min). 00:05:00, Dry",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Re-suspend the pellet in 100 µl Buffer AE. undetermined, Buffee AE",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Measure DNA concentration on Nanodrop (Thermo Fischer Scientific, Darmstadt, DE).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Mix by inversion.",
      "is_critical": false,
      "timers": []
    }
