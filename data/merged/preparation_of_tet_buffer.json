    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1800 mL, RNase free Water to a 2 L single use cell culture bottle.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 4 mL, 0.5 M EDTA , pH 8.0 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 20 mL, 1 M Tris-HCl , pH 8.0 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add 1 mL, Tween-20 .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Make up to 2000 ml Water (RNAse free). Swirl very well to ensure that Tween-20 is well mixed in.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Vacuum filter into sterile bottles.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Label with batch number and date.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Store TET buffer at solution at Room temperature ( 15 °C – 25 °C ).",
      "is_critical": false,
      "timers": []
    },
    {
