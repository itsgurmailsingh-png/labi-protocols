  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Cut frozen muscle sections (5 mm) in a cryostat on microscope slides.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "The slides were allowed to reach room temperature.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "The slides were permeabilized with 0.3% Triton X-100-PBS for 10 min at 4°C.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "A blocking solution of 5% normal goat serum (NGS)-PBS was applied for 1 h at room temperature.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Primary antibody (BD Pharmingen (cat. no. 550300; India)) in 1% NGS-PBS was applied at 4°C overnight.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Three consecutive washes with PBS for 5 min each.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Secondary antibody (Thermo Fisher (cat. no. A21121)) in 1% NGS-PBS was applied for 30 min at room temperature.",
      "is_critical": false,
      "timers": []
    }
  ],
