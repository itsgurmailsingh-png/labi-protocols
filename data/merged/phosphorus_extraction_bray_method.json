  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Print the required labels needed for Bray extraction for each site, depth, and replicate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Weigh out 2 g of soil into labeled 50 mL centrifuge tubes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 14 mL of Bray Extract solution (in cabinet under hood in 1521) using the pipet and electronic pipettor.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Cap the samples and shake to mix. Add samples to foam block on shaker.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "1000S_SITE_P_BRAY_DEPTH_REPLICATE",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "1000S_SITE_Pext_BRAY_DEPTH_REPLICATE",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "For example: 1000S_PRS1_P_Bray_TOP_1",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Shake samples at 1000 rpm, °C, 5 minutes .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Centrifuge samples (using centrifuge on west side of 1521) for 4000 rpm, , 8 minutes .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Pour off liquid into a clean and labelled 15 mL centrifuge tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "For example: 1000S_PRS1_Pext_Bray_TOP_1",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Freeze samples on their side to prevent tube breaking in the -20 °C freezer (Staging Freezer 2) bottom shelf if unable to filter immediately.",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Follow sample filtering protocol below when ready to filter extracts.",
