  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Make at least 40 mL of overnight culture of Xanthomonas Campestris Campestris at 28 °C",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Measure OD600 of O/N culture",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge culture for 00:10:00 at 4000 rpm",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Remove supernatant",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Dissolve pellet in H2O until an OD600 of 1. Make sure you have at least 30 mL of diluted culture.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Dip sterilized scissors in diluted culture and cut of the tip of a leave (about 1 cm). Make sure to cut over the central vein. Repeat this for each leaf you want to infect.",
      "is_critical": false,
      "timers": []
    }
