      "step_id": 0,
      "title": "",
      "instruction": "Bring 1 litre of triple distilled H₂O to boil in pan",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 20g of agar and 84g of light brown soft sugar and stir continuously for 5 minutes while mixture boils rapidly",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Allow mixture to cool to around 70°C and then stir in 7ml of tegosept anti-fungal solution (dissolve Methyl-4- hydroxybenzoate in 95% Ethanol at 150g/L)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Dispense sugar-agar into vials.",
