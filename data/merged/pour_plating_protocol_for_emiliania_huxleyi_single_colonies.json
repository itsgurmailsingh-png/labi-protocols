  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Autoclave 75 mL DDW with 0.75 g agarose",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "For 300 mL (= 7 plates): heat 225 mL FSW in a 50 °C water bath.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Cool autoclaved agar to 50 °C, mix with heated FSW, add F/2 stock and antibiotics if necessary. Swirl/mix well.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "For each sample, pour 40 mL of FSW-agar mixture to a 50 mL conical tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Move to 32 °C bath.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Prepare the cells at desired cell concentration. For each sample prepare 0.5ml cells.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Lay out plates.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "When you are ready, remove FSW-agar mix from 32 °C bath and allow to cool 1-2 degreesCritical: the mixture will start to solidify at 27-28 °C.",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add cell suspension to each tube, mix gently, then pour into plates.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Let solidify to a loose consistency",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Transfer to growth room. Single colonies should appear within 10 days (without selection).",
      "is_critical": false,
      "timers": []
    }
  ],
