  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Aspirate media from original plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Wash with 200 µL PBS and aspirate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add 25 µL of 0.05% Trypsin.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Incubate at 37 °C for 00:05:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Tap to lift cells from plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Check under microscope to ensure that cells have detached from plate.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 45 µL mTesR1 to plate and tap to mix.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Transfer 15 µL to a 96 well PCR plate, while maintaining the location of each sample (this plate will be used for gDNA extraction).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 50 µL of 2X Freezing Media (20% DMSO in FBS) to cell plate and tap to mix.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Wrap plate in parafilm. Add tape over parafilm. Label the plate on the outside of the tape.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Place plate in Styrofoam box. Fill any open areas with diapers, paper towels, or Kimwipes. Cover box and make sure that lid is closed completely.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Store in -80 °C for up to 4 months .",
      "is_critical": false,
      "timers": []
    }
  ],
