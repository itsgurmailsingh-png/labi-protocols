  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Please select between the recipes for 1 L 0.1M Tris HCl pH 6.4 and 5 L 0.1M Tris HCl pH 6.4 . Work in fume hood!",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Weigh out 15.76 g, Tris HCl and add to a 1 L beaker.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Measure out 800 mL, milliQ water and add to the beaker.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add a magnetic flea and place on a magnetic stirring plate to mix the solution.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add a newly calibrated pH meter into the solution to observe the pH.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Tune pH with 5 Molarity (M), NaOH .",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Transfer to a 1 L graduated cylinder and make up to 1000 ml using milliQ water . Swirl.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Vacuum filter into sterile bottles.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Label with batch number and date.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Store 1 L, 0.1 M Tris HCl, pH 6.4 solution at Room temperature ( 15 °C – 25 °C ).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Weigh out 78.8 g, Tris HCl and add to a 5 L beaker.",
      "is_critical": false,
      "timers": []
    },
    {
