  "category": "Molecular Biology",
  "estimated_time_mins": 108,
  "materials": [
    "phenol-chloroform",
    "ethanol",
    "Na acetate",
    "SDS",
    "centrifuge",
    "vortex mixer",
    "dry ice",
    "pipette",
    "tubes"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "To 100ul eluted DNA, add 0.5 ul of 20% SDS (*this may not be necessary as there are no cells) and 100 ul of phenol-chloroform.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Vortex well.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Centrifuge at room temperature for 5 min, at full speed (14,000 rpm).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Pipette the aqueous phase (upper phase, aprox 80 ul, it is better to leave some DNA than to pipette phenol) to a new labeled tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Discard original tube. The tube contains phenol-chloroform.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Proceed to ethanol precipitation.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 1/10 volume Na acetate 3M pH 4.8 or 5.2 (ie 8ul for 80 ul DNA solution) add 2 volumes ETOH 100% (storage -20°C) = 176 ul Total volume: 264ul, possible with 264 ng of starting DNA - otherwise, you must add a carrier: tRNA, glycogen or linear acrylamide.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Vortex.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Put on dry ice for 30 min. or overnight at -20°C",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Centrifuge at 4°C for 30 min at 14,000 rpm.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Discard the supernatant.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Wash with 500ul EtOH 70% (storage 4°C)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Centrifuge at 4°C for 5 min at 14,000 rpm.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Discard the supernatant",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Quick spin",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Pipette out the last drop of EtOH",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Speed Vac for 3&#39; or 5-7 min at room temperature.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Resuspend in 20ul of water ot Tris 10 mM pH 7.5 or 8.0",
      "is_critical": false,
      "timers": []
    }
  ],
  "verification_status": "verified",
  "merged_at": "2026-06-18"
}