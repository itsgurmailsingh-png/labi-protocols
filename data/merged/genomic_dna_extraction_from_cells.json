  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Extract genomic DNA from cells with Quick Extract buffer (QE – Epibio #QE09050).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Remove media.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Trysinize cells.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Centrifuge at 16K x g for 2 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Wash with ice cold 1xPBS.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centrifuge at 16K x g for 2 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add 100ul QE / well (24-well plates, scale up for your plate size).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Let sit 5 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Transfer to PCR tubes, 100 uL each tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Vortex for 15sec, centrifuge to collect liquid in bottom.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Put PCR tubes in thermocycler: 20min at 65C, 20min at 95C, store at -20C.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Measure concentration with Nanodrop. Use QE buffer as blank.",
      "is_critical": false,
      "timers": []
    }
