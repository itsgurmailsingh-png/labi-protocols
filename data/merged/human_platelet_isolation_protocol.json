  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Use IV butterfly set and draw blood into sodium citrate vaccutainers",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Centrifuge at 1200 rpm for 15 minutes at room temperature",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transfer plasma top fraction to a new tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Dilute plasma with an equal volume of Tyrodes buffer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Add PGI2 to a final concentration of 10uM",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Centifuge at 2800 rpm for 5 minutes, decant the supernatant and gently resuspend the platelet pellet into Tyrode&#39;s buffer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Dilute the platelets 1:20 in fresh Tyrode&#39;s buffer for downstream applications such as flow cytometry, or lyse pellet directly for ELISA or western blotting.",
      "is_critical": false,
      "timers": []
    }
