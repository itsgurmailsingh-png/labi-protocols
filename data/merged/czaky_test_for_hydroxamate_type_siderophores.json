    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 2 mL 3 M sulfuric acid and autoclave for 4 hr at 121ºC undetermined 04:00:00 Use H 2 O instead of sulfuric acid for a blank sample. Sulfuric acid Fisher Scientific Catalog #A300C-212",
