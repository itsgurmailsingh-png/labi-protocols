  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Sieve soil to 2mm",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Weigh out 50 g, soil in a weigh boat",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Place tissue paper on top of Baermann funnel apparatus",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Place weighed and sieved soil on top of filter paper",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Fill Baermann funnel with DI water using a DI water bottle so that soil sample is saturated but not submerged in water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Cover all Baermann funnels with a plastic Uline",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "At 24:00:00 and 48:00:00 mark, check soil and refill any funnels with decreased water levels to prevent the soil from drying out.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "At 72:00:00 empty funnel over a 25um mesh sieve to collect nematodes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Transfer the nematodes that are on the sieve into a labelled centrifuge tube using a hot fixative Fixative preparation for Baermann funnel extraction by Casey A Schlenker",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Count the entire sample at 50x magnification using a dissecting scope",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Identify 100 nematodes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Collect soil from top of Baermann funnel; dry and weigh to get gravimetric soil moisture content",
      "is_critical": false,
      "timers": []
    }
