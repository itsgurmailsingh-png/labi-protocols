  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Prepare electrocompetent bacterial cells and keep them on ice.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add 1–2 µL of plasmid DNA to ~50 µL of competent cells. Gently mix.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transfer the mixture into a pre-chilled electroporation cuvette (0.1 cm gap).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Insert the cuvette into the BioRad MicroPulser.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Apply the electrical pulse using the appropriate preset (e.g., Ec1 for E. coli ).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Immediately add 950 µL of SOC or LB recovery media to the cuvette.",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Transfer the cells to a sterile culture tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Incubate at 37°C with shaking for 1 hour.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Plate cells onto selective agar plates.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Incubate plates overnight at 37°C.",
      "is_critical": false,
      "timers": []
    }
  ],
