  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Weigh 0.5 g of soil (remove debris like stones or large particles).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add the soil sample into the PowerBead Pro Tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Add Solution CD1 to the tube as per kit instructions.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Homogenize the sample using one of the following Vortex Adapter method.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Ensure proper mixing and cell lysis through homogenization.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add Solution CD2 to remove impurities.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Add Solution CD3, then load the sample into the MB Spin Column.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Wash the column with Solution EA followed by Solution C5 to ensure purity.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Elute the DNA using Solution C6 to collect the extracted DNA.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Perform electrophoresis on an agarose gel to confirm DNA quality.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Use a Nanodrop spectrophotometer to measure DNA concentration and purity.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Send the extracted e-DNA to the FAILSAFE Project Team at Chulalongkorn University for further analysis.",
      "is_critical": false,
      "timers": []
    }
