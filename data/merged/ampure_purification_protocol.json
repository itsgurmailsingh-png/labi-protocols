  "materials": [
    "AMPure beads",
    "DNA",
    "70% EtOH",
    "Tris 10 mM",
    "magnetic rack",
    "pipette",
    "vortex"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Remove beads from the fridge, equilibrate to the room temperature, mix thoroughly but do not vortex.",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add desired ratio of AMPure beads to the DNA to be purified and mix well by pipetting.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate 5 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Place on the magnetic rack.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Let it stand for 5 minutes on the rack, aspirate and discard supernatant.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 200 μl of freshly prepared 70% EtOH, incubate 30 seconds, aspirate and discard EtOH.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Repeat the wash: add 200 μl of freshly prepared 70% EtOH, incubate 30 seconds, aspirate and discard EtOH.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Wait until the pellet dries out completely. DO NOT remove the plate/tubes from the magnetic rack, as the dried AMPure might pop out from the tubes!",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add desired volume of Tris 10 mM or water, wetting the dried AMPure pellets (add 1 μl to the final volume to avoid pipetting out the beads)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Remove from the magnetic rack.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Resuspend by pipetting or vortexing.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Incubate 10 minutes, incubating in 37°C can improve DNA yield.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Place on the magnetic rack.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Let it stand for 5 minutes, pippete out and save supernatant. The eluted DNA is in the supernatant, do not discard it!",
      "is_critical": true,
      "timers": []
    }
  ],
