  "materials": [
    "10% KOH",
    "acetone",
    "Nile Red",
    "distilled water",
    "Whatman 1 filter",
    "flask",
    "forceps",
    "vacuum system",
    "glass cover"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Take samples of the gastrointestinal tract (GIT) /biofilm and gill tissues (fish gills have the same biofilm membrane)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Weigh out 1-2 g of the tissues. Use a glass cover for weighing.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "10% KOH, 50 mL, (as a guideline 1:50 ratio of tissue to KOH works well)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Filter through coarse mesh",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Wash with 50 mL boiling water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Incubate for 10 min with 10 mL acetone",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Wash with another 10 mL of acetone",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Staining with 1mL of diluted Nile Red",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Cut the sample with forceps to increase surface area",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "incubate at 60 C for 24 hours",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Rinse sides of filter with distilled water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Pour the KOH and tissue solution into the Whatman 1 filter. Vacuum.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Set up a filtration system (Whatman 1 filter, flask)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Soak the Whatman 1 filter in distilled water to prevent it from floating",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "USE VACUUM (or samples will be compromised due to floating)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Carefully take the filter and place it into a glass plate with forceps",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Rinse with 10 mL of water (wash the sides of the filter)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Place into a Petri plate",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Observe, use a fluorescent scope",
      "is_critical": false,
      "timers": []
    }
  ],
