  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Add 1 µL of miniprep plasmid or 5 µL of Gibson product into competent cell Hi-Fi Gibson Assembly by NUS iGEM",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Incubate cells in 42 °C water bath for 00:00:45",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate cells on ice for 00:02:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 1 mL of LB media into cell sample Preparation of LB Media by NUS iGEM",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate cells at 37 °C for 01:00:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Spin down the cells at 6000 x g for 00:01:00",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Remove 700 µL of the supernatant",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Re-suspend pellet in remaining media",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Transfer 100 µL of the culture onto the agar plate containing appropriate antibiotic Preparation of LB Agar by NUS iGEM",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Spread the cells evenly",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Incubate at 37 °C overnight",
      "is_critical": false,
      "timers": []
    }
