  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Sample Adult Trichuris trichiura worms preserved in formaldehyde or ethanol during transport",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Step 1: Sample Washing and Preparation",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transfer worm samples into a clean microcentrifuge tube.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add sterile PBS to fully immerse the sample.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Gently invert or pipette to wash.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Remove PBS and repeat washing 2–3 times to remove residual formaldehyde or ethanol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Step 2: Sample Storage (if not processed immediately)",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "After washing, snap-freeze samples in liquid nitrogen.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Step 3: Tissue Selection",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "For intact worms: Excise and use the anterior portion to ensure consistency.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "For fragmented samples: Use all available tissue material.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Step 4: Mechanical Homogenization",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Place the sample into a tube containing stainless steel beads (2-4 small beads)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Add appropriate lysis buffer from the Clear-S kit.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Homogenize using TissueLyser LT: Frequency: 50 Hz Duration: 1 minute per cycle Number of cycles: 2–3 cycles",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Briefly centrifuge between cycles if needed.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Step 5: DNA Extraction",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Proceed with DNA extraction using the Clear-S Quick DNA Extraction Kit following manufacturer’s instructions.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Apply an extended lysis step to improve DNA recovery: Extend incubation time as needed (e.g., +10–20 minutes beyond standard protocol).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Step 6: DNA Elution",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 20,
      "title": "",
      "instruction": "Elute DNA in nuclease-free water or provided elution buffer.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 21,
      "title": "",
      "instruction": "Typical elution volume: 30–50 µL.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 22,
      "title": "",
      "instruction": "Step 7: DNA Quantification and Quality Assessment",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 23,
      "title": "",
      "instruction": "Measure DNA concentration using a Nanodrop spectrophotometer.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 24,
      "title": "",
      "instruction": "Record: DNA concentration (ng/µL) Purity ratios (A260/A280)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 25,
      "title": "",
      "instruction": "Step 8: Storage of Extracted DNA",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 26,
      "title": "",
      "instruction": "Store extracted DNA at: −20 °C (short-term) −80 °C (long-term)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 27,
      "title": "",
      "instruction": "High-quality genomic DNA suitable for: Long-range PCR (β-tubulin ~4.2 kb) ITS2 amplification (~481 bp)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 28,
      "title": "",
      "instruction": "DNA concentration sufficient for downstream applications (&gt;10–20 ng/µL recommended)",
      "is_critical": false,
      "timers": []
    }
