      "step_id": 0,
      "title": "",
      "instruction": "Mix concentrated Euplotes cells together with Ethanol 70% in a ratio of 1:1. Better to have a completely starved Euplotes culture to avoid autofuorescence from bacteria/algae.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Add DAPI (0.01 mg/ml) to the mix in a ratio of 1:10, and stain for 15 minutes at room temperature.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Observe cells by fluorescence microscopy.",
