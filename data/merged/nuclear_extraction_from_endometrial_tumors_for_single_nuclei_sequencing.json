  "materials": [
    "frozen tissue",
    "cold NST buffer",
    "scalpel",
    "40 uM falcon cell strainer",
    "50 mL conical tube",
    "ST buffer",
    "15 mL conical tube",
    "35 um falcon strainer",
    "resuspension buffer"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Place frozen tissue in a well of a 6 well plate containing 1 mL of cold NST disassociation buffer.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Chop tissue using a scalpel until mostly homogenized",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Incubate solution on ice for 5 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Filter the homogenized solution through a 40 uM falcon cell strainer into a 50 mL falcon tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Use an additional 1 mL of NST buffer to rinse the well and filter",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Count nuclei",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Centrifuge nuclei at 300 g for 10 minutes and aspirate supernatant completely",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Resuspend pellet and bring the volume up to 5 mL using ST buffer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Transfer solution to 15 mL conical tube and centrifuge for 10 minutes at 300 g at 4oC",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "10. Resuspend pellets on ice in 1 ml of the ST buffer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "11. Filter through 35 um falcon strainer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "12. Count nuclei",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "13. Resuspend nuclei pellet in resuspension buffer to get a concentration of 1,000 nuclei per uL",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Centrifuge nuclei at 300 g for 10 minutes and aspirate supernatant completely",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Start with .5 mL per 0.2 grams of endometrial tumor tissue",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Look at nuclear membranes at 40x-60x to ensure high nuclear membrane quality with minimal blebbing",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Ensure plate is on ice",
      "is_critical": false,
      "timers": []
    }
  ],
