  "materials": [
    "Eppendorf tube",
    "PCR tube",
    "Edward's buffer",
    "RNase A",
    "Proteinase K",
    "3M sodium acetate",
    "isopropyl alcohol",
    "70% ethanol"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Spin down 1 ml of sample for 1 minute at max speed and decant",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Resuspend vigorously with 100ul Edward&#39;s buffer",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Transfer carefully to PCR tube - mixture will be viscous",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Add 2ul of RNase A and mix vigorously, vortex for 10 seconds",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Incubate at 37C for 15 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 2ul of Proteinase K and mix vigorously, vortex for 10 seconds",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Incubate at 55C for 1 hour, and deactivate via incubation at 95C for 10 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Transfer to 1.5ml eppendorf tube",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add 10% 3M (pH 5.4) sodium acetate, and 1:1 volume of 100% isopropyl alcohol",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Invert tube 10 times - precipitates should begin to form",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Spin down at max speed for 5 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Decant the supernatant carefully",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Add 1ml of 70% EtOH and resuspend the pellet",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Spin down at max speed for 5 minutes",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Repeat 70% EtOH resuspension and washing step at least 2 more times",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Decant completely and dry the pellet for 5 minutes - do not let the pellet overdry",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 16,
      "title": "",
      "instruction": "Resuspend in storage buffer of choice or dH2O to wanted volume",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 17,
      "title": "",
      "instruction": "Incubate in a 37C shaker for 1 hour - the extract is likely to be not dissolved fully",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 18,
      "title": "",
      "instruction": "Incubate in 4C overnight - depending on yield, the extract will be extremely viscous",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 19,
      "title": "",
      "instruction": "Check extraction quality using both standard gel electrophoresis and UV-Vis method such as Nanodrop.",
      "is_critical": false,
      "timers": []
    }
  ],
  "verification_status": "verified",
  "merged_at": "2026-06-18"
}