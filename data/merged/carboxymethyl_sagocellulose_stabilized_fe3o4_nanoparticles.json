  "materials": [
    "ferric chloride hexahydrate",
    "sodium acetate",
    "Fe3O4 nanoparticles",
    "ethanol",
    "APS",
    "EDC",
    "sulfo-NHS",
    "CMSC",
    "PBS",
    "5-FU",
    "HeLa cells",
    "808 nm laser",
    "autoclave",
    "magnet"
  ],
  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Dissolve 1.08 g of ferric chloride hexahydrate and 3.0 g of sodium acetate in 40 mL of ethylene glycol.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "Homogenize the solution and transfer it to an autoclave.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "Heat at 200 °C for 10 hours.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "Allow the solution to cool, then wash the precipitate with deionized water and dry at 30 °C overnight.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Disperse 0.60 g of Fe3O4 nanoparticles in 350 mL of ethanol and 3 mL of deionized water.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Add 4 mL of APS and stir for 12 hours under nitrogen atmosphere at room temperature.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Wash the precipitate with deionized water and dry at 30 °C overnight.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "Dissolve 1 g of CMSC in 200 mL of PBS (pH 7.0).",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "Add EDC and sulfo-NHS at a molar ratio of 0.5 relative to the carboxyl groups of CMSC.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "Stir for 12 hours in the dark.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "Dialyze against distilled water for 6 hours to remove unreacted EDC and sulfo-NHS.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Mix the activated CMSC with 5-FU and Fe3O4-NH2 nanoparticles, stir for 12 hours.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 12,
      "title": "",
      "instruction": "Recover the nanoparticles using a magnet, wash with deionized water, and dry.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 13,
      "title": "",
      "instruction": "Incubate HeLa cells with Fe3O4-CMSC-5FU nanoparticles at concentrations of 75, 150, and 300 μg/mL for 12 hours.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 14,
      "title": "",
      "instruction": "Irradiate with an 808 nm laser at a power density of 2 W/cm² for 1-3 minutes.",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 15,
      "title": "",
      "instruction": "Assess cell viability using MTT assay.",
      "is_critical": false,
      "timers": []
    }
  ],
  "verification_status": "verified",
  "merged_at": "2026-06-18"
}