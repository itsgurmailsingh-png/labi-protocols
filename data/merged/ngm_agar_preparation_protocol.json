  "steps": [
    {
      "step_id": 0,
      "title": "",
      "instruction": "Start with 975 mL, water",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 1,
      "title": "",
      "instruction": "3.0 g NaCl",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 2,
      "title": "",
      "instruction": "2.5 g Peptone",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 3,
      "title": "",
      "instruction": "17 g Agar",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 4,
      "title": "",
      "instruction": "Autoclave with stir bar",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 5,
      "title": "",
      "instruction": "Cool to 55 °C (faster in water bath)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 6,
      "title": "",
      "instruction": "Then add the following while stirring on heat plate (DO NOT OVERHEAT)",
      "is_critical": true,
      "timers": []
    },
    {
      "step_id": 7,
      "title": "",
      "instruction": "0.5 mL of 1 Molarity (M) CaCl2 (sterile)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 8,
      "title": "",
      "instruction": "1 mL of 5 mg/mL Cholesterol (dissolved in ethanol)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 9,
      "title": "",
      "instruction": "1 mL of 1 Molarity (M) MgSO4 (sterile)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 10,
      "title": "",
      "instruction": "25 mL of 1 Molarity (M) Potassium Phosphate Buffer, pH 6.0 (sterile)",
      "is_critical": false,
      "timers": []
    },
    {
      "step_id": 11,
      "title": "",
      "instruction": "Pour into petri dishes using sterile technique 60 mm dishes = About 7 mL per plate 100 mm dishes = About 20 mL per plate",
      "is_critical": false,
      "timers": []
    }
